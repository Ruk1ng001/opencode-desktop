+// [dokng] preview 字段是「示例图 markdown + 可选说明文字」拼出来的（见 services/api/prompts.ts
+// 的 markdownPreview / davidWu preview）。上游 v0.9.0 用 <pre> 原样直出，导致 ![](url) 退化成
+// 一串裸文本、图片压根不渲染。这里做一个零依赖的轻量解析：把 markdown 图片语法 ![alt](url) 抽成
+// 真正的 <img>，其余非空行按说明文字保留。不引 react-markdown，只认我们自己 preview 产出的两种片段。
+type PreviewSegment = { type: "image"; url: string; alt: string } | { type: "text"; text: string };
+
+function parsePreview(preview: string): PreviewSegment[] {
+    const segments: PreviewSegment[] = [];
+    const imagePattern = /!\[([^\]]*)]\(([^)\s]+)[^)]*\)/g;
+    let lastIndex = 0;
+    let match: RegExpExecArray | null;
+    const pushText = (raw: string) => {
+        const text = raw.trim();
+        if (text) segments.push({ type: "text", text });
+    };
+    while ((match = imagePattern.exec(preview))) {
+        pushText(preview.slice(lastIndex, match.index));
+        segments.push({ type: "image", alt: match[1] || "", url: match[2] });
+        lastIndex = imagePattern.lastIndex;
+    }
+    pushText(preview.slice(lastIndex));
+    return segments;
+}
