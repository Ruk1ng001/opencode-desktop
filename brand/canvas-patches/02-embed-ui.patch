+// [dokng] GitHub raw 域（raw.githubusercontent.com）国内基本不可达，导致提示词 markdown /
+// 封面图拉取失败、图片显示不出来。统一改走 jsDelivr 的 GitHub 镜像（cdn.jsdelivr.net/gh），
+// 把 raw.githubusercontent.com/{owner}/{repo}/{ref}/... 重写为 cdn.jsdelivr.net/gh/{owner}/{repo}@{ref}/...。
+// 应用到下方 5 个 base 常量（markdown / json / 拼接图片全部经此）与 absoluteImage（兜住
+// markdown 内嵌的绝对 raw 链接）。非 raw 域链接原样返回，不影响其它来源。
+function toCdn(url: string) {
+    return url.replace(/^https:\/\/raw\.githubusercontent\.com\/([^/]+)\/([^/]+)\/([^/]+)(\/.*)?$/, "https://cdn.jsdelivr.net/gh/$1/$2@$3$4");
+}
+
+const awesomeGptImageRawBase = toCdn("https://raw.githubusercontent.com/ZeroLu/awesome-gpt-image/main");
+const awesomeGpt4oImagePromptsBase = toCdn("https://raw.githubusercontent.com/ImgEdify/Awesome-GPT4o-Image-Prompts/main");
+const youMindGptImage2RawBase = toCdn("https://raw.githubusercontent.com/YouMind-OpenLab/awesome-gpt-image-2/main");
+const youMindNanoBananaProRawBase = toCdn("https://raw.githubusercontent.com/YouMind-OpenLab/awesome-nano-banana-pro-prompts/main");
+const davidWuGptImage2RawBase = toCdn("https://raw.githubusercontent.com/davidwuw0811-boop/awesome-gpt-image2-prompts/main");
 const cacheTtlMs = 1000 * 60 * 60;
