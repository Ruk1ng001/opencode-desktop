+  "border-radius": "8px",
+  padding: "14px 16px",
+  "margin-bottom": "12px",
+}
+
+// [cx] US-008: 激活 key 卡片的选中态（高亮边框 + 淡蓝底）。
+const activeCardStyle: JSX.CSSProperties = {
+  border: "1px solid rgba(59,130,246,0.7)",
+  background: "rgba(59,130,246,0.10)",
+}
+
+const cardHeadStyle: JSX.CSSProperties = {
+  display: "flex",
+  "align-items": "center",
+  gap: "10px",
+  "margin-bottom": "10px",
+}
+
+const miniAvatarStyle: JSX.CSSProperties = {
+  width: "28px",
+  height: "28px",
+  "border-radius": "9999px",
+  "object-fit": "cover",
+  border: "1px solid rgba(255,255,255,0.12)",
+}
+
+const miniAvatarFallbackStyle: JSX.CSSProperties = {
+  width: "28px",
+  height: "28px",
+  "border-radius": "9999px",
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "center",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "13px",
+  "font-weight": "600",
+}
+
+const cardLabelStyle: JSX.CSSProperties = {
+  "font-size": "14px",
+  "font-weight": "600",
+  color: "#f5f5f5",
+}
+
+const cardKeyStyle: JSX.CSSProperties = {
+  "font-size": "12px",
+  color: "#9ca3af",
+  "font-family": "monospace",
+}
+
+const activeBadgeStyle: JSX.CSSProperties = {
+  "margin-left": "auto",
+  padding: "2px 8px",
+  "border-radius": "9999px",
+  background: "rgba(59,130,246,0.85)",
+  color: "#ffffff",
+  "font-size": "11px",
+  "font-weight": "600",
+}
+
+const cardMetricsStyle: JSX.CSSProperties = {
+  display: "flex",
+  gap: "16px",
+}
+
+const metricLabelStyle: JSX.CSSProperties = {
+  "font-size": "11px",
+  color: "#9ca3af",
+  "margin-bottom": "2px",
+}
+
+const metricValueStyle: JSX.CSSProperties = {
+  "font-size": "15px",
+  "font-weight": "600",
+  color: "#f5f5f5",
+}
+
+const cardStateStyle: JSX.CSSProperties = {
+  "font-size": "12px",
+  color: "#9ca3af",
+}
+
+const cardUserRowStyle: JSX.CSSProperties = {
+  display: "flex",
+  "align-items": "center",
+  gap: "6px",
+  "font-size": "12px",
+  color: "#cbd5e1",
+  "margin-bottom": "8px",
+}
+
+// 账户已用占比（0~100，整数）。总额度为 0 时返回 0，避免除零。
+function usedPercent(usedQuota: number, quota: number): number {
+  if (quota <= 0) return 0
+  return Math.min(100, Math.max(0, Math.round((usedQuota / quota) * 100)))
+}
+
+// [cx] US-008: 单张 key 卡片。按各自 key 独立展示 profile（loading/error/ready）。
+function KeyCard(props: { entry: ResolvedKey; state: KeyProfileState | undefined }) {
+  const state = () => props.state ?? ({ status: "loading" } as KeyProfileState)
+  return (
+    <div style={props.entry.isActive ? { ...cardStyle, ...activeCardStyle } : cardStyle}>
+      <div style={cardHeadStyle}>
+        <div>
+          <div style={cardLabelStyle}>{props.entry.label}</div>
+          <div style={cardKeyStyle}>{maskKey(props.entry.key)}</div>
+        </div>
+        <Show when={props.entry.isActive}>
+          <span style={activeBadgeStyle}>激活</span>
+        </Show>
+      </div>
+
+      <Switch>
+        <Match when={state().status === "loading"}>
+          <div style={cardStateStyle}>加载中…</div>
+        </Match>
+
+        <Match when={state() as Extract<KeyProfileState, { status: "error" }>} keyed>
+          {(err) => <div style={cardStateStyle}>获取失败：{err.message}</div>}
+        </Match>
+
+        <Match when={state() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+          {(ready) => (
+            <>
+              {/* 该 key 所属账户的头像 + 用户名（不同 key 可能是不同账户）。 */}
+              <div style={cardUserRowStyle}>
+                <Show
+                  when={ready.avatar}
+                  fallback={<div style={miniAvatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                >
+                  <img src={ready.avatar} alt="头像" style={miniAvatarStyle} />
+                </Show>
+                <span>{ready.username || "未命名用户"}</span>
+              </div>
+
+              <div style={cardMetricsStyle}>
+                <div>
+                  <div style={metricLabelStyle}>该 key 已消耗</div>
+                  <div style={metricValueStyle}>{formatCurrency(ready.tokenUsed)}</div>
+                </div>
+                <div>
+                  <div style={metricLabelStyle}>今日消耗</div>
+                  <div style={metricValueStyle}>{formatCurrency(ready.tokenUsedToday)}</div>
+                </div>
+              </div>
+            </>
+          )}
+        </Match>
+      </Switch>
+    </div>
+  )
+}
+
+function BalancePanel(props: { onClose: () => void }) {
+  const [initializing, setInitializing] = createSignal(true)
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  // 逐 key 的 profile 状态，按 key id 索引；整份替换以触发响应式更新。
+  const [profiles, setProfiles] = createSignal<Record<string, KeyProfileState>>({})
+
+  // [cx] US-007: 充值页面 URL 在组件创建时解析一次（注入变量为构建期常量，不会变）。
+  const topupUrl = resolveTopupUrl()
+
+  const activeEntry = () => keys().find((k) => k.isActive) ?? keys()[0]
+  const activeProfile = (): KeyProfileState | undefined => {
+    const entry = activeEntry()
+    return entry ? profiles()[entry.id] : undefined
+  }
+  // 有任一 key 仍在加载即视为刷新中（一键刷新按钮据此禁用 + 改文案）。
+  const anyLoading = () => keys().some((k) => (profiles()[k.id]?.status ?? "loading") === "loading")
+
+  // 对单个 key 拉 profile：先置 loading（加载反馈），再写入结果。
+  async function loadProfile(entry: ResolvedKey): Promise<void> {
+    setProfiles((prev) => ({ ...prev, [entry.id]: { status: "loading" } }))
+    const result = await fetchProfileWith(entry.baseURL, entry.key)
+    setProfiles((prev) => ({ ...prev, [entry.id]: result }))
+  }
+
+  // [cx] US-008: 一键刷新——对所有可见 key 重新拉取 profile。
+  function refreshAll(): void {
+    for (const entry of keys()) void loadProfile(entry)
+  }
+
+  onMount(() => {
+    void resolveKeyList().then((list) => {
+      setKeys(list)
+      setInitializing(false)
+      refreshAll()
+    })
+  })
+
+  return (
+    <div style={overlayStyle} onClick={props.onClose} role="presentation">
+      <div
+        style={panelStyle}
+        role="dialog"
+        aria-modal="true"
+        aria-label="账户面板"
+        onClick={(event) => event.stopPropagation()}
+      >
+        <div style={headerStyle}>
+          <span style={{ "font-size": "16px", "font-weight": "600" }}>账户</span>
+          <button type="button" style={closeButtonStyle} aria-label="关闭" onClick={props.onClose}>
+            ✕
+          </button>
+        </div>
+
+        <Switch>
+          <Match when={initializing()}>
+            <div style={stateBoxStyle}>正在加载…</div>
+          </Match>
+
+          <Match when={keys().length === 0}>
+            <div style={stateBoxStyle}>
+              尚未配置渠道凭据
+              <br />
+              请在设置中添加 key,或在打包/启动时注入 NEWAPI_BASE_URL 与 NEWAPI_API_KEY
+            </div>
+          </Match>
+
+          <Match when={keys().length > 0}>
+            {/* [cx] US-008: 顶部账户汇总（激活 key 账户）。 */}
+            <div style={summaryStyle}>
+              <div style={summaryHeadStyle}>
+                <Show
+                  when={(() => {
+                    const p = activeProfile()
+                    return p && p.status === "ready" ? p : undefined
+                  })()}
+                  fallback={<div style={avatarFallbackStyle}>?</div>}
+                  keyed
+                >
+                  {(ready) => (
+                    <Show
+                      when={ready.avatar}
+                      fallback={<div style={avatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                    >
+                      <img src={ready.avatar} alt="头像" style={avatarStyle} />
+                    </Show>
+                  )}
+                </Show>
+                <span style={usernameStyle}>
+                  <Show
+                    when={(() => {
+                      const p = activeProfile()
+                      return p && p.status === "ready" ? p.username : ""
+                    })()}
+                    fallback="当前账户"
+                    keyed
+                  >
+                    {(name) => <>{name}</>}
+                  </Show>
+                </span>
+                <button
+                  type="button"
+                  style={refreshButtonStyle}
+                  disabled={anyLoading()}
+                  aria-disabled={anyLoading()}
+                  onClick={refreshAll}
+                >
+                  {anyLoading() ? "刷新中…" : "一键刷新"}
+                </button>
+              </div>
+
+              <Switch>
+                <Match when={(activeProfile()?.status ?? "loading") === "loading"}>
+                  <div style={cardStateStyle}>正在获取账户额度…</div>
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "error" }>} keyed>
+                  {(err) => <div style={cardStateStyle}>获取失败：{err.message}</div>}
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+                  {(ready) => (
+                    <>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户总额度</span>
+                        <span style={summaryValueStyle}>{formatCurrency(ready.quota)}</span>
+                      </div>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户已用</span>
+                        <span style={summaryValueStyle}>
+                          {formatCurrency(ready.usedQuota)}({usedPercent(ready.usedQuota, ready.quota)}%)
+                        </span>
+                      </div>
+                      <div style={progressTrackStyle}>
+                        <div
+                          style={{
+                            width: `${usedPercent(ready.usedQuota, ready.quota)}%`,
+                            height: "100%",
+                            background: "#3b82f6",
+                          }}
+                        />
+                      </div>
+                    </>
+                  )}
+                </Match>
+              </Switch>
+            </div>
+
+            {/* [cx] US-008: key 卡片列表。每张卡片按各自 key 独立查询 profile。 */}
+            <div style={sectionTitleStyle}>Key 列表({keys().length})</div>
+            <For each={keys()}>{(entry) => <KeyCard entry={entry} state={profiles()[entry.id]} />}</For>
+          </Match>
+        </Switch>
+
+        {/* [cx] US-007: 充值入口。点击经 window.api.openLink 在系统默认浏览器打开充值页面。
+            URL 已配置时按钮可点;未配置(注入变量与站点根都缺失)时禁用并提示。 */}
+        <button
+          type="button"
+          style={topupButtonStyle}
+          disabled={!topupUrl}
+          aria-disabled={!topupUrl}
+          onClick={() => openTopup(topupUrl)}
+        >
+          充值
+        </button>
+
+        <Show when={!topupUrl}>
+          <div style={hintStyle}>未配置充值地址,请注入 NEWAPI_TOPUP_URL 或 NEWAPI_BASE_URL</div>
+        </Show>
+      </div>
+    </div>
+  )
+}
+
+// 独立入口 + 面板容器。挂载在聊天界面之外,自管理开合状态,不与聊天 UI 共享任何上下文。
+export function BalanceLauncher() {
+  const [open, setOpen] = createSignal(false)
+  // [cx] US-007/US-008: 入口按钮上展示当前激活 key 账户的头像/用户名。挂载时按激活 key
+  // 凭据拉一次 profile(resolveActiveCreds 优先本地激活项、回退构建期变量;fetchProfileWith
+  // 内部已捕获所有错误、永不抛出);仅在 ready 态用真实身份,其余态(无凭据/加载中/失败)
+  // 回退到静态「账户」文字,保证入口永远可点、绝不崩溃。
+  const [identity, setIdentity] = createSignal<{ username: string; avatar: string } | null>(null)
+
+  onMount(() => {
+    void resolveActiveCreds().then((creds) => {
+      if (!creds) return
+      void fetchProfileWith(creds.baseURL, creds.apiKey).then((state) => {
+        if (state.status === "ready") {
+          setIdentity({ username: state.username, avatar: state.avatar })
+        }
+      })
+    })
+  })
+
+  return (
+    <>
+      <button type="button" style={launcherStyle} aria-label="打开账户面板" onClick={() => setOpen(true)}>
+        <Show when={identity()} fallback={<span>账户</span>} keyed>
+          {(who) => (
+            <>
+              <Show
+                when={who.avatar}
+                fallback={<div style={launcherAvatarFallbackStyle}>{avatarInitial(who.username)}</div>}
+              >
+                <img src={who.avatar} alt="头像" style={launcherAvatarStyle} />
+              </Show>
+              <span>{who.username || "账户"}</span>
+            </>
+          )}
+        </Show>
+      </button>
+      <Show when={open()}>
+        <BalancePanel onClose={() => setOpen(false)} />
+      </Show>
+    </>
+  )
+}
