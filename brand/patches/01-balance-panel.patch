+            </button>
+          </div>
+        </Show>
+
+        <Switch>
+          <Match when={initializing()}>
+            <div style={stateBoxStyle}>正在加载…</div>
+          </Match>
+
+          {/* [cx] US-011: 首启无 key 引导。本地 key 列表为空且无内置默认 key（resolveKeyList
+              返回空数组）时，展示明确的引导提示，说明「导入你的第一个 key 即可开始」，并直接
+              展开新增 key 表单（startOpen）——引导即进入 US-009 的新增 key 流程，无需二次点击。
+              有内置默认 key 或已有 key 时走 keys().length > 0 分支，不显示本引导。 */}
+          <Match when={keys().length === 0}>
+            <div style={onboardBoxStyle}>
+              <div style={onboardIconStyle}>🔑</div>
+              <div style={onboardTitleStyle}>还没有可用的 key</div>
+              <div style={onboardDescStyle}>
+                导入一个 API Key（sk-…）即可开始使用。
+                <br />
+                在下方粘贴你的 key 完成导入。
+              </div>
+            </div>
+            <AddKeyForm onAdd={handleAdd} startOpen />
+          </Match>
+
+          <Match when={keys().length > 0}>
+            {/* [cx] US-008: 顶部账户汇总（激活 key 账户）。 */}
+            <div style={summaryStyle}>
+              <div style={summaryHeadStyle}>
+                <Show
+                  when={(() => {
+                    const p = activeProfile()
+                    return p && p.status === "ready" ? p : undefined
+                  })()}
+                  fallback={<div style={avatarFallbackStyle}>?</div>}
+                  keyed
+                >
+                  {(ready) => (
+                    <Show
+                      when={ready.avatar}
+                      fallback={<div style={avatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                    >
+                      <img src={ready.avatar} alt="头像" style={avatarStyle} />
+                    </Show>
+                  )}
+                </Show>
+                <span style={usernameStyle}>
+                  <Show
+                    when={(() => {
+                      const p = activeProfile()
+                      return p && p.status === "ready" ? p.username : ""
+                    })()}
+                    fallback="当前账户"
+                    keyed
+                  >
+                    {(name) => <>{name}</>}
+                  </Show>
+                </span>
+                <button
+                  type="button"
+                  style={refreshButtonStyle}
+                  disabled={anyLoading()}
+                  aria-disabled={anyLoading()}
+                  onClick={refreshAll}
+                >
+                  {anyLoading() ? "刷新中…" : "一键刷新"}
+                </button>
+              </div>
+
+              <Switch>
+                <Match when={(activeProfile()?.status ?? "loading") === "loading"}>
+                  <div style={cardStateStyle}>正在获取账户额度…</div>
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "error" }>} keyed>
+                  {(err) => <div style={cardStateStyle}>获取失败：{err.message}</div>}
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+                  {(ready) => (
+                    <>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户总额度</span>
+                        <span style={summaryValueStyle}>{formatCurrency(ready.quota)}</span>
+                      </div>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户已用</span>
+                        <span style={summaryValueStyle}>
+                          {formatCurrency(ready.usedQuota)}({usedPercent(ready.usedQuota, ready.quota)}%)
+                        </span>
+                      </div>
+                      <div style={progressTrackStyle}>
+                        <div
+                          style={{
+                            width: `${usedPercent(ready.usedQuota, ready.quota)}%`,
+                            height: "100%",
+                            background: "#3b82f6",
+                          }}
+                        />
+                      </div>
+                    </>
+                  )}
+                </Match>
+              </Switch>
+            </div>
+
+            {/* [cx] US-008/US-009: key 卡片列表。点击非激活卡片切换激活；每张可编辑名称/删除。 */}
+            <div style={sectionTitleStyle}>
+              <span>Key 列表({keys().length})</span>
+              <span style={{ "font-size": "11px" }}>点击卡片切换激活</span>
+            </div>
+            <For each={keys()}>
+              {(entry) => (
+                <KeyCard
+                  entry={entry}
+                  state={profiles()[entry.id]}
+                  switching={switchingId() === entry.id}
+                  onActivate={(e) => void handleActivate(e)}
+                  onSaveLabel={(id, label) => void handleSaveLabel(id, label)}
+                  onRemove={(id) => void handleRemove(id)}
+                />
+              )}
+            </For>
+
+            {/* [cx] US-009: 新增 key 表单。 */}
+            <AddKeyForm onAdd={handleAdd} />
+          </Match>
+        </Switch>
+
+        {/* [cx] US-007: 充值入口。点击经 window.api.openLink 在系统默认浏览器打开充值页面。
+            URL 已配置时按钮可点;未配置(注入变量与站点根都缺失)时禁用并提示。 */}
+        <button
+          type="button"
+          style={topupButtonStyle}
+          disabled={!topupUrl()}
+          aria-disabled={!topupUrl()}
+          onClick={() => openTopup(topupUrl())}
+        >
+          充值
+        </button>
+
+        <Show when={!topupUrl()}>
+          <div style={hintStyle}>未配置充值地址,请注入 NEWAPI_TOPUP_URL 或 NEWAPI_BASE_URL</div>
+        </Show>
+      </div>
+    </div>
+  )
+}
+
+// 独立入口 + 面板容器。挂载在聊天界面之外,自管理开合状态,不与聊天 UI 共享任何上下文。
+export function BalanceLauncher() {
+  const [open, setOpen] = createSignal(false)
+  // [cx] US-007/US-008: 入口按钮上展示当前激活 key 账户的头像/用户名。挂载时按激活 key
+  // 凭据拉一次 profile(resolveActiveCreds 优先本地激活项、回退构建期变量;fetchProfileWith
+  // 内部已捕获所有错误、永不抛出);仅在 ready 态用真实身份,其余态(无凭据/加载中/失败)
+  // 回退到静态「账户」文字,保证入口永远可点、绝不崩溃。
+  const [identity, setIdentity] = createSignal<{ username: string; avatar: string } | null>(null)
+  // [cx] US-011: 首启无 key 引导。resolveActiveCreds() 返回 null 恰好等价于「本地 key 列表
+  // 为空且无内置默认 key」（既无本地条目、又无构建期注入的 NEWAPI_BASE_URL/API_KEY）——此时
+  // 入口按钮切换为引导态（「导入 key」+ 提示样式），点击打开面板进入 US-009 新增流程。
+  // 有内置默认 key 或已有 key 时 creds 非空，noKeys 保持 false，入口走正常账户展示。
+  const [noKeys, setNoKeys] = createSignal(false)
+  // [cx] US-012: 自动切换 key 的用户可见提示（切到了哪个 key / 全部不可用）。
+  const [autoSwitch, setAutoSwitch] = createSignal<AutoSwitchNotice | null>(null)
+
+  onMount(() => {
+    void resolveActiveCreds().then((creds) => {
+      if (!creds) {
+        setNoKeys(true)
+        return
+      }
+      void fetchProfileWith(creds.baseURL, creds.apiKey).then((state) => {
+        if (state.status === "ready") {
+          setIdentity({ username: state.username, avatar: state.avatar })
+        }
+      })
+    })
+
+    // [cx] US-012: 常驻订阅内核调用失败事件，命中「额度耗尽 / key 失效」即自动切换到
+    // 下一个可用 key。放在常驻的 BalanceLauncher（挂在聊天 UI 树之外）里，全程独立运行。
+    const abort = new AbortController()
+    void subscribeSessionErrors((error) => void handleKernelCallError(error, setAutoSwitch), abort.signal)
+    onCleanup(() => abort.abort())
+  })
+
+  return (
+    <>
+      {/* [cx] US-012: 自动切换提示条（固定在界面顶部，不进聊天 UI）。 */}
+      <Show when={autoSwitch()} keyed>
+        {(notice) => (
+          <div style={notice.kind === "exhausted" ? { ...autoSwitchBannerStyle, ...autoSwitchExhaustedStyle } : autoSwitchBannerStyle}>
+            <span style={{ flex: "1" }}>{notice.message}</span>
+            <Show when={notice.kind === "switched"}>
+              <button type="button" style={bannerButtonStyle} onClick={() => window.api.relaunch()}>
+                立即重启
+              </button>
+            </Show>
+            <button
+              type="button"
+              style={{ ...closeButtonStyle, "font-size": "14px" }}
+              aria-label="关闭提示"
+              onClick={() => setAutoSwitch(null)}
+            >
+              ✕
+            </button>
+          </div>
+        )}
+      </Show>
+      <button
+        type="button"
+        style={noKeys() ? { ...launcherStyle, ...launcherOnboardStyle } : launcherStyle}
+        aria-label={noKeys() ? "导入 key 开始使用" : "打开账户面板"}
+        onClick={() => setOpen(true)}
+      >
+        <Show
+          when={!noKeys()}
+          fallback={
+            <>
+              <span aria-hidden="true">🔑</span>
+              <span>导入 key</span>
+            </>
+          }
+        >
+          <Show when={identity()} fallback={<span>账户</span>} keyed>
+            {(who) => (
+              <>
+                <Show
+                  when={who.avatar}
+                  fallback={<div style={launcherAvatarFallbackStyle}>{avatarInitial(who.username)}</div>}
+                >
+                  <img src={who.avatar} alt="头像" style={launcherAvatarStyle} />
+                </Show>
+                <span>{who.username || "账户"}</span>
+              </>
+            )}
+          </Show>
+        </Show>
+      </button>
+      <Show when={open()}>
+        <BalancePanel onClose={() => setOpen(false)} />
+      </Show>
+    </>
+  )
+}
