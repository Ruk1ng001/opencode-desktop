+// [cx] US-009: 新增 key 表单。粘贴 sk-…（必填）+ 可选 label / baseURL。key 明文只在内存流转，
+// 提交经 channelKeysAdd 写入本地 store；不打印、不写日志。
+// [cx] US-011: startOpen —— 首启无 key 引导时直接展开表单（引导即进入新增 key 流程），
+// 无需用户再点一次「+ 新增 key」。
+function AddKeyForm(props: {
+  onAdd: (input: { label: string; key: string; baseURL: string }) => Promise<void>
+  startOpen?: boolean
+}) {
+  const [open, setOpen] = createSignal(props.startOpen ?? false)
+  const [key, setKey] = createSignal("")
+  const [label, setLabel] = createSignal("")
+  const [baseURL, setBaseURL] = createSignal("")
+  const [error, setError] = createSignal("")
+  const [saving, setSaving] = createSignal(false)
+
+  function reset() {
+    setKey("")
+    setLabel("")
+    setBaseURL("")
+    setError("")
+  }
+
+  async function submit() {
+    const k = key().trim()
+    if (!k) {
+      setError("请粘贴 API Key（sk-…）")
+      return
+    }
+    setSaving(true)
+    try {
+      await props.onAdd({ label: label().trim(), key: k, baseURL: baseURL().trim() })
+      reset()
+      setOpen(false)
+    } finally {
+      setSaving(false)
+    }
+  }
+
+  return (
+    <Show
+      when={open()}
+      fallback={
+        <button type="button" style={{ ...smallButtonStyle, width: "100%", padding: "8px" }} onClick={() => setOpen(true)}>
+          + 新增 key
+        </button>
+      }
+    >
+      <div style={addFormStyle}>
+        <input
+          style={inputStyle}
+          value={key()}
+          type="password"
+          autocomplete="off"
+          placeholder="API Key（sk-…，必填）"
+          onInput={(e) => setKey(e.currentTarget.value)}
+          aria-label="API Key"
+        />
+        <input
+          style={inputStyle}
+          value={label()}
+          placeholder="名称（可选）"
+          onInput={(e) => setLabel(e.currentTarget.value)}
+          aria-label="key 名称"
+        />
+        <input
+          style={inputStyle}
+          value={baseURL()}
+          placeholder="baseURL（可选，缺省用内置渠道地址）"
+          onInput={(e) => setBaseURL(e.currentTarget.value)}
+          aria-label="baseURL"
+        />
+        <Show when={error()}>
+          <div style={{ "font-size": "12px", color: "#fca5a5", "margin-bottom": "8px" }}>{error()}</div>
+        </Show>
+        <div style={{ display: "flex", gap: "8px" }}>
+          <button
+            type="button"
+            style={{ ...primarySmallButtonStyle, flex: "1" }}
+            disabled={saving()}
+            aria-disabled={saving()}
+            onClick={submit}
+          >
+            {saving() ? "保存中…" : "添加"}
+          </button>
+          <button
+            type="button"
+            style={smallButtonStyle}
+            onClick={() => {
+              reset()
+              setOpen(false)
+            }}
+          >
+            取消
+          </button>
+        </div>
+      </div>
+    </Show>
+  )
+}
