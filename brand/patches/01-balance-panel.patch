+// [cx] 独立账户面板 —— 对接 new-api 取用户名/头像/额度/用量（US-006）+ 充值入口（US-007）
+//
+// 设计约束（见 TODO.md / brand/docs/api-app-profile.md / 验收标准）：
+//   - 独立展示区域，与 opencode 原有聊天 UI 组件完全解耦；本文件不 import 任何
+//     上游 app / session-ui 组件，仅依赖 solid-js，可离线 typecheck。
+//   - 明确入口：一个独立悬浮按钮「账户」，点击打开全屏浮层面板。
+//   - 打开面板时向 new-api 只读 profile 接口（GET /api/app/profile）拉取真实
+//     用户名/头像/额度/用量，解析后做单位换算与中文标注。
+//   - [cx] US-006: 端点从旧的 /api/user/self 改为 /api/app/profile。旧端点走
+//     用户会话/系统令牌鉴权，用 sk- API Token 调会失败（TODO 第七节风险 #3）；
+//     新端点走 token 鉴权中间件（同 /v1/*），由 sk- 定位 token → 本人 profile
+//     （见 brand/docs/api-app-profile.md）。
+//   - baseURL 与鉴权凭据复用 US-003 注入的同名变量（NEWAPI_BASE_URL / NEWAPI_API_KEY），
+//     经 electron.vite renderer.define 注入到 import.meta.env，本文件不硬编码任何地址/密钥。
+//   - 四种数据状态各有明确提示：加载中 / 请求失败 / 未配置凭据 / 就绪。
+//   - 全部网络请求包在 try/catch 内，任何错误都落入 error 态，绝不抛出，
+//     不阻塞主程序，也不让面板崩溃。
+//   - 全部中文文案。样式用内联对象，不依赖上游 tailwind / 主题变量。
+//   - US-007 充值入口：面板含「充值」按钮，点击后经 window.api.openLink（→ 主进程
+//     shell.openExternal）在系统默认浏览器打开 new-api 充值页面。充值 URL 走注入变量
+//     NEWAPI_TOPUP_URL，缺省回退到 new-api 站点根。客户端内不实现任何支付逻辑。
+
+import { createSignal, onMount, Show, Switch, Match } from "solid-js"
+import type { JSX } from "solid-js"
+
+// [cx] US-006: new-api 只读 profile 接口路径（站点根下，非 /v1 渠道端点）。
+// 走 token 鉴权中间件，由 Bearer sk- 定位 token → 返回本人 profile。
+// 见 brand/docs/api-app-profile.md。替换旧的 /api/user/self（sk- 鉴权失败）。
+const APP_PROFILE_PATH = "/api/app/profile"
+
+// new-api 默认 QuotaPerUnit：500000 额度 = 1 美元（common.QuotaPerUnit 默认值）。
+// 若目标站点改了该值，展示的货币金额会有偏差——额度原值同时展示以便对照。
+const QUOTA_PER_UNIT = 500000
+
+// 从渠道 baseURL（US-003 的 NEWAPI_BASE_URL，如 https://host/v1）推导 new-api 站点根，
+// 用户接口挂在站点根 /api 下而非 /v1 渠道端点下。
+function deriveApiBase(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return trimmed.replace(/\/v1$/, "")
+}
+
+// [cx] US-007: 解析充值页面 URL。优先用注入变量 NEWAPI_TOPUP_URL（构建期由
+// electron.vite renderer.define 从 process.env 注入），缺省回退到 new-api 站点根
+// （由渠道 baseURL 推导）。两者都缺失时返回空串，此时不渲染充值入口。
+function resolveTopupUrl(): string {
+  const topup = (import.meta.env.NEWAPI_TOPUP_URL ?? "").trim()
+  if (topup) return topup
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  return deriveApiBase(baseURL)
+}
+
+// [cx] US-007: 在系统默认浏览器打开充值页面。renderer 是浏览器上下文，不能直接调
+// electron shell，走 preload 暴露的 window.api.openLink（→ 主进程 ipc "open-link"
+// → shell.openExternal，见 packages/desktop/src/main/ipc.ts）。客户端内不实现任何
+// 支付逻辑，只负责把充值 URL 交给系统浏览器。
+function openTopup(url: string): void {
+  if (!url) return
+  try {
+    window.api.openLink(url)
+  } catch {
+    // openLink 只是发一条 ipc 消息，正常不会抛出；即便异常也不应让面板崩溃。
+  }
+}
+
+// 额度 → 美元金额（两位小数）。
+function formatCurrency(quotaUnits: number): string {
+  return "$" + (quotaUnits / QUOTA_PER_UNIT).toFixed(2)
+}
+
+// 额度原值本地化（千分位）。
+function formatUnits(quotaUnits: number): string {
+  return quotaUnits.toLocaleString("zh-CN")
+}
+
+// [cx] US-006: 无头像时的占位首字（取用户名首个字符，空则用「?」）。
+function avatarInitial(username: string): string {
+  const trimmed = username.trim()
+  return trimmed ? trimmed[0].toUpperCase() : "?"
+}
+
+// [cx] US-006: profile 就绪态承载 8 个字段（用户名/头像/账户额度/key 用量/是否不限额）。
+// 额度类字段均为 new-api 原始 quota 整数，换算/显示在渲染层做。
+type ProfileData = {
+  username: string
+  avatar: string
+  quota: number
+  usedQuota: number
+  tokenRemain: number
+  tokenUsed: number
+  tokenUsedToday: number
+  unlimited: boolean
+}
+
+type BalanceState =
+  | { status: "unconfigured" }
+  | { status: "loading" }
+  | { status: "error"; message: string }
+  | ({ status: "ready" } & ProfileData)
+
+// [cx] US-006: /api/app/profile 响应信封（见 brand/docs/api-app-profile.md 第 3 节）。
+// 字段全部可选，做防御性解析——缺字段回退到 0 / "" / false，不因缺项崩溃。
+// 契约未强约束是否带 success 信封（错误体格式以现网为准），故按 HTTP status 分支，
+// data 缺失时把整个 body 当作扁平 profile 兜底。
+type ProfileResponse = {
+  success?: boolean
+  message?: string
+  username?: string
+  avatar?: string
+  quota?: number
+  used_quota?: number
+  token_remain?: number
+  token_used?: number
+  token_used_today?: number
+  unlimited?: boolean
+  data?: {
+    username?: string
+    avatar?: string
+    quota?: number
+    used_quota?: number
+    token_remain?: number
+    token_used?: number
+    token_used_today?: number
+    unlimited?: boolean
+  }
+}
+
+// 拉取 profile。任何异常都被捕获并转成 error 态返回，本函数永不抛出。
+async function fetchProfile(): Promise<BalanceState> {
+  // 复用 US-003 注入的同名变量（构建期由 renderer.define 从 process.env 注入）。
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+
+  if (!baseURL || !apiKey) return { status: "unconfigured" }
+
+  try {
+    // [cx] US-006: 带该 key 的 sk- 调 /api/app/profile，走 token 鉴权中间件。
+    const url = deriveApiBase(baseURL) + APP_PROFILE_PATH
+    const res = await fetch(url, {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return { status: "error", message: `请求返回 HTTP ${res.status}` }
+
+    const body = (await res.json()) as ProfileResponse
+    // 契约可能带 success 信封；显式 success === false 视为失败。
+    if (body.success === false) {
+      return { status: "error", message: body.message || "接口返回失败" }
+    }
+    // profile 字段可能在 data 信封内或扁平在 body 顶层，两者都兼容。
+    const p = body.data ?? body
+    return {
+      status: "ready",
+      username: p.username ?? "",
+      avatar: p.avatar ?? "",
+      quota: p.quota ?? 0,
+      usedQuota: p.used_quota ?? 0,
+      tokenRemain: p.token_remain ?? 0,
+      tokenUsed: p.token_used ?? 0,
+      tokenUsedToday: p.token_used_today ?? 0,
+      unlimited: p.unlimited ?? false,
+    }
+  } catch (error) {
+    return {
+      status: "error",
+      message: error instanceof Error ? error.message : "网络请求失败",
+    }
+  }
+}
+
+const Z_LAUNCHER = 9998
+const Z_OVERLAY = 9999
+
+const launcherStyle: JSX.CSSProperties = {
+  position: "fixed",
+  right: "16px",
+  bottom: "16px",
+  "z-index": String(Z_LAUNCHER),
+  display: "inline-flex",
+  "align-items": "center",
+  gap: "6px",
+  padding: "8px 14px",
+  "border-radius": "9999px",
+  border: "1px solid rgba(255,255,255,0.14)",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "13px",
+  "font-weight": "500",
+  cursor: "pointer",
+  "box-shadow": "0 2px 8px rgba(0,0,0,0.25)",
+}
+
+const overlayStyle: JSX.CSSProperties = {
+  position: "fixed",
+  inset: "0",
+  "z-index": String(Z_OVERLAY),
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "center",
+  background: "rgba(0,0,0,0.5)",
+}
+
+const panelStyle: JSX.CSSProperties = {
+  width: "min(420px, 90vw)",
+  "max-height": "90vh",
+  overflow: "auto",
+  background: "#161618",
+  color: "#e5e5e5",
+  border: "1px solid rgba(255,255,255,0.12)",
+  "border-radius": "12px",
+  padding: "20px",
+  "box-shadow": "0 12px 40px rgba(0,0,0,0.5)",
+  "font-size": "14px",
+}
+
+const headerStyle: JSX.CSSProperties = {
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "space-between",
+  "margin-bottom": "16px",
+}
+
+const cardStyle: JSX.CSSProperties = {
+  background: "rgba(255,255,255,0.04)",
+  border: "1px solid rgba(255,255,255,0.08)",
+  "border-radius": "8px",
+  padding: "14px 16px",
+  "margin-bottom": "12px",
+}
+
+const cardLabelStyle: JSX.CSSProperties = {
+  "font-size": "12px",
+  color: "#9ca3af",
+  "margin-bottom": "6px",
+}
+
+const cardValueStyle: JSX.CSSProperties = {
+  "font-size": "22px",
+  "font-weight": "600",
+  color: "#f5f5f5",
+}
+
+const cardSubStyle: JSX.CSSProperties = {
+  "font-size": "12px",
+  color: "#9ca3af",
+  "margin-top": "4px",
+}
+
+const stateBoxStyle: JSX.CSSProperties = {
+  padding: "24px 16px",
+  "text-align": "center",
+  color: "#9ca3af",
+  "font-size": "13px",
+  "line-height": "1.6",
+}
+
+const closeButtonStyle: JSX.CSSProperties = {
+  background: "transparent",
+  border: "none",
+  color: "#9ca3af",
+  "font-size": "18px",
+  cursor: "pointer",
+  "line-height": "1",
+  padding: "4px",
+}
+
+const topupButtonStyle: JSX.CSSProperties = {
+  width: "100%",
+  padding: "10px 16px",
+  "margin-top": "4px",
+  "border-radius": "8px",
+  border: "none",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "14px",
+  "font-weight": "500",
+  cursor: "pointer",
+}
+
+const hintStyle: JSX.CSSProperties = {
+  "margin-top": "10px",
+  "font-size": "12px",
+  color: "#9ca3af",
+  "text-align": "center",
+}
+
+// [cx] US-006: 用户信息头（头像 + 用户名）样式。
+const identityStyle: JSX.CSSProperties = {
+  display: "flex",
+  "align-items": "center",
+  gap: "12px",
+  "margin-bottom": "16px",
+}
+
+const avatarStyle: JSX.CSSProperties = {
+  width: "44px",
+  height: "44px",
+  "border-radius": "9999px",
+  "object-fit": "cover",
+  border: "1px solid rgba(255,255,255,0.12)",
+}
+
+const avatarFallbackStyle: JSX.CSSProperties = {
+  width: "44px",
+  height: "44px",
+  "border-radius": "9999px",
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "center",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "20px",
+  "font-weight": "600",
+}
+
+const usernameStyle: JSX.CSSProperties = {
+  "font-size": "16px",
+  "font-weight": "600",
+  color: "#f5f5f5",
+}
+
+function BalanceCard(props: { label: string; value: string; sub: string }) {
+  return (
+    <div style={cardStyle}>
+      <div style={cardLabelStyle}>{props.label}</div>
+      <div style={cardValueStyle}>{props.value}</div>
+      <div style={cardSubStyle}>{props.sub}</div>
+    </div>
+  )
+}
+
+function BalancePanel(props: { onClose: () => void }) {
+  const [state, setState] = createSignal<BalanceState>({ status: "loading" })
+
+  // [cx] US-007: 充值页面 URL 在组件创建时解析一次（注入变量为构建期常量，不会变）。
+  const topupUrl = resolveTopupUrl()
+
+  // 打开面板即拉取一次。fetchProfile 内部已捕获所有错误，这里不会抛出。
+  onMount(() => {
+    void fetchProfile().then(setState)
+  })
+
+  return (
+    <div style={overlayStyle} onClick={props.onClose} role="presentation">
+      <div
+        style={panelStyle}
+        role="dialog"
+        aria-modal="true"
+        aria-label="账户面板"
+        onClick={(event) => event.stopPropagation()}
+      >
+        <div style={headerStyle}>
+          <span style={{ "font-size": "16px", "font-weight": "600" }}>账户</span>
+          <button type="button" style={closeButtonStyle} aria-label="关闭" onClick={props.onClose}>
+            ✕
+          </button>
+        </div>
+
+        <Switch>
+          <Match when={state().status === "loading"}>
+            <div style={stateBoxStyle}>正在获取余额…</div>
+          </Match>
+
+          <Match when={state().status === "unconfigured"}>
+            <div style={stateBoxStyle}>
+              尚未配置渠道凭据
+              <br />
+              请在打包/启动时注入 NEWAPI_BASE_URL 与 NEWAPI_API_KEY
+            </div>
+          </Match>
+
+          <Match when={state() as Extract<BalanceState, { status: "error" }>} keyed>
+            {(errorState) => (
+              <div style={stateBoxStyle}>
+                获取失败
+                <br />
+                {errorState.message}
+              </div>
+            )}
+          </Match>
+
+          <Match when={state() as Extract<BalanceState, { status: "ready" }>} keyed>
+            {(ready) => (
+              <>
+                {/* [cx] US-006: 用户信息头（用户名 + 头像）。头像缺失时用用户名首字占位。 */}
+                <div style={identityStyle}>
+                  <Show
+                    when={ready.avatar}
+                    fallback={<div style={avatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                  >
+                    <img src={ready.avatar} alt="头像" style={avatarStyle} />
+                  </Show>
+                  <span style={usernameStyle}>{ready.username || "未命名用户"}</span>
+                </div>
+
+                {/* [cx] US-006: 账户级额度（user.quota + used_quota）。 */}
+                <BalanceCard
+                  label="账户余额"
+                  value={formatCurrency(ready.quota)}
+                  sub={`${formatUnits(ready.quota)} 额度`}
+                />
+                <BalanceCard
+                  label="账户已用"
+                  value={formatCurrency(ready.usedQuota)}
+                  sub={`${formatUnits(ready.usedQuota)} 额度`}
+                />
+
+                {/* [cx] US-006: 当前 key 用量。unlimited 时剩余额度显示「不限额」而非金额。 */}
+                <BalanceCard
+                  label="本 key 剩余"
+                  value={ready.unlimited ? "不限额" : formatCurrency(ready.tokenRemain)}
+                  sub={ready.unlimited ? "该 key 不限额度" : `${formatUnits(ready.tokenRemain)} 额度`}
+                />
+                <BalanceCard
+                  label="本 key 已用"
+                  value={formatCurrency(ready.tokenUsed)}
+                  sub={`今日消耗 ${formatCurrency(ready.tokenUsedToday)}`}
+                />
+              </>
+            )}
+          </Match>
+        </Switch>
+
+        {/* [cx] US-007: 充值入口。点击经 window.api.openLink 在系统默认浏览器打开充值页面。
+            URL 已配置时按钮可点；未配置（注入变量与站点根都缺失）时禁用并提示。 */}
+        <button
+          type="button"
+          style={topupButtonStyle}
+          disabled={!topupUrl}
+          aria-disabled={!topupUrl}
+          onClick={() => openTopup(topupUrl)}
+        >
+          充值
+        </button>
+
+        <Show when={!topupUrl}>
+          <div style={hintStyle}>未配置充值地址，请注入 NEWAPI_TOPUP_URL 或 NEWAPI_BASE_URL</div>
+        </Show>
+      </div>
+    </div>
+  )
+}
+
+// 独立入口 + 面板容器。挂载在聊天界面之外，自管理开合状态，不与聊天 UI 共享任何上下文。
+export function BalanceLauncher() {
+  const [open, setOpen] = createSignal(false)
+
+  return (
+    <>
+      <button type="button" style={launcherStyle} aria-label="打开账户面板" onClick={() => setOpen(true)}>
+        账户
+      </button>
+      <Show when={open()}>
+        <BalancePanel onClose={() => setOpen(false)} />
+      </Show>
+    </>
+  )
+}
