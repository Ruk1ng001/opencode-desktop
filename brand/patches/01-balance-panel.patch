+// [cx] 独立账户面板 —— 对接 new-api 取用户名/头像/额度/用量（US-006）+ 充值入口（US-007）
+//     + key 列表卡片 UI + 顶部账户汇总（US-008）+ 增删改 key 与手动切换激活 key（US-009）
+//     + 首启无 key 引导（US-011）
+//
+// 设计约束（见 TODO.md / brand/docs/api-app-profile.md / 验收标准）：
+//   - 独立展示区域，与 opencode 原有聊天 UI 组件完全解耦；本文件不 import 任何
+//     上游 app / session-ui 组件，仅依赖 solid-js，可离线 typecheck。
+//   - 明确入口：一个独立悬浮按钮「账户」，点击打开全屏浮层面板。
+//   - 打开面板时向 new-api 只读 profile 接口（GET /api/app/profile）拉取真实
+//     用户名/头像/额度/用量，解析后做单位换算与中文标注。
+//   - [cx] US-006: 端点从旧的 /api/user/self 改为 /api/app/profile。旧端点走
+//     用户会话/系统令牌鉴权，用 sk- API Token 调会失败（TODO 第七节风险 #3）；
+//     新端点走 token 鉴权中间件（同 /v1/*），由 sk- 定位 token → 本人 profile
+//     （见 brand/docs/api-app-profile.md）。
+//   - [cx] US-008: 面板不再只看构建期注入的单 key，而是读 US-003 本地 key 列表
+//     （主进程 store-channel-keys 写入的 `channelKeys`）。顶部汇总区展示「当前激活 key」
+//     账户的头像/用户名/账户总额度/账户已用（进度条）+ 一键刷新；下方逐 key 卡片，
+//     每张卡片按各自 key 独立调 /api/app/profile（不同 key 可能是不同账户），激活 key
+//     卡片有明显选中态。本地无 key 列表时回退到构建期注入的内置渠道合成单条。
+//   - [cx] US-009: 面板可管理本地 key 列表：
+//       · 新增 key —— 粘贴 sk-…（可选 label / baseURL），经 channelKeysAdd 写入本地列表；
+//       · 删除 key —— 二次确认后经 channelKeysRemove 删除（删激活项时主进程侧激活回退首项/置空）；
+//       · 修改 label —— 内联编辑保存，经 channelKeysUpdateLabel；
+//       · 点击非激活卡片切换激活 key —— 每个 key 已被主进程注入成独立 opencode provider，
+//         切换是纯前端行为：channelKeysSetActive 更新激活项 + 派发 cx:select-provider 事件，
+//         由树内桥调 useLocal().model.set 切到该 provider（同原生切 model）——**零重启、零打断**。
+//     增删 key（改变 provider 集合）走热重载：主进程重写 OPENCODE_CONFIG 文件 + POST /global/dispose，
+//     内核重建 instance 即生效（channelConfigRefreshKey / channelConfigReload）——不重启进程；
+//     dispose 会中断进行中的流式回复（同原生加/连 provider），故在会话空闲时增删。
+//     所有 key 的增删改切换都走主进程数据层专用 IPC（window.api.channelKeys* / channelConfig*）。
+//   - [cx] US-011: 首启无 key 引导。本地 key 列表为空且无内置默认 key（resolveKeyList
+//     返回空数组）时，面板与入口都显示明确引导：面板空态换成「还没有可用的 key」引导块并
+//     直接展开新增 key 表单（AddKeyForm startOpen），入口按钮换成「导入 key」引导态——
+//     引导即进入 US-009 的新增 key 流程。有内置默认 key 或已有 key 时不显示引导。
+//   - baseURL 与鉴权凭据：优先取本地 key 条目（每张卡片各自的 baseURL/key），
+//     回退构建期注入的同名变量（NEWAPI_BASE_URL / NEWAPI_API_KEY），本文件不硬编码任何地址/密钥。
+//   - 各数据状态各有明确提示：加载中 / 请求失败 / 未配置凭据 / 就绪。
+//   - 全部网络请求包在 try/catch 内，任何错误都落入 error 态，绝不抛出，
+//     不阻塞主程序，也不让面板崩溃。
+//   - 全部中文文案。样式用内联对象，不依赖上游 tailwind / 主题变量。
+//   - US-007/US-010 充值入口：面板含「充值」按钮，点击后经 window.api.openLink（→ 主进程
+//     shell.openExternal）在系统默认浏览器打开 new-api 充值页面。充值 URL 优先用注入变量
+//     NEWAPI_TOPUP_URL，缺省回退到「由当前激活 key 的 baseURL 推导的站点根」（US-010：随
+//     切换激活 key 响应式变化，激活项无 baseURL 时再回退构建期 NEWAPI_BASE_URL）。URL 缺失
+//     时按钮禁用并提示。客户端内不实现任何支付逻辑。
+//   - 安全底线：key 明文仅本地持有，展示层一律打码（maskKey），绝不整段渲染或写日志。
+//     key 明文输入（新增表单）只在内存/本地 store 流转，不打印、不写日志、不上传。
+
+import { createSignal, onMount, onCleanup, For, Show, Switch, Match } from "solid-js"
+import type { JSX } from "solid-js"
+
+// [cx] US-006: new-api 只读 profile 接口路径（站点根下，非 /v1 渠道端点）。
+// 走 token 鉴权中间件，由 Bearer sk- 定位 token → 返回本人 profile。
+// 见 brand/docs/api-app-profile.md。替换旧的 /api/user/self（sk- 鉴权失败）。
+const APP_PROFILE_PATH = "/api/app/profile"
+
+// new-api 默认 QuotaPerUnit：500000 额度 = 1 美元（common.QuotaPerUnit 默认值）。
+// 若目标站点改了该值，展示的货币金额会有偏差——额度原值同时展示以便对照。
+const QUOTA_PER_UNIT = 500000
+
+// 从渠道 baseURL（US-003 的 NEWAPI_BASE_URL，如 https://host/v1）推导 new-api 站点根，
+// 用户接口挂在站点根 /api 下而非 /v1 渠道端点下。
+function deriveApiBase(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return trimmed.replace(/\/v1$/, "")
+}
+
+// [cx] US-009: 由渠道 baseURL 推导 OpenAI 兼容 /v1/models 端点。baseURL 通常已以 /v1 结尾
+// （如 https://host/v1）；无 /v1 后缀时补上，保证命中 OpenAI 兼容的 /v1/models。
+function deriveModelsUrl(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  if (/\/v1$/.test(trimmed)) return `${trimmed}/models`
+  return `${trimmed}/v1/models`
+}
+
+// [cx] US-007/US-010: 解析充值页面 URL。优先用注入变量 NEWAPI_TOPUP_URL（构建期由
+// electron.vite renderer.define 从 process.env 注入），缺省回退到「由激活 key 的 baseURL
+// 推导的站点根」（US-010：随激活 key 变化，非构建期常量）。activeBaseURL 为空时再回退到
+// 构建期注入的 NEWAPI_BASE_URL，两者都缺失时返回空串，此时充值入口禁用并提示。
+function resolveTopupUrl(activeBaseURL?: string): string {
+  const topup = (import.meta.env.NEWAPI_TOPUP_URL ?? "").trim()
+  if (topup) return topup
+  const baseURL = (activeBaseURL ?? "").trim() || (import.meta.env.NEWAPI_BASE_URL ?? "")
+  return deriveApiBase(baseURL)
+}
+
+// [cx] US-007: 在系统默认浏览器打开充值页面。renderer 是浏览器上下文，不能直接调
+// electron shell，走 preload 暴露的 window.api.openLink（→ 主进程 ipc "open-link"
+// → shell.openExternal，见 packages/desktop/src/main/ipc.ts）。客户端内不实现任何
+// 支付逻辑，只负责把充值 URL 交给系统浏览器。
+function openTopup(url: string): void {
+  if (!url) return
+  try {
+    window.api.openLink(url)
+  } catch {
+    // openLink 只是发一条 ipc 消息，正常不会抛出；即便异常也不应让面板崩溃。
+  }
+}
+
+// 额度 → 美元金额（两位小数）。
+function formatCurrency(quotaUnits: number): string {
+  return "$" + (quotaUnits / QUOTA_PER_UNIT).toFixed(2)
+}
+
+// [cx] US-006: 无头像时的占位首字（取用户名首个字符，空则用「?」）。
+function avatarInitial(username: string): string {
+  const trimmed = username.trim()
+  return trimmed ? trimmed[0].toUpperCase() : "?"
+}
+
+// [cx] US-008: key 打码展示（`sk-…abcd`）。仅保留可辨识的前缀与末 4 位，
+// 绝不整段渲染 key 明文。空串返回空。
+function maskKey(key: string): string {
+  const k = key.trim()
+  if (!k) return ""
+  if (k.length <= 7) return "…" + k.slice(-Math.min(4, k.length))
+  return `${k.slice(0, 3)}…${k.slice(-4)}`
+}
+
+// [cx] US-006: profile 就绪态承载 8 个字段（用户名/头像/账户额度/key 用量/是否不限额）。
+// 额度类字段均为 new-api 原始 quota 整数，换算/显示在渲染层做。
+type ProfileData = {
+  username: string
+  avatar: string
+  quota: number
+  usedQuota: number
+  tokenRemain: number
+  tokenUsed: number
+  tokenUsedToday: number
+  unlimited: boolean
+}
+
+// [cx] US-006: /api/app/profile 响应信封（见 brand/docs/api-app-profile.md 第 3 节）。
+// 字段全部可选，做防御性解析——缺字段回退到 0 / "" / false，不因缺项崩溃。
+// 契约未强约束是否带 success 信封（错误体格式以现网为准），故按 HTTP status 分支，
+// data 缺失时把整个 body 当作扁平 profile 兜底。
+type ProfileResponse = {
+  success?: boolean
+  message?: string
+  username?: string
+  avatar?: string
+  quota?: number
+  used_quota?: number
+  token_remain?: number
+  token_used?: number
+  token_used_today?: number
+  unlimited?: boolean
+  data?: {
+    username?: string
+    avatar?: string
+    quota?: number
+    used_quota?: number
+    token_remain?: number
+    token_used?: number
+    token_used_today?: number
+    unlimited?: boolean
+  }
+}
+
+// [cx] US-008: 单 key 的 profile 拉取结果。unconfigured 由 key 解析阶段处理（无凭据的
+// key 不会进列表），故此处只有 loading / error / ready 三态。
+type KeyProfileState =
+  | { status: "loading" }
+  | { status: "error"; message: string }
+  | ({ status: "ready" } & ProfileData)
+
+// [cx] US-008/US-009: 已解析的可用 key 条目（本地 store 或构建期回退）。key 为明文，仅本地
+// 持有，展示前必经 maskKey 打码。builtin=true 表示这是构建期注入的内置渠道合成条目（不在
+// 本地 store，不可增删改切换）。baseURL 为「查询用有效地址」（条目自带 or 回退构建期变量）。
+type ResolvedKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  isActive: boolean
+  builtin: boolean
+  models: string[]
+}
+
+// 本地 store 里的原始条目（与主进程 store-channel-keys.ts 的 ChannelKey 对齐）。
+type StoredChannelKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  models?: string[]
+}
+
+function isStoredChannelKey(value: unknown): value is StoredChannelKey {
+  if (!value || typeof value !== "object") return false
+  const r = value as Record<string, unknown>
+  return (
+    typeof r.id === "string" &&
+    typeof r.label === "string" &&
+    typeof r.key === "string" &&
+    typeof r.baseURL === "string"
+  )
+}
+
+function normalizeModels(value: unknown): string[] {
+  if (!Array.isArray(value)) return []
+  return value.filter((m): m is string => typeof m === "string" && m.length > 0)
+}
+
+type ChannelState = { keys: StoredChannelKey[]; activeKeyId: string | null }
+
+// [cx] US-009: 读本地 key 列表状态。经专用 IPC channelKeysList 拿到 JSON 字符串再解析；
+// 任何异常/脏数据都吞掉返回空状态，绝不抛出。
+async function loadChannelState(): Promise<ChannelState> {
+  try {
+    const raw = await window.api.channelKeysList()
+    if (!raw) return { keys: [], activeKeyId: null }
+    const parsed = JSON.parse(raw) as { keys?: unknown; activeKeyId?: unknown }
+    if (!parsed || typeof parsed !== "object" || !Array.isArray(parsed.keys)) {
+      return { keys: [], activeKeyId: null }
+    }
+    const keys = parsed.keys.filter(isStoredChannelKey).map((k) => ({ ...k, models: normalizeModels(k.models) }))
+    const activeKeyId =
+      typeof parsed.activeKeyId === "string" && keys.some((k) => k.id === parsed.activeKeyId)
+        ? parsed.activeKeyId
+        : null
+    return { keys, activeKeyId }
+  } catch {
+    return { keys: [], activeKeyId: null }
+  }
+}
+
+// [cx] US-008/US-009: 把 store 状态解析成面板要展示的 key 列表。本地有 key 时全部展示
+// （含缺 baseURL 的条目：查询用地址回退构建期变量），并标注激活项；本地无 key 时回退到构建期
+// 注入的内置渠道合成单条（builtin，不可增删改切换），保证面板仍可用。
+function resolveKeyList(state: ChannelState): ResolvedKey[] {
+  const fallbackBase = import.meta.env.NEWAPI_BASE_URL ?? ""
+  if (state.keys.length > 0) {
+    return state.keys.map((k) => ({
+      id: k.id,
+      label: k.label || "未命名 key",
+      key: k.key,
+      baseURL: k.baseURL || fallbackBase,
+      isActive: k.id === state.activeKeyId,
+      builtin: false,
+      models: normalizeModels(k.models),
+    }))
+  }
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+  if (fallbackBase && apiKey) {
+    return [
+      { id: "__builtin__", label: "内置渠道", key: apiKey, baseURL: fallbackBase, isActive: true, builtin: true, models: [] },
+    ]
+  }
+  return []
+}
+
+// [cx] US-006/US-008: 按指定 key/baseURL 拉取 profile。任何异常都被捕获并转成 error 态返回，
+// 本函数永不抛出。凭据由参数传入（逐 key 查询）——不同 key 可能是不同账户。
+async function fetchProfileWith(baseURL: string, apiKey: string): Promise<KeyProfileState> {
+  if (!baseURL || !apiKey) return { status: "error", message: "缺少渠道凭据" }
+  try {
+    const url = deriveApiBase(baseURL) + APP_PROFILE_PATH
+    const res = await fetch(url, {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return { status: "error", message: `请求返回 HTTP ${res.status}` }
+
+    const body = (await res.json()) as ProfileResponse
+    // 契约可能带 success 信封；显式 success === false 视为失败。
+    if (body.success === false) {
+      return { status: "error", message: body.message || "接口返回失败" }
+    }
+    // profile 字段可能在 data 信封内或扁平在 body 顶层，两者都兼容。
+    const p = body.data ?? body
+    return {
+      status: "ready",
+      username: p.username ?? "",
+      avatar: p.avatar ?? "",
+      quota: p.quota ?? 0,
+      usedQuota: p.used_quota ?? 0,
+      tokenRemain: p.token_remain ?? 0,
+      tokenUsed: p.token_used ?? 0,
+      tokenUsedToday: p.token_used_today ?? 0,
+      unlimited: p.unlimited ?? false,
+    }
+  } catch (error) {
+    return {
+      status: "error",
+      message: error instanceof Error ? error.message : "网络请求失败",
+    }
+  }
+}
+
+// [cx] US-009: 拉取某 key 的可用模型列表（OpenAI 兼容 /v1/models，带 Bearer sk-）。
+// 返回模型 id 字符串数组；任何异常/非 200/脏响应都返回空数组，本函数永不抛出。
+// 用于「切换激活 key 后更新内核可选模型」——结果落盘进 key 条目，server.ts 构造 config 时注入。
+async function fetchModelsWith(baseURL: string, apiKey: string): Promise<string[]> {
+  if (!baseURL || !apiKey) return []
+  try {
+    const res = await fetch(deriveModelsUrl(baseURL), {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return []
+    const body = (await res.json()) as { data?: unknown } | unknown[]
+    const list = Array.isArray(body) ? body : Array.isArray((body as { data?: unknown }).data) ? (body as { data: unknown[] }).data : []
+    const ids = list
+      .map((m) => (typeof m === "string" ? m : m && typeof m === "object" ? (m as { id?: unknown }).id : undefined))
+      .filter((id): id is string => typeof id === "string" && id.length > 0)
+    return Array.from(new Set(ids))
+  } catch {
+    return []
+  }
+}
+
+// ============================================================================
+// [cx] US-013: cx:// 深链一键导入 —— 网站点击「一键导入」把 key 灌进 App，免手动粘贴。
+//
+// 深链机制复用桌面端既有的 deep-link 分发：主进程注册 cx:// 协议（index.ts
+// setAsDefaultProtocolClient("cx")），系统唤起 App 时经 open-url / second-instance →
+// emitDeepLinks → sendDeepLinks 送到 renderer，由 renderer index.tsx 派发
+// `opencode:deep-link` CustomEvent（detail.urls）。BalanceLauncher 监听该事件，抽出
+// cx:// 链接解析后走「确认 → 写入」流程。
+//
+// 深链格式（约定）：
+//   cx://import-key?key=sk-xxx&label=我的渠道&baseURL=https://host/v1
+//   - key（必填）：new-api 的 API Token（sk-…）。校验非空 + sk- 前缀（宽松，仅告警不拦截）。
+//   - label（可选）：展示名。
+//   - baseURL（可选）：渠道地址，缺省用内置渠道地址。校验必须是 http(s) 且能被 URL 解析。
+// host 兼容 import-key / 空 host（cx://?key=…）两种写法。
+//
+// 安全（验收标准 #3）：解析成功不静默写入，先弹确认框展示将导入的 label / 打码 key /
+// baseURL，由用户确认后才 channelKeysAdd 写入本地列表，避免恶意深链偷偷灌 key。
+// ============================================================================
+
+// [cx] US-013: 深链解析结果 —— 待确认导入的 key 信息（key 为明文，仅内存持有，展示打码）。
+type ImportRequest = { key: string; label: string; baseURL: string }
+
+// [cx] US-013: 从单条 cx:// URL 解析导入请求。校验：必须是 cx: 协议、key 非空。
+// baseURL 若提供则须是可解析的 http(s) URL，否则丢弃该字段（回退内置地址）而非整体失败。
+// 解析失败（非 cx:// / 无 key / URL 非法）返回 null，不抛出。
+function parseImportDeepLink(raw: string): ImportRequest | null {
+  if (typeof raw !== "string" || !raw.trim()) return null
+  let url: URL
+  try {
+    url = new URL(raw.trim())
+  } catch {
+    return null
+  }
+  if (url.protocol !== "cx:") return null
+  const params = url.searchParams
+  const key = (params.get("key") ?? "").trim()
+  if (!key) return null
+  const label = (params.get("label") ?? "").trim()
+  let baseURL = (params.get("baseURL") ?? params.get("baseurl") ?? "").trim()
+  if (baseURL) {
+    try {
+      const parsed = new URL(baseURL)
+      if (parsed.protocol !== "http:" && parsed.protocol !== "https:") baseURL = ""
+    } catch {
+      baseURL = "" // baseURL 非法 —— 丢弃，回退内置地址，不因此整体失败。
+    }
+  }
+  return { key, label, baseURL }
+}
+
+const Z_OVERLAY = 9999
+
+const overlayStyle: JSX.CSSProperties = {
+  position: "fixed",
+  inset: "0",
+  "z-index": String(Z_OVERLAY),
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "center",
+  background: "rgba(0,0,0,0.5)",
+}
+
+const panelStyle: JSX.CSSProperties = {
+  width: "min(440px, 92vw)",
+  "max-height": "90vh",
+  overflow: "auto",
