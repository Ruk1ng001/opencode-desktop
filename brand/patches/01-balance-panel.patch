+// 账户已用占比（0~100，整数）。总额度为 0 时返回 0，避免除零。
+function usedPercent(usedQuota: number, quota: number): number {
+  if (quota <= 0) return 0
+  return Math.min(100, Math.max(0, Math.round((usedQuota / quota) * 100)))
+}
+
+// [cx] US-008/US-009: 单张 key 卡片。按各自 key 独立展示 profile（loading/error/ready），
+// 并提供切换激活 / 编辑 label / 删除操作（builtin 内置渠道条目不可管理）。
+function KeyCard(props: {
+  entry: ResolvedKey
+  state: KeyProfileState | undefined
+  switching: boolean
+  onActivate: (entry: ResolvedKey) => void
+  onSaveLabel: (id: string, label: string) => void
+  onRemove: (id: string) => void
+}) {
+  const state = () => props.state ?? ({ status: "loading" } as KeyProfileState)
+  const [editing, setEditing] = createSignal(false)
+  const [labelDraft, setLabelDraft] = createSignal("")
+  const [confirmingDelete, setConfirmingDelete] = createSignal(false)
+
+  function startEdit() {
+    setLabelDraft(props.entry.label)
+    setEditing(true)
+  }
+  function saveEdit() {
+    props.onSaveLabel(props.entry.id, labelDraft().trim())
+    setEditing(false)
+  }
+
+  const manageable = () => !props.entry.builtin
+  const clickable = () => manageable() && !props.entry.isActive && !props.switching
+
+  return (
+    <div
+      style={
+        props.entry.isActive
+          ? { ...cardStyle, ...activeCardStyle }
+          : clickable()
+            ? { ...cardStyle, ...clickableCardStyle }
+            : cardStyle
+      }
+      onClick={() => {
+        // 仅在「非激活、可管理、未切换中、未处于内联编辑」时，点击卡片切换激活。
+        if (clickable() && !editing()) props.onActivate(props.entry)
+      }}
+    >
+      <div style={cardHeadStyle}>
+        <div style={{ "min-width": "0", flex: "1" }}>
+          <Show
+            when={editing()}
+            fallback={
+              <>
+                <div style={cardLabelStyle}>{props.entry.label}</div>
+                <div style={cardKeyStyle}>{maskKey(props.entry.key)}</div>
+              </>
+            }
+          >
+            {/* 内联编辑 label —— 点击输入区不触发卡片切换。 */}
+            <div onClick={(e) => e.stopPropagation()}>
+              <input
+                style={{ ...inputStyle, "margin-bottom": "0" }}
+                value={labelDraft()}
+                placeholder="key 名称"
+                onInput={(e) => setLabelDraft(e.currentTarget.value)}
+                aria-label="编辑 key 名称"
+              />
+            </div>
+          </Show>
+        </div>
+        <Show when={props.entry.isActive}>
+          <span style={activeBadgeStyle}>激活</span>
+        </Show>
+      </div>
+
+      <Switch>
+        <Match when={props.switching && !props.entry.isActive}>
+          <div style={cardStateStyle}>切换中…</div>
+        </Match>
+
+        <Match when={state().status === "loading"}>
+          <div style={cardStateStyle}>加载中…</div>
+        </Match>
+
+        <Match when={state() as Extract<KeyProfileState, { status: "error" }>} keyed>
+          {(err) => <div style={cardStateStyle}>获取失败：{err.message}</div>}
+        </Match>
+
+        <Match when={state() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+          {(ready) => (
+            <>
+              {/* 该 key 所属账户的头像 + 用户名（不同 key 可能是不同账户）。 */}
+              <div style={cardUserRowStyle}>
+                <Show
+                  when={ready.avatar}
+                  fallback={<div style={miniAvatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                >
+                  <img src={ready.avatar} alt="头像" style={miniAvatarStyle} />
+                </Show>
+                <span>{ready.username || "未命名用户"}</span>
+              </div>
+
+              <div style={cardMetricsStyle}>
+                <div>
+                  <div style={metricLabelStyle}>该 key 已消耗</div>
+                  <div style={metricValueStyle}>{formatCurrency(ready.tokenUsed)}</div>
+                </div>
+                <div>
+                  <div style={metricLabelStyle}>今日消耗</div>
+                  <div style={metricValueStyle}>{formatCurrency(ready.tokenUsedToday)}</div>
+                </div>
+              </div>
+            </>
+          )}
+        </Match>
+      </Switch>
+
+      {/* [cx] US-009: 已缓存的可用模型数（切换激活时经 /v1/models 拉取落盘）。 */}
+      <Show when={props.entry.models.length > 0}>
+        <div style={modelCountStyle}>可用模型：{props.entry.models.length} 个</div>
+      </Show>
+
+      {/* [cx] US-009: 卡片操作行——切换/编辑/删除。内置渠道条目（builtin）不可管理。 */}
+      <Show when={manageable()}>
+        <div style={cardActionsStyle} onClick={(e) => e.stopPropagation()}>
+          <Show when={editing()} fallback={
+            <>
+              <Show when={!props.entry.isActive}>
+                <button
+                  type="button"
+                  style={primarySmallButtonStyle}
+                  disabled={props.switching}
+                  aria-disabled={props.switching}
+                  onClick={() => props.onActivate(props.entry)}
+                >
+                  {props.switching ? "切换中…" : "切换为激活"}
+                </button>
+              </Show>
+              <button type="button" style={smallButtonStyle} onClick={startEdit}>
+                编辑名称
+              </button>
+              <Show
+                when={confirmingDelete()}
+                fallback={
+                  <button type="button" style={dangerButtonStyle} onClick={() => setConfirmingDelete(true)}>
+                    删除
+                  </button>
+                }
+              >
+                <span style={{ "font-size": "12px", color: "#fca5a5" }}>确认删除？</span>
+                <button
+                  type="button"
+                  style={dangerButtonStyle}
+                  onClick={() => {
+                    setConfirmingDelete(false)
+                    props.onRemove(props.entry.id)
+                  }}
+                >
+                  确认
+                </button>
+                <button type="button" style={smallButtonStyle} onClick={() => setConfirmingDelete(false)}>
+                  取消
+                </button>
+              </Show>
+            </>
+          }>
+            <button type="button" style={primarySmallButtonStyle} onClick={saveEdit}>
+              保存
+            </button>
+            <button type="button" style={smallButtonStyle} onClick={() => setEditing(false)}>
+              取消
+            </button>
+          </Show>
+        </div>
+      </Show>
+    </div>
+  )
+}
+
+// [cx] US-009: 新增 key 表单。粘贴 sk-…（必填）+ 可选 label / baseURL。key 明文只在内存流转，
+// 提交经 channelKeysAdd 写入本地 store；不打印、不写日志。
+// [cx] US-011: startOpen —— 首启无 key 引导时直接展开表单（引导即进入新增 key 流程），
+// 无需用户再点一次「+ 新增 key」。
+function AddKeyForm(props: {
+  onAdd: (input: { label: string; key: string; baseURL: string }) => Promise<void>
+  startOpen?: boolean
+}) {
+  const [open, setOpen] = createSignal(props.startOpen ?? false)
+  const [key, setKey] = createSignal("")
+  const [label, setLabel] = createSignal("")
+  const [baseURL, setBaseURL] = createSignal("")
+  const [error, setError] = createSignal("")
+  const [saving, setSaving] = createSignal(false)
+
+  function reset() {
+    setKey("")
+    setLabel("")
+    setBaseURL("")
+    setError("")
+  }
+
+  async function submit() {
+    const k = key().trim()
+    if (!k) {
+      setError("请粘贴 API Key（sk-…）")
+      return
+    }
+    setSaving(true)
+    try {
+      await props.onAdd({ label: label().trim(), key: k, baseURL: baseURL().trim() })
+      reset()
+      setOpen(false)
+    } finally {
+      setSaving(false)
+    }
+  }
+
+  return (
+    <Show
+      when={open()}
+      fallback={
+        <button type="button" style={{ ...smallButtonStyle, width: "100%", padding: "8px" }} onClick={() => setOpen(true)}>
+          + 新增 key
+        </button>
+      }
+    >
+      <div style={addFormStyle}>
+        <input
+          style={inputStyle}
+          value={key()}
+          type="password"
+          autocomplete="off"
+          placeholder="API Key（sk-…，必填）"
+          onInput={(e) => setKey(e.currentTarget.value)}
+          aria-label="API Key"
+        />
+        <input
+          style={inputStyle}
+          value={label()}
+          placeholder="名称（可选）"
+          onInput={(e) => setLabel(e.currentTarget.value)}
+          aria-label="key 名称"
+        />
+        <input
+          style={inputStyle}
+          value={baseURL()}
+          placeholder="baseURL（可选，缺省用内置渠道地址）"
+          onInput={(e) => setBaseURL(e.currentTarget.value)}
+          aria-label="baseURL"
+        />
+        <Show when={error()}>
+          <div style={{ "font-size": "12px", color: "#fca5a5", "margin-bottom": "8px" }}>{error()}</div>
+        </Show>
+        <div style={{ display: "flex", gap: "8px" }}>
+          <button
+            type="button"
+            style={{ ...primarySmallButtonStyle, flex: "1" }}
+            disabled={saving()}
+            aria-disabled={saving()}
+            onClick={submit}
+          >
+            {saving() ? "保存中…" : "添加"}
+          </button>
+          <button
+            type="button"
+            style={smallButtonStyle}
+            onClick={() => {
+              reset()
+              setOpen(false)
+            }}
+          >
+            取消
+          </button>
+        </div>
+      </div>
+    </Show>
+  )
+}
+
+function BalancePanel(props: { onClose: () => void }) {
+  const [initializing, setInitializing] = createSignal(true)
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  // 逐 key 的 profile 状态，按 key id 索引；整份替换以触发响应式更新。
+  const [profiles, setProfiles] = createSignal<Record<string, KeyProfileState>>({})
+  // [cx] US-009: 正在切换激活的 key id（切换期间禁用相关按钮、显示反馈）。
+  const [switchingId, setSwitchingId] = createSignal<string | null>(null)
+
+  const activeEntry = () => keys().find((k) => k.isActive) ?? keys()[0]
+  const activeProfile = (): KeyProfileState | undefined => {
+    const entry = activeEntry()
+    return entry ? profiles()[entry.id] : undefined
+  }
+
+  // [cx] US-010: 充值页面 URL 派生自「当前激活 key」。优先用注入变量 NEWAPI_TOPUP_URL；
+  // 缺省回退到由激活 key 的 baseURL 推导的站点根（随切换激活 key 响应式变化，故用派生函数
+  // 而非组件创建期常量）。都缺失时为空串 → 充值按钮禁用并提示。
+  const topupUrl = () => resolveTopupUrl(activeEntry()?.baseURL)
+  // 有任一 key 仍在加载即视为刷新中（一键刷新按钮据此禁用 + 改文案）。
+  const anyLoading = () => keys().some((k) => (profiles()[k.id]?.status ?? "loading") === "loading")
+
+  // 对单个 key 拉 profile：先置 loading（加载反馈），再写入结果。
+  async function loadProfile(entry: ResolvedKey): Promise<void> {
+    setProfiles((prev) => ({ ...prev, [entry.id]: { status: "loading" } }))
+    const result = await fetchProfileWith(entry.baseURL, entry.key)
+    setProfiles((prev) => ({ ...prev, [entry.id]: result }))
+  }
+
+  // [cx] US-008: 一键刷新——对所有可见 key 重新拉取 profile。
+  function refreshAll(): void {
+    for (const entry of keys()) void loadProfile(entry)
+  }
+
+  // 从本地 store 重新拉列表并刷新 profile（增删改切换后调用以同步 UI）。
+  async function reload(): Promise<void> {
+    const state = await loadChannelState()
+    setKeys(resolveKeyList(state))
+    setInitializing(false)
+    refreshAll()
+  }
+
+  onMount(() => {
+    void reload()
+  })
+
+  // [cx] 新增 key —— 写入本地列表 → 主进程拉模型 + 热重载（provider 出现），不重启进程。
+  //   写库后调 channelConfigRefreshKey(新id)：主进程拉该 key 的 /v1/models（无 CORS，比 renderer
+  //   fetch 更稳）落盘 → 重写 OPENCODE_CONFIG 文件 → POST /global/dispose 让内核重建 instance，
+  //   该 key 即成为可用 provider。全程不重启 sidecar。dispose 会中断进行中的流式回复（同原生
+  //   加 provider），故用户应在会话空闲时加 key。
+  async function handleAdd(input: { label: string; key: string; baseURL: string }): Promise<void> {
+    let addedId: string | undefined
+    try {
+      // channelKeysAdd 返回最新 ChannelKeysState 的 JSON，解析出新条目 id（按明文 key 反向匹配）。
+      const raw = await window.api.channelKeysAdd(input)
+      const state = JSON.parse(raw) as { keys?: StoredChannelKey[] }
+      const keys = Array.isArray(state.keys) ? state.keys : []
+      addedId = [...keys].reverse().find((k) => k.key === input.key)?.id
+    } catch {
+      // 主进程写库正常不抛；即便异常也不应让面板崩溃。
+    }
+    await reload()
+    // 主进程拉模型 + 热重载（provider 出现）。失败不崩溃。
+    if (addedId) {
+      try {
+        await window.api.channelConfigRefreshKey(addedId)
+      } catch {
+        // 热重载失败不阻断；下次启动时文件配置仍会生效。
+      }
+      await reload()
+    }
+  }
+
+  // [cx] US-009: 保存 label。
+  async function handleSaveLabel(id: string, label: string): Promise<void> {
+    try {
+      await window.api.channelKeysUpdateLabel(id, label)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    await reload()
+  }
+
+  // [cx] 删除 key（二次确认在卡片内完成）。删激活项时主进程侧激活回退首项/置空。
+  //   删除改变了 provider 集合，调 channelConfigReload：主进程重写 OPENCODE_CONFIG 文件（整份
+  //   覆盖，被删 key 天然消失）+ POST /global/dispose，内核重建后该 provider 消失——不重启进程。
+  async function handleRemove(id: string): Promise<void> {
+    try {
+      await window.api.channelKeysRemove(id)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    await reload()
+    try {
+      await window.api.channelConfigReload()
+    } catch {
+      // 热重载失败不阻断；下次启动时文件配置仍会生效。
+    }
+  }
+
+  // [cx] 点击卡片切换激活 key —— 零重启。新设计下每个 key 都被主进程注入成一个独立的
+  // opencode provider，切换 key 不再重建 config / 重启 sidecar，而是派发 CustomEvent
+  // 交给 opencode 原生 model 切换机制接管：
+  //   1. channelKeysSetActive —— 更新本地激活项（供下次 spawn 的默认值 + 面板卡片高亮）；
+  //   2. 拉该 key 的 /v1/models 落盘（provider 的可选模型依赖它，保留）；
+  //   3. 派发 cx:select-provider 事件，让原生机制切到对应 provider/model（不再提示重启）；
+  //   4. reload 刷新面板自身 UI。
+  async function handleActivate(entry: ResolvedKey): Promise<void> {
+    if (entry.builtin || entry.isActive || switchingId()) return
+    setSwitchingId(entry.id)
+    try {
+      await window.api.channelKeysSetActive(entry.id)
+      // 拉该 key 的可用模型并落盘（供 provider 的可选模型）。失败返回空数组，不阻断切换。
+      const models = await fetchModelsWith(entry.baseURL, entry.key)
+      if (models.length > 0) {
+        try {
+          await window.api.channelKeysSetModels(entry.id, models)
+        } catch {
+          // 忽略：模型缓存写入失败不阻断切换。
+        }
+      }
+      // [cx] providerID 规则必须与主进程 server.ts 的 channelProviderId 完全一致：
+      // `newapi-${id.slice(0, 8)}`。写错则派发的事件匹配不到 provider，切换不生效——硬约束。
+      const providerId = `newapi-${entry.id.slice(0, 8)}`
+      // 默认 model：优先本次刚拉到的 models 第一个；否则用 entry 已缓存的 models 第一个；
+      // 都没有则不派发事件（仅更新激活项，避免切到一个没有 model 的 provider）。
+      const modelId = models.length > 0 ? models[0] : entry.models?.[0]
+      if (modelId) {
+        window.dispatchEvent(
+          new CustomEvent("cx:select-provider", { detail: { providerID: providerId, modelID: modelId } }),
+        )
+      }
+      await reload()
+    } catch {
+      // 忽略：切换失败不让面板崩溃。
+    } finally {
+      setSwitchingId(null)
+    }
+  }
+
+  return (
+    <div style={overlayStyle} onClick={props.onClose} role="presentation">
+      <div
+        style={panelStyle}
+        role="dialog"
+        aria-modal="true"
+        aria-label="账户面板"
+        onClick={(event) => event.stopPropagation()}
+      >
+        <div style={headerStyle}>
+          <span style={{ "font-size": "16px", "font-weight": "600" }}>账户</span>
+          <button type="button" style={closeButtonStyle} aria-label="关闭" onClick={props.onClose}>
+            ✕
+          </button>
+        </div>
+
+        <Switch>
+          <Match when={initializing()}>
+            <div style={stateBoxStyle}>正在加载…</div>
+          </Match>
+
+          {/* [cx] US-011: 首启无 key 引导。本地 key 列表为空且无内置默认 key（resolveKeyList
+              返回空数组）时，展示明确的引导提示，说明「导入你的第一个 key 即可开始」，并直接
+              展开新增 key 表单（startOpen）——引导即进入 US-009 的新增 key 流程，无需二次点击。
+              有内置默认 key 或已有 key 时走 keys().length > 0 分支，不显示本引导。 */}
+          <Match when={keys().length === 0}>
+            <div style={onboardBoxStyle}>
+              <div style={onboardIconStyle}>🔑</div>
+              <div style={onboardTitleStyle}>还没有可用的 key</div>
+              <div style={onboardDescStyle}>
+                导入一个 API Key（sk-…）即可开始使用。
+                <br />
+                在下方粘贴你的 key 完成导入。
+              </div>
+            </div>
+            <AddKeyForm onAdd={handleAdd} startOpen />
+          </Match>
+
+          <Match when={keys().length > 0}>
+            {/* [cx] US-008: 顶部账户汇总（激活 key 账户）。 */}
+            <div style={summaryStyle}>
+              <div style={summaryHeadStyle}>
+                <Show
+                  when={(() => {
+                    const p = activeProfile()
+                    return p && p.status === "ready" ? p : undefined
+                  })()}
+                  fallback={<div style={avatarFallbackStyle}>?</div>}
+                  keyed
+                >
+                  {(ready) => (
+                    <Show
+                      when={ready.avatar}
+                      fallback={<div style={avatarFallbackStyle}>{avatarInitial(ready.username)}</div>}
+                    >
+                      <img src={ready.avatar} alt="头像" style={avatarStyle} />
+                    </Show>
+                  )}
+                </Show>
+                <span style={usernameStyle}>
+                  <Show
+                    when={(() => {
+                      const p = activeProfile()
+                      return p && p.status === "ready" ? p.username : ""
+                    })()}
+                    fallback="当前账户"
+                    keyed
+                  >
+                    {(name) => <>{name}</>}
+                  </Show>
+                </span>
+                <button
+                  type="button"
+                  style={refreshButtonStyle}
+                  disabled={anyLoading()}
+                  aria-disabled={anyLoading()}
+                  onClick={refreshAll}
+                >
+                  {anyLoading() ? "刷新中…" : "一键刷新"}
+                </button>
+              </div>
+
+              <Switch>
+                <Match when={(activeProfile()?.status ?? "loading") === "loading"}>
+                  <div style={cardStateStyle}>正在获取账户额度…</div>
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "error" }>} keyed>
+                  {(err) => <div style={cardStateStyle}>获取失败：{err.message}</div>}
+                </Match>
+
+                <Match when={activeProfile() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+                  {(ready) => (
+                    <>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户总额度</span>
+                        <span style={summaryValueStyle}>{formatCurrency(ready.quota)}</span>
+                      </div>
+                      <div style={summaryRowStyle}>
+                        <span style={summaryLabelStyle}>账户已用</span>
+                        <span style={summaryValueStyle}>
+                          {formatCurrency(ready.usedQuota)}({usedPercent(ready.usedQuota, ready.quota)}%)
+                        </span>
+                      </div>
+                      <div style={progressTrackStyle}>
+                        <div
+                          style={{
+                            width: `${usedPercent(ready.usedQuota, ready.quota)}%`,
+                            height: "100%",
+                            background: "#3b82f6",
+                          }}
+                        />
+                      </div>
+                    </>
+                  )}
+                </Match>
+              </Switch>
+            </div>
+
+            {/* [cx] US-008/US-009: key 卡片列表。点击非激活卡片切换激活；每张可编辑名称/删除。 */}
+            <div style={sectionTitleStyle}>
+              <span>Key 列表({keys().length})</span>
+              <span style={{ "font-size": "11px" }}>点击卡片切换激活</span>
+            </div>
+            <For each={keys()}>
+              {(entry) => (
+                <KeyCard
+                  entry={entry}
+                  state={profiles()[entry.id]}
+                  switching={switchingId() === entry.id}
+                  onActivate={(e) => void handleActivate(e)}
+                  onSaveLabel={(id, label) => void handleSaveLabel(id, label)}
+                  onRemove={(id) => void handleRemove(id)}
+                />
+              )}
+            </For>
+
+            {/* [cx] US-009: 新增 key 表单。 */}
+            <AddKeyForm onAdd={handleAdd} />
+          </Match>
+        </Switch>
+
+        {/* [cx] US-007: 充值入口。点击经 window.api.openLink 在系统默认浏览器打开充值页面。
+            URL 已配置时按钮可点;未配置(注入变量与站点根都缺失)时禁用并提示。 */}
+        <button
+          type="button"
+          style={topupButtonStyle}
+          disabled={!topupUrl()}
+          aria-disabled={!topupUrl()}
+          onClick={() => openTopup(topupUrl())}
+        >
+          充值
+        </button>
+
+        <Show when={!topupUrl()}>
+          <div style={hintStyle}>未配置充值地址,请注入 NEWAPI_TOPUP_URL 或 NEWAPI_BASE_URL</div>
+        </Show>
+      </div>
+    </div>
+  )
+}
+
+// 独立入口 + 面板容器。挂载在聊天界面之外,自管理开合状态,不与聊天 UI 共享任何上下文。
+// [cx] US-013: 深链导入确认弹窗。展示待导入的 label / 打码 key / baseURL，由用户确认后
+// 才写入（验收标准 #3：导入前有确认，避免恶意深链静默写入）。确认写入成功后转为「成功」态，
+// 提示可「设为激活」（验收标准 #4）。key 明文仅内存持有，展示一律 maskKey 打码、不写日志。
+function ImportDialog(props: { request: ImportRequest; onClose: () => void }) {
+  type Phase =
+    | { status: "confirm" }
+    | { status: "saving" }
+    | { status: "done"; id: string }
+    | { status: "activating" }
+    | { status: "error"; message: string }
+  const [phase, setPhase] = createSignal<Phase>({ status: "confirm" })
+
+  const displayBase = () => props.request.baseURL || (import.meta.env.NEWAPI_BASE_URL ?? "") || "内置渠道地址"
+
+  async function confirmImport() {
+    setPhase({ status: "saving" })
+    try {
+      // channelKeysAdd 返回最新 ChannelKeysState 的 JSON。解析出新条目 id（用于「设为激活」）。
+      const raw = await window.api.channelKeysAdd({
+        label: props.request.label,
+        key: props.request.key,
+        baseURL: props.request.baseURL,
+      })
+      const state = JSON.parse(raw) as { keys?: StoredChannelKey[] }
+      const keys = Array.isArray(state.keys) ? state.keys : []
+      // 新增条目排在列表末尾；按明文 key 匹配取回其 id（key 仅内存比对，不外传）。
+      const added = [...keys].reverse().find((k) => k.key === props.request.key)
+      setPhase({ status: "done", id: added?.id ?? "" })
+    } catch {
+      setPhase({ status: "error", message: "导入失败，请重试或手动在账户面板添加。" })
+    }
+  }
+
+  // [cx] US-013: 导入成功后可直接设为激活。setActive → channelConfigRefreshKey（主进程拉该 key
+  // 的 /v1/models 落盘 + 重写 OPENCODE_CONFIG 文件 + 热重载），该 key 即成为可用 provider——不重启进程。
+  async function activateNow(id: string) {
+    if (!id) {
+      props.onClose()
+      return
+    }
+    setPhase({ status: "activating" })
+    try {
+      await window.api.channelKeysSetActive(id)
+      // 主进程拉模型 + 热重载（provider 出现）。失败不崩溃。
+      await window.api.channelConfigRefreshKey(id)
+    } catch {
+      // 设为激活/重载失败——不崩溃，直接关闭（用户可在面板手动切换）。
+    }
+    props.onClose()
+  }
+
+  return (
+    <div style={overlayStyle} onClick={props.onClose} role="presentation">
+      <div style={panelStyle} onClick={(e) => e.stopPropagation()} role="dialog" aria-modal="true" aria-label="导入 key">
+        <div style={headerStyle}>
+          <strong style={{ "font-size": "15px" }}>导入 key</strong>
+          <button type="button" style={closeButtonStyle} aria-label="关闭" onClick={props.onClose}>
+            ✕
+          </button>
+        </div>
+
+        <Switch>
+          <Match when={phase().status === "done" || phase().status === "activating"}>
+            <div style={{ ...stateBoxStyle, "text-align": "left" }}>
+              <div style={{ ...onboardTitleStyle, "text-align": "center" }}>✅ 导入成功</div>
+              <p style={{ "margin-bottom": "16px", "text-align": "center" }}>
+                「{props.request.label || maskKey(props.request.key) || "新 key"}」已加入本地列表。是否立即设为激活 key？
+              </p>
+              <div style={{ display: "flex", gap: "8px" }}>
+                <button
+                  type="button"
+                  style={{ ...primarySmallButtonStyle, flex: "1" }}
+                  disabled={phase().status === "activating"}
+                  aria-disabled={phase().status === "activating"}
+                  onClick={() => {
+                    const p = phase()
+                    if (p.status === "done") void activateNow(p.id)
+                  }}
+                >
+                  {phase().status === "activating" ? "设置中…" : "设为激活"}
+                </button>
+                <button type="button" style={smallButtonStyle} onClick={props.onClose}>
+                  暂不
+                </button>
+              </div>
+            </div>
+          </Match>
+
+          <Match when={phase().status === "error"}>
+            <div style={stateBoxStyle}>
+              <div style={{ color: "#fca5a5", "margin-bottom": "16px" }}>
+                {(phase() as { status: "error"; message: string }).message}
+              </div>
+              <button type="button" style={{ ...smallButtonStyle, width: "100%" }} onClick={props.onClose}>
+                关闭
+              </button>
+            </div>
+          </Match>
+
+          <Match when={phase().status === "confirm" || phase().status === "saving"}>
+            <p style={{ "margin-bottom": "12px", color: "#9ca3af", "font-size": "13px", "line-height": "1.6" }}>
+              收到一条导入请求。请确认以下 key 信息无误后再导入——请勿导入来源不明的 key。
+            </p>
+            <div style={{ "margin-bottom": "16px" }}>
+              <div style={importRowStyle}>
+                <span style={importRowLabelStyle}>名称</span>
+                <span style={importRowValueStyle}>{props.request.label || "（未命名）"}</span>
+              </div>
+              <div style={importRowStyle}>
+                <span style={importRowLabelStyle}>API Key</span>
+                <span style={importRowValueStyle}>{maskKey(props.request.key)}</span>
+              </div>
+              <div style={{ ...importRowStyle, "border-bottom": "none" }}>
+                <span style={importRowLabelStyle}>渠道地址</span>
+                <span style={importRowValueStyle}>{displayBase()}</span>
+              </div>
+            </div>
+            <div style={{ display: "flex", gap: "8px" }}>
+              <button
+                type="button"
+                style={{ ...primarySmallButtonStyle, flex: "1" }}
+                disabled={phase().status === "saving"}
+                aria-disabled={phase().status === "saving"}
+                onClick={confirmImport}
+              >
+                {phase().status === "saving" ? "导入中…" : "确认导入"}
+              </button>
+              <button type="button" style={smallButtonStyle} onClick={props.onClose}>
+                取消
+              </button>
+            </div>
+          </Match>
+        </Switch>
+      </div>
+    </div>
+  )
+}
+
+// [cx] 打开账户面板的全局事件名。侧边栏账户按钮（在 opencode 组件树内，见 layout.tsx）
+// 派发此事件；BalanceLauncher（挂在组件树外，index.tsx）监听并打开面板。这样按钮与面板
+// 跨组件树解耦，复用仓库已验证的 CustomEvent 桥模式（同 opencode:deep-link / cx:select-provider）。
+export const CX_OPEN_ACCOUNT_EVENT = "cx:open-account"
+
+// [cx] 账户面板宿主：不再自带悬浮入口按钮（入口已移入 opencode 侧边栏底部，见
+// AccountSidebarButton / layout.tsx）。本组件只负责：监听「打开账户」事件弹出面板、
+// 以及 US-013 的 cx:// 深链导入确认框。仍挂在组件树外（index.tsx），面板为全屏浮层。
+export function BalanceLauncher() {
+  const [open, setOpen] = createSignal(false)
+  // [cx] US-013: 待确认导入的 cx:// 深链请求（非空时弹确认框）。
+  const [importReq, setImportReq] = createSignal<ImportRequest | null>(null)
+
+  onMount(() => {
+    // [cx] 侧边栏账户按钮点击 → 打开面板。
+    const onOpen = () => setOpen(true)
+    window.addEventListener(CX_OPEN_ACCOUNT_EVENT, onOpen)
+
+    // [cx] US-013: 监听桌面端 deep-link 事件（renderer index.tsx 派发的 opencode:deep-link
+    // CustomEvent，detail.urls 含所有唤起 URL——含上游 opencode:// 与本项目 cx://）。从中筛出
+    // cx:// 导入链接解析，弹确认框（避免恶意深链静默写入）。一次只处理一条（取第一条有效的）。
+    const onDeepLink = (e: Event) => {
+      const detail = (e as CustomEvent<{ urls?: unknown }>).detail
+      const urls = Array.isArray(detail?.urls) ? (detail.urls as unknown[]) : []
+      for (const u of urls) {
+        if (typeof u !== "string") continue
+        const req = parseImportDeepLink(u)
+        if (req) {
+          setImportReq(req)
+          // [cx] 深链导入时自动打开面板宿主（确认框依附其上）。
+          setOpen(true)
+          break
+        }
+      }
+    }
+    window.addEventListener("opencode:deep-link", onDeepLink)
+    onCleanup(() => {
+      window.removeEventListener(CX_OPEN_ACCOUNT_EVENT, onOpen)
+      window.removeEventListener("opencode:deep-link", onDeepLink)
+    })
+  })
+
+  return (
+    <>
+      <Show when={open()}>
+        <BalancePanel onClose={() => setOpen(false)} />
+      </Show>
+      {/* [cx] US-013: cx:// 深链导入确认弹窗（有待确认请求时才渲染）。 */}
+      <Show when={importReq()} keyed>
+        {(req) => <ImportDialog request={req} onClose={() => setImportReq(null)} />}
+      </Show>
+    </>
+  )
+}
