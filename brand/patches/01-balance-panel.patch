+// [cx] 独立账户面板 —— 对接 new-api 取用户名/头像/额度/用量（US-006）+ 充值入口（US-007）
+//     + key 列表卡片 UI + 顶部账户汇总（US-008）+ 增删改 key 与手动切换激活 key（US-009）
+//     + 首启无 key 引导（US-011）+ 失效自动切换 key（US-012）
+//
+// 设计约束（见 TODO.md / brand/docs/api-app-profile.md / 验收标准）：
+//   - 独立展示区域，与 opencode 原有聊天 UI 组件完全解耦；本文件不 import 任何
+//     上游 app / session-ui 组件，仅依赖 solid-js，可离线 typecheck。
+//   - 明确入口：一个独立悬浮按钮「账户」，点击打开全屏浮层面板。
+//   - 打开面板时向 new-api 只读 profile 接口（GET /api/app/profile）拉取真实
+//     用户名/头像/额度/用量，解析后做单位换算与中文标注。
+//   - [cx] US-006: 端点从旧的 /api/user/self 改为 /api/app/profile。旧端点走
+//     用户会话/系统令牌鉴权，用 sk- API Token 调会失败（TODO 第七节风险 #3）；
+//     新端点走 token 鉴权中间件（同 /v1/*），由 sk- 定位 token → 本人 profile
+//     （见 brand/docs/api-app-profile.md）。
+//   - [cx] US-008: 面板不再只看构建期注入的单 key，而是读 US-003 本地 key 列表
+//     （主进程 store-channel-keys 写入的 `channelKeys`）。顶部汇总区展示「当前激活 key」
+//     账户的头像/用户名/账户总额度/账户已用（进度条）+ 一键刷新；下方逐 key 卡片，
+//     每张卡片按各自 key 独立调 /api/app/profile（不同 key 可能是不同账户），激活 key
+//     卡片有明显选中态。本地无 key 列表时回退到构建期注入的内置渠道合成单条。
+//   - [cx] US-009: 面板可管理本地 key 列表：
+//       · 新增 key —— 粘贴 sk-…（可选 label / baseURL），经 channelKeysAdd 写入本地列表；
+//       · 删除 key —— 二次确认后经 channelKeysRemove 删除（删激活项时主进程侧激活回退首项/置空）；
+//       · 修改 label —— 内联编辑保存，经 channelKeysUpdateLabel；
+//       · 点击非激活卡片切换激活 key —— 经 channelKeysSetActive 更新 activeKeyId，随后带该
+//         key 的 sk- 调 /v1/models 拉取可用模型并经 channelKeysSetModels 落盘（供内核 config
+//         注入「可选模型」）；因内核 config 是启动期一次性注入（US-002 结论：必须重启 sidecar），
+//         切换后给出重启提示（横幅 + 立即重启按钮），提醒当前会话将中断，由用户决定何时重启。
+//     所有 key 的增删改切换都走主进程数据层专用 IPC（window.api.channelKeys*），不用通用
+//     storeSet（那会把整个对象存成字符串、破坏主进程侧对象读取）。
+//   - [cx] US-011: 首启无 key 引导。本地 key 列表为空且无内置默认 key（resolveKeyList
+//     返回空数组）时，面板与入口都显示明确引导：面板空态换成「还没有可用的 key」引导块并
+//     直接展开新增 key 表单（AddKeyForm startOpen），入口按钮换成「导入 key」引导态——
+//     引导即进入 US-009 的新增 key 流程。有内置默认 key 或已有 key 时不显示引导。
+//   - baseURL 与鉴权凭据：优先取本地 key 条目（每张卡片各自的 baseURL/key），
+//     回退构建期注入的同名变量（NEWAPI_BASE_URL / NEWAPI_API_KEY），本文件不硬编码任何地址/密钥。
+//   - 各数据状态各有明确提示：加载中 / 请求失败 / 未配置凭据 / 就绪。
+//   - 全部网络请求包在 try/catch 内，任何错误都落入 error 态，绝不抛出，
+//     不阻塞主程序，也不让面板崩溃。
+//   - 全部中文文案。样式用内联对象，不依赖上游 tailwind / 主题变量。
+//   - US-007/US-010 充值入口：面板含「充值」按钮，点击后经 window.api.openLink（→ 主进程
+//     shell.openExternal）在系统默认浏览器打开 new-api 充值页面。充值 URL 优先用注入变量
+//     NEWAPI_TOPUP_URL，缺省回退到「由当前激活 key 的 baseURL 推导的站点根」（US-010：随
+//     切换激活 key 响应式变化，激活项无 baseURL 时再回退构建期 NEWAPI_BASE_URL）。URL 缺失
+//     时按钮禁用并提示。客户端内不实现任何支付逻辑。
+//   - 安全底线：key 明文仅本地持有，展示层一律打码（maskKey），绝不整段渲染或写日志。
+//     key 明文输入（新增表单）只在内存/本地 store 流转，不打印、不写日志、不上传。
+//   - [cx] US-012: 失效自动切换 key。常驻的 BalanceLauncher 挂载后独立订阅内核 sidecar 的
+//     事件流（GET /global/event，SSE，Basic 鉴权 opencode:password，凭据来自
+//     window.api.awaitInitialization()），监听 session.error 事件。当错误特征命中
+//     「额度耗尽 / key 失效」（ProviderAuthError，或 APIError 的 statusCode 401/402/403/429
+//     或报文含额度/失效关键词，见 isKeyFailureError）时，自动切换到列表中「下一个」未被本轮
+//     标记失败的可用 key（channelKeysSetActive + 拉该 key 的 /v1/models 落盘），并复用既有
+//     relaunch 重启内核使新 key 生效（US-002：config 启动期一次性注入，切 key 必须重启）。
+//     切换给用户可见提示（浮层横幅，说明切到了哪个 key + 立即重启）。所有 key 都已试过仍失败
+//     时给出「全部不可用」提示、不再自动切换（不无限重试）——重启后失败集合清零，用户修复额度
+//     后可重新触发。检测/切换全在 renderer（本文件），不改上游聊天组件、不新增 IPC。
+
+import { createSignal, onMount, onCleanup, For, Show, Switch, Match } from "solid-js"
+import type { JSX } from "solid-js"
+
+// [cx] US-006: new-api 只读 profile 接口路径（站点根下，非 /v1 渠道端点）。
+// 走 token 鉴权中间件，由 Bearer sk- 定位 token → 返回本人 profile。
+// 见 brand/docs/api-app-profile.md。替换旧的 /api/user/self（sk- 鉴权失败）。
+const APP_PROFILE_PATH = "/api/app/profile"
+
+// new-api 默认 QuotaPerUnit：500000 额度 = 1 美元（common.QuotaPerUnit 默认值）。
+// 若目标站点改了该值，展示的货币金额会有偏差——额度原值同时展示以便对照。
+const QUOTA_PER_UNIT = 500000
+
+// 从渠道 baseURL（US-003 的 NEWAPI_BASE_URL，如 https://host/v1）推导 new-api 站点根，
+// 用户接口挂在站点根 /api 下而非 /v1 渠道端点下。
+function deriveApiBase(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return trimmed.replace(/\/v1$/, "")
+}
+
+// [cx] US-009: 由渠道 baseURL 推导 OpenAI 兼容 /v1/models 端点。baseURL 通常已以 /v1 结尾
+// （如 https://host/v1）；无 /v1 后缀时补上，保证命中 OpenAI 兼容的 /v1/models。
+function deriveModelsUrl(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  if (/\/v1$/.test(trimmed)) return `${trimmed}/models`
+  return `${trimmed}/v1/models`
+}
+
+// [cx] US-007/US-010: 解析充值页面 URL。优先用注入变量 NEWAPI_TOPUP_URL（构建期由
+// electron.vite renderer.define 从 process.env 注入），缺省回退到「由激活 key 的 baseURL
+// 推导的站点根」（US-010：随激活 key 变化，非构建期常量）。activeBaseURL 为空时再回退到
+// 构建期注入的 NEWAPI_BASE_URL，两者都缺失时返回空串，此时充值入口禁用并提示。
+function resolveTopupUrl(activeBaseURL?: string): string {
+  const topup = (import.meta.env.NEWAPI_TOPUP_URL ?? "").trim()
+  if (topup) return topup
+  const baseURL = (activeBaseURL ?? "").trim() || (import.meta.env.NEWAPI_BASE_URL ?? "")
+  return deriveApiBase(baseURL)
+}
+
+// [cx] US-007: 在系统默认浏览器打开充值页面。renderer 是浏览器上下文，不能直接调
+// electron shell，走 preload 暴露的 window.api.openLink（→ 主进程 ipc "open-link"
+// → shell.openExternal，见 packages/desktop/src/main/ipc.ts）。客户端内不实现任何
+// 支付逻辑，只负责把充值 URL 交给系统浏览器。
+function openTopup(url: string): void {
+  if (!url) return
+  try {
+    window.api.openLink(url)
+  } catch {
+    // openLink 只是发一条 ipc 消息，正常不会抛出；即便异常也不应让面板崩溃。
+  }
+}
+
+// 额度 → 美元金额（两位小数）。
+function formatCurrency(quotaUnits: number): string {
+  return "$" + (quotaUnits / QUOTA_PER_UNIT).toFixed(2)
+}
+
+// [cx] US-006: 无头像时的占位首字（取用户名首个字符，空则用「?」）。
+function avatarInitial(username: string): string {
+  const trimmed = username.trim()
+  return trimmed ? trimmed[0].toUpperCase() : "?"
+}
+
+// [cx] US-008: key 打码展示（`sk-…abcd`）。仅保留可辨识的前缀与末 4 位，
+// 绝不整段渲染 key 明文。空串返回空。
+function maskKey(key: string): string {
+  const k = key.trim()
+  if (!k) return ""
+  if (k.length <= 7) return "…" + k.slice(-Math.min(4, k.length))
+  return `${k.slice(0, 3)}…${k.slice(-4)}`
+}
+
+// [cx] US-006: profile 就绪态承载 8 个字段（用户名/头像/账户额度/key 用量/是否不限额）。
+// 额度类字段均为 new-api 原始 quota 整数，换算/显示在渲染层做。
+type ProfileData = {
+  username: string
+  avatar: string
+  quota: number
+  usedQuota: number
+  tokenRemain: number
+  tokenUsed: number
+  tokenUsedToday: number
+  unlimited: boolean
+}
+
+// [cx] US-006: /api/app/profile 响应信封（见 brand/docs/api-app-profile.md 第 3 节）。
+// 字段全部可选，做防御性解析——缺字段回退到 0 / "" / false，不因缺项崩溃。
+// 契约未强约束是否带 success 信封（错误体格式以现网为准），故按 HTTP status 分支，
+// data 缺失时把整个 body 当作扁平 profile 兜底。
+type ProfileResponse = {
+  success?: boolean
+  message?: string
+  username?: string
+  avatar?: string
+  quota?: number
+  used_quota?: number
+  token_remain?: number
+  token_used?: number
+  token_used_today?: number
+  unlimited?: boolean
+  data?: {
+    username?: string
+    avatar?: string
+    quota?: number
+    used_quota?: number
+    token_remain?: number
+    token_used?: number
+    token_used_today?: number
+    unlimited?: boolean
+  }
+}
+
+// [cx] US-008: 单 key 的 profile 拉取结果。unconfigured 由 key 解析阶段处理（无凭据的
+// key 不会进列表），故此处只有 loading / error / ready 三态。
+type KeyProfileState =
+  | { status: "loading" }
+  | { status: "error"; message: string }
+  | ({ status: "ready" } & ProfileData)
+
+// [cx] US-008/US-009: 已解析的可用 key 条目（本地 store 或构建期回退）。key 为明文，仅本地
+// 持有，展示前必经 maskKey 打码。builtin=true 表示这是构建期注入的内置渠道合成条目（不在
+// 本地 store，不可增删改切换）。baseURL 为「查询用有效地址」（条目自带 or 回退构建期变量）。
+type ResolvedKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  isActive: boolean
+  builtin: boolean
+  models: string[]
+}
+
+// 本地 store 里的原始条目（与主进程 store-channel-keys.ts 的 ChannelKey 对齐）。
+type StoredChannelKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  models?: string[]
+}
+
+function isStoredChannelKey(value: unknown): value is StoredChannelKey {
+  if (!value || typeof value !== "object") return false
+  const r = value as Record<string, unknown>
+  return (
+    typeof r.id === "string" &&
+    typeof r.label === "string" &&
+    typeof r.key === "string" &&
+    typeof r.baseURL === "string"
+  )
+}
+
+function normalizeModels(value: unknown): string[] {
+  if (!Array.isArray(value)) return []
+  return value.filter((m): m is string => typeof m === "string" && m.length > 0)
+}
+
+type ChannelState = { keys: StoredChannelKey[]; activeKeyId: string | null }
+
+// [cx] US-009: 读本地 key 列表状态。经专用 IPC channelKeysList 拿到 JSON 字符串再解析；
+// 任何异常/脏数据都吞掉返回空状态，绝不抛出。
+async function loadChannelState(): Promise<ChannelState> {
+  try {
+    const raw = await window.api.channelKeysList()
+    if (!raw) return { keys: [], activeKeyId: null }
+    const parsed = JSON.parse(raw) as { keys?: unknown; activeKeyId?: unknown }
+    if (!parsed || typeof parsed !== "object" || !Array.isArray(parsed.keys)) {
+      return { keys: [], activeKeyId: null }
+    }
+    const keys = parsed.keys.filter(isStoredChannelKey).map((k) => ({ ...k, models: normalizeModels(k.models) }))
+    const activeKeyId =
+      typeof parsed.activeKeyId === "string" && keys.some((k) => k.id === parsed.activeKeyId)
+        ? parsed.activeKeyId
+        : null
+    return { keys, activeKeyId }
+  } catch {
+    return { keys: [], activeKeyId: null }
+  }
+}
+
+// [cx] US-008/US-009: 把 store 状态解析成面板要展示的 key 列表。本地有 key 时全部展示
+// （含缺 baseURL 的条目：查询用地址回退构建期变量），并标注激活项；本地无 key 时回退到构建期
+// 注入的内置渠道合成单条（builtin，不可增删改切换），保证面板仍可用。
+function resolveKeyList(state: ChannelState): ResolvedKey[] {
+  const fallbackBase = import.meta.env.NEWAPI_BASE_URL ?? ""
+  if (state.keys.length > 0) {
+    return state.keys.map((k) => ({
+      id: k.id,
+      label: k.label || "未命名 key",
+      key: k.key,
+      baseURL: k.baseURL || fallbackBase,
+      isActive: k.id === state.activeKeyId,
+      builtin: false,
+      models: normalizeModels(k.models),
+    }))
+  }
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+  if (fallbackBase && apiKey) {
+    return [
+      { id: "__builtin__", label: "内置渠道", key: apiKey, baseURL: fallbackBase, isActive: true, builtin: true, models: [] },
+    ]
+  }
+  return []
+}
+
+// [cx] US-006/US-008: 按指定 key/baseURL 拉取 profile。任何异常都被捕获并转成 error 态返回，
+// 本函数永不抛出。凭据由参数传入（逐 key 查询）——不同 key 可能是不同账户。
+async function fetchProfileWith(baseURL: string, apiKey: string): Promise<KeyProfileState> {
+  if (!baseURL || !apiKey) return { status: "error", message: "缺少渠道凭据" }
+  try {
+    const url = deriveApiBase(baseURL) + APP_PROFILE_PATH
+    const res = await fetch(url, {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return { status: "error", message: `请求返回 HTTP ${res.status}` }
+
+    const body = (await res.json()) as ProfileResponse
+    // 契约可能带 success 信封；显式 success === false 视为失败。
+    if (body.success === false) {
+      return { status: "error", message: body.message || "接口返回失败" }
+    }
+    // profile 字段可能在 data 信封内或扁平在 body 顶层，两者都兼容。
+    const p = body.data ?? body
+    return {
+      status: "ready",
+      username: p.username ?? "",
+      avatar: p.avatar ?? "",
+      quota: p.quota ?? 0,
+      usedQuota: p.used_quota ?? 0,
+      tokenRemain: p.token_remain ?? 0,
+      tokenUsed: p.token_used ?? 0,
+      tokenUsedToday: p.token_used_today ?? 0,
+      unlimited: p.unlimited ?? false,
+    }
+  } catch (error) {
+    return {
+      status: "error",
+      message: error instanceof Error ? error.message : "网络请求失败",
+    }
+  }
+}
+
+// [cx] US-009: 拉取某 key 的可用模型列表（OpenAI 兼容 /v1/models，带 Bearer sk-）。
+// 返回模型 id 字符串数组；任何异常/非 200/脏响应都返回空数组，本函数永不抛出。
+// 用于「切换激活 key 后更新内核可选模型」——结果落盘进 key 条目，server.ts 构造 config 时注入。
+async function fetchModelsWith(baseURL: string, apiKey: string): Promise<string[]> {
+  if (!baseURL || !apiKey) return []
+  try {
+    const res = await fetch(deriveModelsUrl(baseURL), {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return []
+    const body = (await res.json()) as { data?: unknown } | unknown[]
+    const list = Array.isArray(body) ? body : Array.isArray((body as { data?: unknown }).data) ? (body as { data: unknown[] }).data : []
+    const ids = list
+      .map((m) => (typeof m === "string" ? m : m && typeof m === "object" ? (m as { id?: unknown }).id : undefined))
+      .filter((id): id is string => typeof id === "string" && id.length > 0)
+    return Array.from(new Set(ids))
+  } catch {
+    return []
+  }
+}
+
+// [cx] US-007/US-008: 入口按钮身份展示用——解析当前激活 key 的凭据（本地激活项优先，
+// 无则回退列表首个，再无则回退构建期注入变量）。返回 null 表示无任何可用凭据。
+async function resolveActiveCreds(): Promise<{ baseURL: string; apiKey: string } | null> {
+  const state = await loadChannelState()
+  if (state.keys.length > 0) {
+    const active = state.keys.find((k) => k.id === state.activeKeyId) ?? state.keys[0]
+    const baseURL = active.baseURL || (import.meta.env.NEWAPI_BASE_URL ?? "")
+    if (active && baseURL && active.key) return { baseURL, apiKey: active.key }
+  }
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+  if (baseURL && apiKey) return { baseURL, apiKey }
+  return null
+}
+
+// ============================================================================
+// [cx] US-012: 失效自动切换 key —— 检测内核调用失败中「额度耗尽 / key 失效」类错误，
+// 自动切换到列表中下一个可用 key 并重建内核 config（重启 sidecar），给用户可见提示。
+//
+// 检测来源（内核错误出口）：内核 sidecar 暴露 SSE 事件流 `/global/event`（Basic 鉴权
+// opencode:password，凭据来自 window.api.awaitInitialization()）。内核每次调用（生成）失败
+// 都会发 `session.error` 事件，`properties.error` 是判别联合：
+//   - ProviderAuthError —— provider 鉴权失败（key 失效 / 无权限）；
+//   - APIError —— 上游 HTTP 错误，含 statusCode / message / responseBody。
+// 我们据此识别「额度耗尽 / key 失效」这一类可切换的错误（见 classifyKernelError）。
+//
+// 生效机制：内核 config 是启动期一次性注入（US-002 结论：换 key 必须重启 sidecar），故
+// 「切换到下一个 key + 重建 config」= channelKeysSetActive(下一个 key) + relaunch（重启后
+// 主进程 buildChannelConfigContent 读新激活 key 重建 OPENCODE_CONFIG_CONTENT）。
+//
+// 不无限重试：把「本次会话内已失败」的 key id 记进 localStorage（带 TTL，额度可能次日恢复），
+// 自动切换只在「未失败」的 key 里挑下一个；全部 key 都失败时给明确提示、不再切换/重启。
+// localStorage 跨重启保留，故重启后新激活 key 若仍失败也会被记入，避免 A↔B 无限重启环。
+// ============================================================================
+
+// [cx] US-012: 已识别为「额度耗尽 / key 失效」的内核调用错误。message 仅用于展示/日志摘要，
+// 不含 sk- 明文（错误体来自内核，不回显任何本地 key）。
+type KernelCallError = { kind: "auth" | "quota"; message: string }
+
+// [cx] US-012: 从内核 session.error 的 error 对象识别「额度耗尽 / key 失效」类错误。
+// 命中返回分类结果，否则返回 null（如用户主动中断 MessageAbortedError、输出超长等不切换）。
+function classifyKernelError(error: unknown): KernelCallError | null {
+  if (!error || typeof error !== "object") return null
+  const e = error as { name?: unknown; data?: unknown }
+  const name = typeof e.name === "string" ? e.name : ""
+  const data = (e.data && typeof e.data === "object" ? e.data : {}) as {
+    message?: unknown
+    statusCode?: unknown
+    responseBody?: unknown
+  }
+  const message = typeof data.message === "string" ? data.message : ""
+  const responseBody = typeof data.responseBody === "string" ? data.responseBody : ""
+  const statusCode = typeof data.statusCode === "number" ? data.statusCode : undefined
+  const haystack = `${message}\n${responseBody}`.toLowerCase()
+
+  // provider 鉴权失败 —— 直接视为 key 失效类。
+  if (name === "ProviderAuthError") return { kind: "auth", message: message || "凭据鉴权失败" }
+
+  // 只对上游 API 错误做进一步判别；其余（UnknownError / OutputLength / Aborted）不切换。
+  if (name !== "APIError") return null
+
+  // 额度耗尽：new-api / OpenAI 兼容常见特征（402 付费 / 429 限流 + 额度类文案）。
+  const quotaHit =
+    statusCode === 402 ||
+    /insufficient|quota|balance|exceeded|欠费|额度|余额|耗尽|不足|out of credits?/.test(haystack)
+  if (quotaHit) return { kind: "quota", message: message || `额度不足（HTTP ${statusCode ?? "?"}）` }
+  if (statusCode === 429 && /quota|额度|余额|balance/.test(haystack))
+    return { kind: "quota", message: message || "额度不足（限流）" }
+
+  // key 失效 / 无权限：401 或明确的鉴权失败文案。
+  const authHit =
+    statusCode === 401 ||
+    statusCode === 403 ||
+    /unauthorized|invalid[_\s-]*api[_\s-]*key|invalid[_\s-]*key|expired|token.*invalid|invalid.*token|无效|失效|密钥错误|鉴权/.test(
+      haystack,
+    )
+  if (authHit) return { kind: "auth", message: message || `凭据无效（HTTP ${statusCode ?? "?"}）` }
+
+  return null
+}
+
+// [cx] US-012: 订阅内核 session.error 事件流。凭据来自 awaitInitialization（sidecar 的 url /
+// Basic 认证），断线自动重连（3s 退避）。任何错误都吞掉不抛出，signal.abort 后干净退出。
+// 命中「额度耗尽 / key 失效」类错误时回调 onError。轻量实现：不引入上游 SDK 的合流/心跳逻辑，
+// 只做「读取 SSE → 抽 data → 找 session.error」这一件事，避免耦合上游聊天上下文。
+async function subscribeSessionErrors(
+  onError: (error: KernelCallError) => void,
+  signal: AbortSignal,
+): Promise<void> {
+  const wait = (ms: number) => new Promise<void>((resolve) => setTimeout(resolve, ms))
+  while (!signal.aborted) {
+    try {
+      const init = await window.api.awaitInitialization()
+      const base = (init?.url ?? "").replace(/\/+$/, "")
+      if (!base) {
+        await wait(3000)
+        continue
+      }
+      const headers: Record<string, string> = { Accept: "text/event-stream" }
+      const user = init.username ?? "opencode"
+      const pass = init.password ?? ""
+      if (pass) headers.Authorization = "Basic " + btoa(`${user}:${pass}`)
+
+      const res = await fetch(`${base}/global/event`, { headers, signal })
+      if (!res.ok || !res.body) {
+        await wait(3000)
+        continue
+      }
+
+      const reader = res.body.getReader()
+      const decoder = new TextDecoder()
+      let buf = ""
+      while (!signal.aborted) {
+        const { done, value } = await reader.read()
+        if (done) break
+        buf += decoder.decode(value, { stream: true })
+        let sep: number
+        // SSE 事件以空行（\n\n）分隔；逐个取出解析。
+        while ((sep = buf.indexOf("\n\n")) !== -1) {
+          const rawEvent = buf.slice(0, sep)
+          buf = buf.slice(sep + 2)
+          const dataStr = rawEvent
+            .split("\n")
+            .filter((line) => line.startsWith("data:"))
+            .map((line) => line.slice(5).trimStart())
+            .join("\n")
+          if (!dataStr) continue
+          try {
+            const msg = JSON.parse(dataStr) as { payload?: { type?: string; properties?: { error?: unknown } } }
+            const payload = msg?.payload ?? (msg as unknown as { type?: string; properties?: { error?: unknown } })
+            if (payload?.type === "session.error") {
+              const classified = classifyKernelError(payload.properties?.error)
+              if (classified) onError(classified)
+            }
+          } catch {
+            // 单条事件解析失败不影响后续；忽略。
+          }
+        }
+      }
+    } catch {
+      // 网络中断 / abort —— 落到下方重连退避。
+    }
+    if (signal.aborted) return
+    await wait(3000)
+  }
+}
+
+// [cx] US-012: 记录「已失败」key（额度耗尽 / 失效）到 localStorage，防止自动切换反复挑到同一个
+// 坏 key（含跨重启，避免无限重启环）。带 TTL——额度可能次日恢复，过期后重新可被自动选中。
+const FAILED_KEYS_STORAGE = "opencode.desktop.channel-keys.failed"
+const FAILED_TTL_MS = 10 * 60 * 1000
+
+type FailedKeyRec = { id: string; ts: number }
+
+function readFailedKeyRecs(): FailedKeyRec[] {
+  try {
+    if (typeof localStorage !== "object") return []
+    const raw = localStorage.getItem(FAILED_KEYS_STORAGE)
+    if (!raw) return []
+    const arr = JSON.parse(raw) as unknown
+    if (!Array.isArray(arr)) return []
+    const now = Date.now()
+    return arr.filter(
+      (r): r is FailedKeyRec =>
+        !!r && typeof (r as FailedKeyRec).id === "string" && typeof (r as FailedKeyRec).ts === "number" && now - (r as FailedKeyRec).ts < FAILED_TTL_MS,
+    )
+  } catch {
+    return []
+  }
+}
+
+function readFailedKeyIds(): string[] {
+  return readFailedKeyRecs().map((r) => r.id)
+}
+
+function markKeyFailed(id: string): void {
+  if (!id) return
+  try {
+    if (typeof localStorage !== "object") return
+    const recs = readFailedKeyRecs().filter((r) => r.id !== id)
+    recs.push({ id, ts: Date.now() })
+    localStorage.setItem(FAILED_KEYS_STORAGE, JSON.stringify(recs))
+  } catch {
+    // localStorage 不可用不影响主流程（仅退化为不跨重启记忆）。
+  }
+}
+
+// [cx] US-012: 自动切换的用户可见提示。
+//   - switched：已自动切到下一个可用 key（message 含目标 key 名），带「立即重启」使新 config 生效；
+//   - exhausted：所有 key 都不可用，明确提示、不再切换/重启（避免无限重试）。
+type AutoSwitchNotice = { kind: "switched" | "exhausted"; message: string }
+
+// [cx] US-012: 处理一次内核调用失败（已判定为额度耗尽 / key 失效）。串行化 + 幂等：
+//   - 用模块级 handling 标志避免并发处理（一次失败可能触发多条 error / 重连重放）；
+//   - 已产生「switched」提示（等待用户重启）后，忽略后续错误，不反复切换。
+// 流程：标记当前激活 key 失败 → 在「未失败、有有效凭据」的 stored key 里挑「下一个」（列表顺序
+// 轮转）→ channelKeysSetActive + 拉 /v1/models 落盘（重建 config 的模型集合）→ switched 提示；
+// 无下一个可用 key → exhausted 提示，不再重试。切换只改本地激活项 + 缓存模型，config 由下次
+// spawn 重建（US-002：换 key 必须重启 sidecar 才生效），故提示里给「立即重启」。
+let autoSwitchHandling = false
+
+async function handleKernelCallError(
+  error: KernelCallError,
+  setNotice: (notice: AutoSwitchNotice | null) => void,
+): Promise<void> {
+  if (autoSwitchHandling) return
+  autoSwitchHandling = true
+  try {
+    const state = await loadChannelState()
+    // 只在本地 stored key 上做切换（channelKeysSetActive 按 id 操作；内置回退无 id 不可切）。
+    const usable = state.keys.filter((k) => (k.key ?? "").trim().length > 0)
+    if (usable.length === 0) return // 无本地 key（仅内置回退）——无从切换，交由面板提示。
+
+    const current = state.keys.find((k) => k.id === state.activeKeyId) ?? usable[0]
+    if (current) markKeyFailed(current.id)
+
+    const failed = new Set(readFailedKeyIds())
+    // 从当前项之后开始按列表顺序轮转，挑第一个「未失败」的 key。
+    const startIdx = Math.max(0, usable.findIndex((k) => k.id === current?.id))
+    let next: StoredChannelKey | undefined
+    for (let i = 1; i <= usable.length; i++) {
+      const cand = usable[(startIdx + i) % usable.length]
+      if (!failed.has(cand.id)) {
+        next = cand
+        break
+      }
+    }
+
+    if (!next) {
+      // 所有 key 都已失败——明确提示、不再切换/重启，避免无限重试。
+      setNotice({
+        kind: "exhausted",
+        message: `所有 key 都不可用（${error.kind === "quota" ? "额度耗尽" : "凭据失效"}）。请在账户面板检查或充值后重试。`,
+      })
+      return
+    }
+
+    // 切换激活项 + 拉该 key 可用模型落盘（供重建 config 时注入），失败不阻断切换。
+    try {
+      await window.api.channelKeysSetActive(next.id)
+      const baseURL = next.baseURL || (import.meta.env.NEWAPI_BASE_URL ?? "")
+      const models = await fetchModelsWith(baseURL, next.key)
+      if (models.length > 0) {
+        try {
+          await window.api.channelKeysSetModels(next.id, models)
+        } catch {
+          // 模型缓存写入失败不阻断切换。
+        }
+      }
+    } catch {
+      // 切换写入失败——退化为提示，不崩溃。
+      setNotice({ kind: "exhausted", message: "自动切换 key 失败，请在账户面板手动切换。" })
+      return
+    }
+
+    const targetName = next.label?.trim() || maskKey(next.key) || "下一个 key"
+    setNotice({
+      kind: "switched",
+      message: `当前 key ${error.kind === "quota" ? "额度耗尽" : "已失效"}，已自动切换到「${targetName}」。重启内核后生效。`,
+    })
+  } finally {
+    autoSwitchHandling = false
+  }
+}
