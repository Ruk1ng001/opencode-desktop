+// [cx] 独立账户面板 —— 对接 new-api 取用户名/头像/额度/用量（US-006）+ 充值入口（US-007）
+//     + key 列表卡片 UI + 顶部账户汇总（US-008）
+//
+// 设计约束（见 TODO.md / brand/docs/api-app-profile.md / 验收标准）：
+//   - 独立展示区域，与 opencode 原有聊天 UI 组件完全解耦；本文件不 import 任何
+//     上游 app / session-ui 组件，仅依赖 solid-js，可离线 typecheck。
+//   - 明确入口：一个独立悬浮按钮「账户」，点击打开全屏浮层面板。
+//   - 打开面板时向 new-api 只读 profile 接口（GET /api/app/profile）拉取真实
+//     用户名/头像/额度/用量，解析后做单位换算与中文标注。
+//   - [cx] US-006: 端点从旧的 /api/user/self 改为 /api/app/profile。旧端点走
+//     用户会话/系统令牌鉴权，用 sk- API Token 调会失败（TODO 第七节风险 #3）；
+//     新端点走 token 鉴权中间件（同 /v1/*），由 sk- 定位 token → 本人 profile
+//     （见 brand/docs/api-app-profile.md）。
+//   - [cx] US-008: 面板不再只看构建期注入的单 key，而是读 US-003 本地 key 列表
+//     （主进程 store-channel-keys 写入的 `channelKeys`），renderer 经 window.api.storeGet
+//     同步读到。顶部汇总区展示「当前激活 key」账户的头像/用户名/账户总额度/账户已用
+//     （进度条）+ 一键刷新；下方逐 key 卡片，每张卡片按各自 key 独立调 /api/app/profile
+//     （不同 key 可能是不同账户），激活 key 卡片有明显选中态。本地无 key 列表时回退到
+//     构建期注入的内置渠道（NEWAPI_BASE_URL / NEWAPI_API_KEY）合成单条，保持面板可用。
+//   - baseURL 与鉴权凭据：优先取本地 key 条目（每张卡片各自的 baseURL/key），
+//     回退构建期注入的同名变量（NEWAPI_BASE_URL / NEWAPI_API_KEY），本文件不硬编码任何地址/密钥。
+//   - 各数据状态各有明确提示：加载中 / 请求失败 / 未配置凭据 / 就绪。
+//   - 全部网络请求包在 try/catch 内，任何错误都落入 error 态，绝不抛出，
+//     不阻塞主程序，也不让面板崩溃。
+//   - 全部中文文案。样式用内联对象，不依赖上游 tailwind / 主题变量。
+//   - US-007 充值入口：面板含「充值」按钮，点击后经 window.api.openLink（→ 主进程
+//     shell.openExternal）在系统默认浏览器打开 new-api 充值页面。充值 URL 走注入变量
+//     NEWAPI_TOPUP_URL，缺省回退到 new-api 站点根。客户端内不实现任何支付逻辑。
+//   - 安全底线：key 明文仅本地持有，展示层一律打码（maskKey），绝不整段渲染或写日志。
+
+import { createSignal, onMount, For, Show, Switch, Match } from "solid-js"
+import type { JSX } from "solid-js"
+
+// [cx] US-006: new-api 只读 profile 接口路径（站点根下，非 /v1 渠道端点）。
+// 走 token 鉴权中间件，由 Bearer sk- 定位 token → 返回本人 profile。
+// 见 brand/docs/api-app-profile.md。替换旧的 /api/user/self（sk- 鉴权失败）。
+const APP_PROFILE_PATH = "/api/app/profile"
+
+// new-api 默认 QuotaPerUnit：500000 额度 = 1 美元（common.QuotaPerUnit 默认值）。
+// 若目标站点改了该值，展示的货币金额会有偏差——额度原值同时展示以便对照。
+const QUOTA_PER_UNIT = 500000
+
+// [cx] US-008: 本地 key 列表存储位置。与主进程 store-channel-keys.ts / store-keys.ts
+// 保持一致的字面量（renderer 不 import 主进程模块，故内联；同 i18n 里直接用
+// "opencode.global.dat" 的模式）。主进程以对象形式 set 到该键，store-get IPC 返回其
+// JSON.stringify 字符串，本文件解析回对象。
+const SETTINGS_STORE_NAME = "opencode.settings"
+const CHANNEL_KEYS_STORE_KEY = "channelKeys"
+
+// 从渠道 baseURL（US-003 的 NEWAPI_BASE_URL，如 https://host/v1）推导 new-api 站点根，
+// 用户接口挂在站点根 /api 下而非 /v1 渠道端点下。
+function deriveApiBase(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return trimmed.replace(/\/v1$/, "")
+}
+
+// [cx] US-007: 解析充值页面 URL。优先用注入变量 NEWAPI_TOPUP_URL（构建期由
+// electron.vite renderer.define 从 process.env 注入），缺省回退到 new-api 站点根
+// （由渠道 baseURL 推导）。两者都缺失时返回空串，此时不渲染充值入口。
+function resolveTopupUrl(): string {
+  const topup = (import.meta.env.NEWAPI_TOPUP_URL ?? "").trim()
+  if (topup) return topup
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  return deriveApiBase(baseURL)
+}
+
+// [cx] US-007: 在系统默认浏览器打开充值页面。renderer 是浏览器上下文，不能直接调
+// electron shell，走 preload 暴露的 window.api.openLink（→ 主进程 ipc "open-link"
+// → shell.openExternal，见 packages/desktop/src/main/ipc.ts）。客户端内不实现任何
+// 支付逻辑，只负责把充值 URL 交给系统浏览器。
+function openTopup(url: string): void {
+  if (!url) return
+  try {
+    window.api.openLink(url)
+  } catch {
+    // openLink 只是发一条 ipc 消息，正常不会抛出；即便异常也不应让面板崩溃。
+  }
+}
+
+// 额度 → 美元金额（两位小数）。
+function formatCurrency(quotaUnits: number): string {
+  return "$" + (quotaUnits / QUOTA_PER_UNIT).toFixed(2)
+}
+
+// 额度原值本地化（千分位）。
+function formatUnits(quotaUnits: number): string {
+  return quotaUnits.toLocaleString("zh-CN")
+}
+
+// [cx] US-006: 无头像时的占位首字（取用户名首个字符，空则用「?」）。
+function avatarInitial(username: string): string {
+  const trimmed = username.trim()
+  return trimmed ? trimmed[0].toUpperCase() : "?"
+}
+
+// [cx] US-008: key 打码展示（`sk-…abcd`）。仅保留可辨识的前缀与末 4 位，
+// 绝不整段渲染 key 明文。空串返回空。
+function maskKey(key: string): string {
+  const k = key.trim()
+  if (!k) return ""
+  if (k.length <= 7) return "…" + k.slice(-Math.min(4, k.length))
+  return `${k.slice(0, 3)}…${k.slice(-4)}`
+}
+
+// [cx] US-006: profile 就绪态承载 8 个字段（用户名/头像/账户额度/key 用量/是否不限额）。
+// 额度类字段均为 new-api 原始 quota 整数，换算/显示在渲染层做。
+type ProfileData = {
+  username: string
+  avatar: string
+  quota: number
+  usedQuota: number
+  tokenRemain: number
+  tokenUsed: number
+  tokenUsedToday: number
+  unlimited: boolean
+}
+
+// [cx] US-006: /api/app/profile 响应信封（见 brand/docs/api-app-profile.md 第 3 节）。
+// 字段全部可选，做防御性解析——缺字段回退到 0 / "" / false，不因缺项崩溃。
+// 契约未强约束是否带 success 信封（错误体格式以现网为准），故按 HTTP status 分支，
+// data 缺失时把整个 body 当作扁平 profile 兜底。
+type ProfileResponse = {
+  success?: boolean
+  message?: string
+  username?: string
+  avatar?: string
+  quota?: number
+  used_quota?: number
+  token_remain?: number
+  token_used?: number
+  token_used_today?: number
+  unlimited?: boolean
+  data?: {
+    username?: string
+    avatar?: string
+    quota?: number
+    used_quota?: number
+    token_remain?: number
+    token_used?: number
+    token_used_today?: number
+    unlimited?: boolean
+  }
+}
+
+// [cx] US-008: 单 key 的 profile 拉取结果。unconfigured 由 key 解析阶段处理（无凭据的
+// key 不会进列表），故此处只有 loading / error / ready 三态。
+type KeyProfileState =
+  | { status: "loading" }
+  | { status: "error"; message: string }
+  | ({ status: "ready" } & ProfileData)
+
+// [cx] US-008: 已解析的可用 key 条目（本地 store 或构建期回退）。key 为明文，仅本地持有，
+// 展示前必经 maskKey 打码。
+type ResolvedKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  isActive: boolean
+}
+
+// 本地 store 里的原始条目（与主进程 store-channel-keys.ts 的 ChannelKey 对齐）。
+type StoredChannelKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+}
+
+function isStoredChannelKey(value: unknown): value is StoredChannelKey {
+  if (!value || typeof value !== "object") return false
+  const r = value as Record<string, unknown>
+  return (
+    typeof r.id === "string" &&
+    typeof r.label === "string" &&
+    typeof r.key === "string" &&
+    typeof r.baseURL === "string"
+  )
+}
+
+// [cx] US-008: 读本地 key 列表（US-003 主进程写入的 `channelKeys`）。经 store-get IPC 拿到
+// JSON 字符串再解析；任何异常/脏数据都吞掉返回 null，绝不抛出。
+async function readChannelKeysFromStore(): Promise<{ keys: StoredChannelKey[]; activeKeyId: string | null } | null> {
+  try {
+    const raw = await window.api.storeGet(SETTINGS_STORE_NAME, CHANNEL_KEYS_STORE_KEY)
+    if (!raw) return null
+    const parsed = JSON.parse(raw) as { keys?: unknown; activeKeyId?: unknown }
+    if (!parsed || typeof parsed !== "object" || !Array.isArray(parsed.keys)) return null
+    const keys = parsed.keys.filter(isStoredChannelKey)
+    const activeKeyId =
+      typeof parsed.activeKeyId === "string" && keys.some((k) => k.id === parsed.activeKeyId)
+        ? parsed.activeKeyId
+        : null
+    return { keys, activeKeyId }
+  } catch {
+    return null
+  }
+}
+
+// [cx] US-008: 解析出面板要展示的 key 列表。优先本地 store（多渠道），其中有凭据的条目
+// 才进列表；本地无 key 时回退到构建期注入的内置渠道合成单条，保证面板仍可用。
+async function resolveKeyList(): Promise<ResolvedKey[]> {
+  const stored = await readChannelKeysFromStore()
+  if (stored && stored.keys.length > 0) {
+    const usable = stored.keys.filter((k) => k.baseURL && k.key)
+    if (usable.length > 0) {
+      return usable.map((k) => ({
+        id: k.id,
+        label: k.label || "未命名 key",
+        key: k.key,
+        baseURL: k.baseURL,
+        isActive: k.id === stored.activeKeyId,
+      }))
+    }
+  }
+  // 回退：本地无可用 key 列表时，用构建期注入的内置渠道合成单条（激活）。
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+  if (baseURL && apiKey) {
+    return [{ id: "__builtin__", label: "内置渠道", key: apiKey, baseURL, isActive: true }]
+  }
+  return []
+}
+
+// [cx] US-008: 按指定 key/baseURL 拉取 profile。任何异常都被捕获并转成 error 态返回，
+// 本函数永不抛出。相比旧的 fetchProfile()，凭据由参数传入（逐 key 查询），不再直接读
+// import.meta.env——不同 key 可能是不同账户。
+async function fetchProfileWith(baseURL: string, apiKey: string): Promise<KeyProfileState> {
+  if (!baseURL || !apiKey) return { status: "error", message: "缺少渠道凭据" }
+  try {
+    const url = deriveApiBase(baseURL) + APP_PROFILE_PATH
+    const res = await fetch(url, {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return { status: "error", message: `请求返回 HTTP ${res.status}` }
+
+    const body = (await res.json()) as ProfileResponse
+    // 契约可能带 success 信封；显式 success === false 视为失败。
+    if (body.success === false) {
+      return { status: "error", message: body.message || "接口返回失败" }
+    }
+    // profile 字段可能在 data 信封内或扁平在 body 顶层，两者都兼容。
+    const p = body.data ?? body
+    return {
+      status: "ready",
+      username: p.username ?? "",
+      avatar: p.avatar ?? "",
+      quota: p.quota ?? 0,
+      usedQuota: p.used_quota ?? 0,
+      tokenRemain: p.token_remain ?? 0,
+      tokenUsed: p.token_used ?? 0,
+      tokenUsedToday: p.token_used_today ?? 0,
+      unlimited: p.unlimited ?? false,
+    }
+  } catch (error) {
+    return {
+      status: "error",
+      message: error instanceof Error ? error.message : "网络请求失败",
+    }
+  }
+}
+
+// [cx] US-007/US-008: 入口按钮身份展示用——解析当前激活 key 的凭据（本地激活项优先，
+// 无则回退列表首个，再无则回退构建期注入变量）。返回 null 表示无任何可用凭据。
+async function resolveActiveCreds(): Promise<{ baseURL: string; apiKey: string } | null> {
+  const stored = await readChannelKeysFromStore()
+  if (stored && stored.keys.length > 0) {
+    const active = stored.keys.find((k) => k.id === stored.activeKeyId) ?? stored.keys[0]
+    if (active && active.baseURL && active.key) return { baseURL: active.baseURL, apiKey: active.key }
+  }
+  const baseURL = import.meta.env.NEWAPI_BASE_URL ?? ""
+  const apiKey = import.meta.env.NEWAPI_API_KEY ?? ""
+  if (baseURL && apiKey) return { baseURL, apiKey }
+  return null
+}
