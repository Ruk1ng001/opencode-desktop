+// [cx] 独立余额面板 —— 界面骨架（US-005，新增文件）
+//
+// 设计约束（见 TODO.md / 验收标准）：
+//   - 独立展示区域，与 opencode 原有聊天 UI 组件完全解耦；本文件不 import 任何
+//     上游 app / session-ui 组件，仅依赖 solid-js，可离线 typecheck。
+//   - 明确入口：一个独立悬浮按钮「账户」，点击打开全屏浮层面板。
+//   - 占位区块：余额 / 已用量 / 充值按钮，数据均为**静态占位**，后续故事接入
+//     真实渠道（new-api）账户接口后替换 PLACEHOLDER 即可。
+//   - 全部中文文案。
+//   - 样式用内联对象，不依赖上游 tailwind / 主题变量，保证独立可渲染。
+
+import { createSignal, Show } from "solid-js"
+import type { JSX } from "solid-js"
+
+// 静态占位数据。后续接入真实账户接口时替换本常量即可，UI 结构不变。
+const PLACEHOLDER = {
+  balance: "¥ 0.00",
+  used: "¥ 0.00",
+  updatedAt: "—",
+}
+
+const Z_LAUNCHER = 9998
+const Z_OVERLAY = 9999
+
+const launcherStyle: JSX.CSSProperties = {
+  position: "fixed",
+  right: "16px",
+  bottom: "16px",
+  "z-index": String(Z_LAUNCHER),
+  display: "inline-flex",
+  "align-items": "center",
+  gap: "6px",
+  padding: "8px 14px",
+  "border-radius": "9999px",
+  border: "1px solid rgba(255,255,255,0.14)",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "13px",
+  "font-weight": "500",
+  cursor: "pointer",
+  "box-shadow": "0 2px 8px rgba(0,0,0,0.25)",
+}
+
+const overlayStyle: JSX.CSSProperties = {
+  position: "fixed",
+  inset: "0",
+  "z-index": String(Z_OVERLAY),
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "center",
+  background: "rgba(0,0,0,0.5)",
+}
+
+const panelStyle: JSX.CSSProperties = {
+  width: "min(420px, 90vw)",
+  "max-height": "90vh",
+  overflow: "auto",
+  background: "#161618",
+  color: "#e5e5e5",
+  border: "1px solid rgba(255,255,255,0.12)",
+  "border-radius": "12px",
+  padding: "20px",
+  "box-shadow": "0 12px 40px rgba(0,0,0,0.5)",
+  "font-size": "14px",
+}
+
+const headerStyle: JSX.CSSProperties = {
+  display: "flex",
+  "align-items": "center",
+  "justify-content": "space-between",
+  "margin-bottom": "16px",
+}
+
+const cardStyle: JSX.CSSProperties = {
+  background: "rgba(255,255,255,0.04)",
+  border: "1px solid rgba(255,255,255,0.08)",
+  "border-radius": "8px",
+  padding: "14px 16px",
+  "margin-bottom": "12px",
+}
+
+const cardLabelStyle: JSX.CSSProperties = {
+  "font-size": "12px",
+  color: "#9ca3af",
+  "margin-bottom": "6px",
+}
+
+const cardValueStyle: JSX.CSSProperties = {
+  "font-size": "22px",
+  "font-weight": "600",
+  color: "#f5f5f5",
+}
+
+const closeButtonStyle: JSX.CSSProperties = {
+  background: "transparent",
+  border: "none",
+  color: "#9ca3af",
+  "font-size": "18px",
+  cursor: "pointer",
+  "line-height": "1",
+  padding: "4px",
+}
+
+const topupButtonStyle: JSX.CSSProperties = {
+  width: "100%",
+  padding: "10px 16px",
+  "margin-top": "4px",
+  "border-radius": "8px",
+  border: "none",
+  background: "#2563eb",
+  color: "#ffffff",
+  "font-size": "14px",
+  "font-weight": "500",
+  cursor: "pointer",
+}
+
+const hintStyle: JSX.CSSProperties = {
+  "margin-top": "10px",
+  "font-size": "12px",
+  color: "#9ca3af",
+  "text-align": "center",
+}
+
+function BalancePanel(props: { onClose: () => void }) {
+  const [hint, setHint] = createSignal(false)
+
+  return (
+    <div style={overlayStyle} onClick={props.onClose} role="presentation">
+      <div
+        style={panelStyle}
+        role="dialog"
+        aria-modal="true"
+        aria-label="账户面板"
+        onClick={(event) => event.stopPropagation()}
+      >
+        <div style={headerStyle}>
+          <span style={{ "font-size": "16px", "font-weight": "600" }}>账户</span>
+          <button type="button" style={closeButtonStyle} aria-label="关闭" onClick={props.onClose}>
+            ✕
+          </button>
+        </div>
+
+        <div style={cardStyle}>
+          <div style={cardLabelStyle}>余额</div>
+          <div style={cardValueStyle}>{PLACEHOLDER.balance}</div>
+        </div>
+
+        <div style={cardStyle}>
+          <div style={cardLabelStyle}>已用量</div>
+          <div style={cardValueStyle}>{PLACEHOLDER.used}</div>
+        </div>
+
+        <button type="button" style={topupButtonStyle} onClick={() => setHint(true)}>
+          充值
+        </button>
+
+        <Show when={hint()}>
+          <div style={hintStyle}>充值功能即将上线，敬请期待</div>
+        </Show>
+
+        <div style={{ ...hintStyle, "margin-top": "16px" }}>数据为占位示例 · 更新时间 {PLACEHOLDER.updatedAt}</div>
+      </div>
+    </div>
+  )
+}
+
+// 独立入口 + 面板容器。挂载在聊天界面之外，自管理开合状态，不与聊天 UI 共享任何上下文。
+export function BalanceLauncher() {
+  const [open, setOpen] = createSignal(false)
+
+  return (
+    <>
+      <button type="button" style={launcherStyle} aria-label="打开账户面板" onClick={() => setOpen(true)}>
+        账户
+      </button>
+      <Show when={open()}>
+        <BalancePanel onClose={() => setOpen(false)} />
+      </Show>
+    </>
+  )
+}
