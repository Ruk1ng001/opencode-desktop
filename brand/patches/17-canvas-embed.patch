diff --git a/packages/app/src/components/cx-account/cx-canvas-slots.ts b/packages/app/src/components/cx-account/cx-canvas-slots.ts
new file mode 100644
index 000000000..7fbd074c6
--- /dev/null
+++ b/packages/app/src/components/cx-account/cx-canvas-slots.ts
@@ -0,0 +1,210 @@
+// [dokng] 画布四槽位状态 + 投递 payload 合成（待办 4）。
+//
+// 账户面板每个 key 卡片有四个按钮，对应画布的四类模型能力：
+//   - 生图槽 imageKeyId ← 点了「生图」的 key（供 image 类模型）
+//   - 视频槽 videoKeyId ← 点了「视频」的 key（供 video 类模型）
+//   - 文本槽 textKeyId  ← 点了「文本」的 key（供 text 类模型）
+//   - 音频槽 audioKeyId ← 点了「音频」的 key（供 audio 类模型）
+// 用户可自由组合：四类各选一个 key、同一个 key 占多个槽、只选部分。互不干扰。
+//
+// 本模块只管「哪个 key 在哪个槽」+「由槽位 + key 列表合成投给画布的 channel 数组」。
+// 纯前端状态，模块级 signal 跨账户面板（写）与画布页（读+投递）共享，无副作用、无网络。
+// 投递动作（postMessage）在 canvas-embed.tsx；本模块只提供状态与纯合成函数，便于单测与复用。
+
+import { createSignal } from "solid-js"
+import type { ResolvedKey } from "./cx-account-api"
+
+// [dokng] 画布 config store 的 ModelCapability（见 infinite-canvas web/src/stores/use-config-store.ts）。
+// 与画布侧保持一致的四类；宿主显式标注，避免画布 guessCapability 误判 new-api 自定义模型名。
+export type CanvasModelCapability = "image" | "video" | "text" | "audio"
+
+// [dokng] 投给画布的单个渠道模型（画布 ChannelModel 的子集：name + capability）。
+export type CanvasInjectedModel = { name: string; capability: CanvasModelCapability }
+
+// [dokng] 投给画布的单个渠道（画布 InjectedChannel：id/name/baseUrl/apiKey/models）。
+export type CanvasInjectedChannel = {
+  id: string
+  name: string
+  baseUrl: string
+  apiKey: string
+  models: CanvasInjectedModel[]
+}
+
+// [dokng] 完整投递消息（与画布 client-root-init.tsx 的 CanvasConfigMessage 对齐）。
+export type CanvasConfigPayload = {
+  type: "dokng:canvas-config"
+  channels: CanvasInjectedChannel[]
+  imageModel?: string
+  videoModel?: string
+  textModel?: string
+  audioModel?: string
+}
+
+// ============================================================================
+// 四槽位状态（模块级全局，跨组件共享）
+// ============================================================================
+
+const [imageKeyId, setImageKeyId] = createSignal<string | null>(null)
+const [videoKeyId, setVideoKeyId] = createSignal<string | null>(null)
+const [textKeyId, setTextKeyId] = createSignal<string | null>(null)
+const [audioKeyId, setAudioKeyId] = createSignal<string | null>(null)
+
+export const canvasImageKeyId = imageKeyId
+export const canvasVideoKeyId = videoKeyId
+export const canvasTextKeyId = textKeyId
+export const canvasAudioKeyId = audioKeyId
+
+// 点「生图」：切到该 key（再点同一个则取消，生图槽清空）。
+export function toggleCanvasImageKey(id: string) {
+  setImageKeyId((prev) => (prev === id ? null : id))
+}
+
+// 点「视频」：切到该 key（再点同一个则取消，视频槽清空）。
+export function toggleCanvasVideoKey(id: string) {
+  setVideoKeyId((prev) => (prev === id ? null : id))
+}
+
+// 点「文本」：切到该 key（再点同一个则取消，文本槽清空）。
+export function toggleCanvasTextKey(id: string) {
+  setTextKeyId((prev) => (prev === id ? null : id))
+}
+
+// 点「音频」：切到该 key（再点同一个则取消，音频槽清空）。
+export function toggleCanvasAudioKey(id: string) {
+  setAudioKeyId((prev) => (prev === id ? null : id))
+}
+
+// 是否已选中任一槽位（决定「画布」入口是否可直接进入并投递有效渠道）。
+export function hasAnyCanvasSlot(): boolean {
+  return imageKeyId() !== null || videoKeyId() !== null || textKeyId() !== null || audioKeyId() !== null
+}
+
+// [dokng] 模型缓存版本号：key 的可用模型（/v1/models）只在「激活」或「选进画布槽位后按需拉取」时
+// 才落盘到本地 store。落盘后 bump 此版本号，让画布页（canvas-embed 的 createEffect 订阅它）重新
+// 从 store 读最新 key 列表并重投 payload —— 否则画布收到的 channel 带空 models、四类默认模型全空，
+// 表现为「选了 key 但画布渠道/模型不联动」。仅作变化通知，不承载数据。
+const [modelsVersion, setModelsVersion] = createSignal(0)
+export const canvasModelsVersion = modelsVersion
+export function bumpCanvasModels() {
+  setModelsVersion((v) => v + 1)
+}
+
+// ============================================================================
+// payload 合成（纯函数）
+// ============================================================================
+
+// [dokng] 关键字兜底判定：宿主拿到的 new-api 模型名多为自定义名，无 capability 元数据。
+// 与画布 guessCapability 同源关键字，但在宿主侧显式判定后随 payload 下发，避免画布再猜一次。
+const VIDEO_KEYWORDS = ["seedance", "video", "sora", "veo", "kling", "wan", "hailuo"]
+const AUDIO_KEYWORDS = ["audio", "tts", "speech", "voice", "music", "sound"]
+const IMAGE_KEYWORDS = [
+  "seedream",
+  "gpt-image",
+  "image",
+  "dall-e",
+  "dalle",
+  "imagen",
+  "flux",
+  "sdxl",
+  "stable-diffusion",
+  "midjourney",
+]
+
+function guessCapability(name: string): CanvasModelCapability {
+  const value = name.toLowerCase()
+  if (VIDEO_KEYWORDS.some((k) => value.includes(k))) return "video"
+  if (AUDIO_KEYWORDS.some((k) => value.includes(k))) return "audio"
+  if (IMAGE_KEYWORDS.some((k) => value.includes(k))) return "image"
+  return "text"
+}
+
+// [dokng] 一个 key 的模型名列表 → 带 capability 的模型数组，按目标能力集过滤。
+// 若过滤后为空（该 key 没有对应类型的模型），回退全量按各自 capability 下发，避免画布无模型可选。
+function modelsForCapabilities(models: string[], wanted: CanvasModelCapability[]): CanvasInjectedModel[] {
+  const all = models.map((name) => ({ name, capability: guessCapability(name) }))
+  const filtered = all.filter((m) => wanted.includes(m.capability))
+  return filtered.length > 0 ? filtered : all
+}
+
+// 四类能力的固定顺序，用于稳定遍历。
+const CAPABILITIES: CanvasModelCapability[] = ["image", "video", "text", "audio"]
+
+// [dokng] 四类能力的中文标签，用于合成画布渠道名（Dokng:出图|对话|…），让用户在画布渠道列表里
+// 一眼看出「这条渠道 key 被指派了哪些用途」。顺序跟随 CAPABILITIES，保证名字稳定不抖动。
+const CAPABILITY_LABELS: Record<CanvasModelCapability, string> = {
+  image: "出图",
+  video: "视频",
+  text: "对话",
+  audio: "音频",
+}
+
+// [dokng] 由四槽位 + 已解析 key 列表合成投递 payload。核心规则（按 keyId 分组）：
+//   - 每个被选中的 key → 一个画布 channel（baseUrl + apiKey + 该 key 按其占用槽位并集过滤的 models）。
+//   - 同一个 key 占多个槽：合并成一个 channel，models 取所占各能力的并集。
+//   - 不同 key 占不同槽：各成一个 channel，只带对应类型模型。
+//   - 都没选：channels 为空（画布保持自身默认，不被覆盖）。
+// 同时给出各类默认模型选择（channelId::modelName），让画布切到刚接入的渠道模型。
+export function buildCanvasPayload(
+  keys: ResolvedKey[],
+  imgId: string | null,
+  videoId: string | null,
+  textId: string | null,
+  audioId: string | null,
+): CanvasConfigPayload {
+  const byId = new Map(keys.map((k) => [k.id, k]))
+  const slotByCapability: Record<CanvasModelCapability, string | null> = {
+    image: imgId,
+    video: videoId,
+    text: textId,
+    audio: audioId,
+  }
+
+  // 按 keyId 归并：每个被选中的 key → 它占用了哪些能力槽。
+  const capsByKey = new Map<string, CanvasModelCapability[]>()
+  for (const cap of CAPABILITIES) {
+    const id = slotByCapability[cap]
+    if (!id || !byId.has(id)) continue
+    const list = capsByKey.get(id) ?? []
+    list.push(cap)
+    capsByKey.set(id, list)
+  }
+
+  const encode = (channelId: string, models: CanvasInjectedModel[], cap: CanvasModelCapability): string | undefined => {
+    const hit = models.find((m) => m.capability === cap)
+    return hit ? `${channelId}::${hit.name}` : undefined
+  }
+
+  // [dokng] 画布渠道名：Dokng:出图|对话|… —— 前缀标明来自客户端，后接该 key 被指派的用途标签
+  // （按 CAPABILITIES 固定顺序，用 | 连接），让用户在画布渠道列表里直接看出每条渠道的用途联动。
+  const channelName = (caps: CanvasModelCapability[]) => {
+    const labels = CAPABILITIES.filter((cap) => caps.includes(cap)).map((cap) => CAPABILITY_LABELS[cap])
+    return labels.length > 0 ? `Dokng:${labels.join("|")}` : "Dokng:客户端渠道"
+  }
+
+  const channels: CanvasInjectedChannel[] = []
+  const modelsByKey = new Map<string, CanvasInjectedModel[]>()
+
+  for (const [id, caps] of capsByKey) {
+    const key = byId.get(id)!
+    const models = modelsForCapabilities(key.models, caps)
+    channels.push({ id: key.id, name: channelName(caps), baseUrl: key.baseURL, apiKey: key.key, models })
+    modelsByKey.set(id, models)
+  }
+
+  // 各类默认模型：取该能力所选 key 的 channel 里匹配该 capability 的第一个模型。
+  const pick = (cap: CanvasModelCapability): string | undefined => {
+    const id = slotByCapability[cap]
+    if (!id) return undefined
+    const models = modelsByKey.get(id)
+    return models ? encode(id, models, cap) : undefined
+  }
+
+  return {
+    type: "dokng:canvas-config",
+    channels,
+    imageModel: pick("image"),
+    videoModel: pick("video"),
+    textModel: pick("text"),
+    audioModel: pick("audio"),
+  }
+}
diff --git a/packages/app/src/pages/canvas-embed.tsx b/packages/app/src/pages/canvas-embed.tsx
new file mode 100644
index 000000000..05f6175b2
--- /dev/null
+++ b/packages/app/src/pages/canvas-embed.tsx
@@ -0,0 +1,167 @@
+// [dokng] 画布内嵌宿主（待办 4 + 页面保活）。
+//
+// infinite-canvas（React 19 SPA）与宿主（SolidJS）框架异构，不能当组件嵌，只能 <iframe> 隔离。
+// 画布产物构建期以 VITE_BASE=/canvas/ 打包、拷进 desktop 的 out/renderer/canvas/，经 oc:// 特权协议
+// （已白名单整个 out/renderer 子树）以 oc://renderer/canvas/index.html 加载，主进程/preload/协议零改。
+//
+// —— 页面保活（keep-alive）——
+// 本组件不再作为 /canvas 路由页渲染（那样切走即卸载、iframe 重建、画布内容与状态全丢）。
+// 改为常驻挂载在 NewLayout 的 <main> 内容区（Titlebar 下方、跨路由不卸载的外壳）里，用 absolute
+// inset-0 填满内容区承载：靠 useLocation() 判断是否在 /canvas，只切 display 显隐、绝不卸载 iframe。
+// 首次进入 /canvas 才创建 iframe（懒挂载：没进过画布就不加载画布资源）；之后 iframe 常驻内存，
+// 从画布切到别的页面再切回来，画布内容 / 缩放 / 选中态 / 未保存编辑全部原样保留。
+//
+// —— 顶栏 ——
+// 画布只占 Titlebar 下方内容区、不盖顶栏，故壳的 Titlebar（会话 tab 条 + palette 画布入口 +
+// 账户按钮）在画布内全程可见，来回切会话/画布都方便，无需再补返回/账户极简栏。切回会话点会话
+// tab 即可；开账户 / 切四槽位模型走 Titlebar 右侧账户按钮（CxAccountLauncher）。
+//
+// 本组件职责：
+//   1. 渲染填满内容区的 <iframe src="oc://renderer/canvas/index.html">（absolute inset-0，不盖 Titlebar）。
+//   2. 把账户面板选中的 key（四槽位 image/video/text/audio）合成 channel 数组，postMessage 投给画布。
+//      投递时机：① 画布发来 dokng:canvas-ready 握手回执后立即投；② 槽位/模型变化时重投（createEffect）。
+//   3. targetOrigin 严格限 oc://renderer，杜绝把 key 投给非宿主 origin。
+//
+// 全部仅 desktop 生效（key 来自 desktop preload 的 window.api）；非 desktop 时进入 /canvas 显示占位提示。
+
+import { createEffect, createMemo, createSignal, onCleanup, onMount, Show } from "solid-js"
+import { useLocation, useNavigate } from "@solidjs/router"
+import { Icon } from "@opencode-ai/ui/icon"
+import { IconButtonV2 } from "@opencode-ai/ui/v2/icon-button-v2"
+import { usePlatform } from "@/context/platform"
+import { loadChannelState, resolveKeyList, type ResolvedKey } from "@/components/cx-account/cx-account-api"
+import {
+  buildCanvasPayload,
+  canvasAudioKeyId,
+  canvasImageKeyId,
+  canvasModelsVersion,
+  canvasTextKeyId,
+  canvasVideoKeyId,
+} from "@/components/cx-account/cx-canvas-slots"
+
+// 画布产物在 oc://renderer/canvas/ 下的入口；协议层已白名单 out/renderer 全子树。
+const CANVAS_SRC = "oc://renderer/canvas/index.html"
+// 画布 iframe 的 origin（oc 协议 + host=renderer）；postMessage 双向都严格用它，不用 "*"。
+const CANVAS_ORIGIN = "oc://renderer"
+// 画布路由路径：常驻宿主靠它切显隐。
+const CANVAS_PATH = "/canvas"
+
+export default function CanvasHost() {
+  const platform = usePlatform()
+  const navigate = useNavigate()
+  const location = useLocation()
+
+  // 是否处于画布路由（决定覆盖层显隐）。
+  const isCanvas = createMemo(() => location.pathname === CANVAS_PATH)
+
+  // 懒挂载：首次进入 /canvas 才创建 iframe；一旦创建就常驻（保活的关键——之后只切显隐不卸载）。
+  const [mounted, setMounted] = createSignal(false)
+  createEffect(() => {
+    if (isCanvas()) setMounted(true)
+  })
+
+  // 返回：优先浏览器历史回退（保留来源上下文），无历史时兜底回根路由。
+  // 保活下导航走后 iframe 只是 display:none、不卸载，画布状态全留。
+  const goBack = () => {
+    if (window.history.length > 1) navigate(-1)
+    else navigate("/")
+  }
+
+  // 非 desktop：画布依赖 desktop 侧渠道 key。仅在进入 /canvas 时显示占位，其余时候不渲染任何东西。
+  if (platform.platform !== "desktop") {
+    return (
+      <Show when={isCanvas()}>
+        <div class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 bg-v2-background-bg-deep text-v2-text-text-muted">
+          <span>画布仅在桌面客户端可用。</span>
+          <IconButtonV2
+            type="button"
+            variant="neutral"
+            size="small"
+            icon={<Icon name="arrow-left" size="small" />}
+            onClick={goBack}
+            aria-label="返回"
+          />
+        </div>
+      </Show>
+    )
+  }
+
+  let iframeRef: HTMLIFrameElement | undefined
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  const [ready, setReady] = createSignal(false)
+
+  // 向画布 iframe 投递当前槽位合成的渠道配置。画布未 ready 时不投（等握手），避免早投丢失。
+  const post = () => {
+    const win = iframeRef?.contentWindow
+    if (!win || !ready()) return
+    const payload = buildCanvasPayload(keys(), canvasImageKeyId(), canvasVideoKeyId(), canvasTextKeyId(), canvasAudioKeyId())
+    win.postMessage(payload, CANVAS_ORIGIN)
+  }
+
+  // [dokng] 从本地 store 重新拉 key 列表（含账户面板选槽位时按需拉取并落盘的最新 models），
+  // 再触发重投。账户面板 bumpCanvasModels() 后经 canvasModelsVersion 订阅走到这里，确保画布
+  // 拿到刚落盘的模型（onMount 的一次性快照读不到之后缓存的 models）。
+  const refreshKeys = () => {
+    void loadChannelState().then((state) => setKeys(resolveKeyList(state)))
+  }
+
+  onMount(() => {
+    // 加载本地 key 列表（供合成 payload）。异步、失败返回空列表，不抛出。
+    refreshKeys()
+
+    // 画布就绪握手：收到 dokng:canvas-ready 才认为可投递（画布 listener 已挂好）。
+    const onMessage = (event: MessageEvent) => {
+      if (event.origin !== CANVAS_ORIGIN) return
+      const data = event.data as { type?: unknown } | null
+      if (!data || typeof data !== "object") return
+      if (data.type === "dokng:canvas-ready") {
+        setReady(true)
+        post()
+      }
+    }
+    window.addEventListener("message", onMessage)
+    onCleanup(() => window.removeEventListener("message", onMessage))
+  })
+
+  // 账户面板选槽位按需拉到新 models 后 bump 版本 → 这里重新读 store 拿最新 models。
+  // 与下方重投 effect 分离：本 effect 只负责刷新 keys（刷新完 keys() 变化会自然触发重投）。
+  createEffect(() => {
+    void canvasModelsVersion()
+    refreshKeys()
+  })
+
+  // 槽位变化或 key 列表加载完成后重投（画布已 ready 时才实际发送）。
+  createEffect(() => {
+    // 显式订阅四槽位信号 + key 列表 + ready，任一变化触发重投。
+    void canvasImageKeyId()
+    void canvasVideoKeyId()
+    void canvasTextKeyId()
+    void canvasAudioKeyId()
+    void keys()
+    void ready()
+    post()
+  })
+
+  // 常驻内容区层：mounted 前不渲染 iframe（省资源）；mounted 后常驻，靠 isCanvas 切 display。
+  // 挂在 NewLayout 的 <main> 内容区（Titlebar 下方），用 absolute inset-0 填满内容区、不盖
+  // Titlebar，故壳顶栏（会话 tab + palette 画布入口 + 账户按钮）画布内全程可见，切会话/画布都方便。
+  // 无需再补返回/账户极简栏，也无需避让 macOS 红绿灯（红绿灯落在常驻可见的 Titlebar 上）。
+  return (
+    <Show when={mounted()}>
+      <div
+        class="absolute inset-0 z-10 flex flex-col bg-v2-background-bg-deep"
+        style={{ display: isCanvas() ? undefined : "none" }}
+        aria-hidden={isCanvas() ? undefined : "true"}
+      >
+        <iframe
+          ref={iframeRef}
+          src={CANVAS_SRC}
+          title="画布"
+          class="flex-1 min-h-0 min-w-0 w-full border-0"
+          // 沙箱：允许脚本 / 同源（IndexedDB 持久化画布数据）/ 弹窗 / 下载（导出图片）。
+          sandbox="allow-scripts allow-same-origin allow-popups allow-downloads allow-forms"
+        />
+      </div>
+    </Show>
+  )
+}
