diff --git a/packages/desktop/scripts/build-canvas.ts b/packages/desktop/scripts/build-canvas.ts
new file mode 100644
index 000000000..d7b2d88eb
--- /dev/null
+++ b/packages/desktop/scripts/build-canvas.ts
@@ -0,0 +1,35 @@
+#!/usr/bin/env bun
+// [dokng] 画布产物构建（待办 4）：以 VITE_BASE=/canvas/ 构建 infinite-canvas（第二上游），
+// 产出 web/dist/。供 desktop 经 oc://renderer/canvas/ 内嵌 iframe 加载。
+//
+// 与 build-node.ts（构建 opencode 内核 sidecar）同为 prebuild 的一步；dist 的拷贝由
+// electron.vite.config.ts 的 dokng:copy-canvas writeBundle 钩子完成（renderer 构建后拷进
+// out/renderer/canvas/，避免被 emptyOutDir 清掉）。
+//
+// 路径：infinite-canvas 位于父仓库根（open-code/infinite-canvas），相对 packages/desktop
+// 为 ../../../infinite-canvas（与 electron.vite.config.ts 引用 ../../../brand/brand.json 同级）。
+//
+// VITE_BASE=/canvas/：让产物 asset 前缀带 /canvas/，配合画布补丁的 router basename
+// （createBrowserRouter 读 import.meta.env.BASE_URL），使 iframe 在 /canvas/index.html 正常路由。
+//
+// 前置：画布补丁（brand/canvas-patches/）须已应用（由 scripts/apply-canvas-patches.sh 在构建前重放，
+// 对齐 opencode 侧 apply-patches.sh）。未应用则构建的是未打补丁的画布（无 basename / 无 postMessage 注入）。
+//
+// 容错：画布目录缺失时告警并跳过（不阻断 desktop 构建），此时 iframe 会 404——维护者据告警排查。
+import { $ } from "bun"
+import { existsSync } from "node:fs"
+
+const CANVAS_WEB = "../../../infinite-canvas/web"
+
+if (!existsSync(CANVAS_WEB)) {
+  console.warn(`[dokng] 未找到画布源码 ${CANVAS_WEB}，跳过画布构建（内嵌 iframe 将 404）。`)
+  process.exit(0)
+}
+
+console.log("[dokng] 安装画布依赖…")
+await $`bun install`.cwd(CANVAS_WEB)
+
+console.log("[dokng] 构建画布产物（VITE_BASE=/canvas/）…")
+await $`bun run build`.cwd(CANVAS_WEB).env({ ...process.env, VITE_BASE: "/canvas/" })
+
+console.log("[dokng] 画布产物构建完成：infinite-canvas/web/dist/")
