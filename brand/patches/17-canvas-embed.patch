diff --git a/packages/app/src/components/cx-account/cx-canvas-slots.ts b/packages/app/src/components/cx-account/cx-canvas-slots.ts
new file mode 100644
index 000000000..b1389e19a
--- /dev/null
+++ b/packages/app/src/components/cx-account/cx-canvas-slots.ts
@@ -0,0 +1,154 @@
+// [dokng] 画布双槽位状态 + 投递 payload 合成（待办 4）。
+//
+// 账户面板每个 key 卡片有两个按钮：① 启动作图、② 启动作图对话。宿主维护两个独立槽位：
+//   - 作图槽 imageKeyId ← 点了「启动作图」的 key（供 image/video 类模型）
+//   - 对话槽 chatKeyId  ← 点了「启动作图对话」的 key（供 text 类模型）
+// 用户可自由组合：分开选两个 key、同一 key 两个都点、只点一个。互不干扰。
+//
+// 本模块只管「哪个 key 在哪个槽」+「由槽位 + key 列表合成投给画布的 channel 数组」。
+// 纯前端状态，模块级 signal 跨账户面板（写）与画布页（读+投递）共享，无副作用、无网络。
+// 投递动作（postMessage）在 canvas-embed.tsx；本模块只提供状态与纯合成函数，便于单测与复用。
+
+import { createSignal } from "solid-js"
+import type { ResolvedKey } from "./cx-account-api"
+
+// [dokng] 画布 config store 的 ModelCapability（见 infinite-canvas web/src/stores/use-config-store.ts）。
+// 与画布侧保持一致的四类；宿主显式标注，避免画布 guessCapability 误判 new-api 自定义模型名。
+export type CanvasModelCapability = "image" | "video" | "text" | "audio"
+
+// [dokng] 投给画布的单个渠道模型（画布 ChannelModel 的子集：name + capability）。
+export type CanvasInjectedModel = { name: string; capability: CanvasModelCapability }
+
+// [dokng] 投给画布的单个渠道（画布 InjectedChannel：id/name/baseUrl/apiKey/models）。
+export type CanvasInjectedChannel = {
+  id: string
+  name: string
+  baseUrl: string
+  apiKey: string
+  models: CanvasInjectedModel[]
+}
+
+// [dokng] 完整投递消息（与画布 client-root-init.tsx 的 CanvasConfigMessage 对齐）。
+export type CanvasConfigPayload = {
+  type: "dokng:canvas-config"
+  channels: CanvasInjectedChannel[]
+  imageModel?: string
+  videoModel?: string
+  textModel?: string
+  audioModel?: string
+}
+
+// ============================================================================
+// 双槽位状态（模块级全局，跨组件共享）
+// ============================================================================
+
+const [imageKeyId, setImageKeyId] = createSignal<string | null>(null)
+const [chatKeyId, setChatKeyId] = createSignal<string | null>(null)
+
+export const canvasImageKeyId = imageKeyId
+export const canvasChatKeyId = chatKeyId
+
+// 点「启动作图」：切到该 key（再点同一个则取消，作图槽清空）。
+export function toggleCanvasImageKey(id: string) {
+  setImageKeyId((prev) => (prev === id ? null : id))
+}
+
+// 点「启动作图对话」：切到该 key（再点同一个则取消，对话槽清空）。
+export function toggleCanvasChatKey(id: string) {
+  setChatKeyId((prev) => (prev === id ? null : id))
+}
+
+// 是否已选中任一槽位（决定「画布」入口是否可直接进入并投递有效渠道）。
+export function hasAnyCanvasSlot(): boolean {
+  return imageKeyId() !== null || chatKeyId() !== null
+}
+
+// ============================================================================
+// payload 合成（纯函数）
+// ============================================================================
+
+// [dokng] 关键字兜底判定：宿主拿到的 new-api 模型名多为自定义名，无 capability 元数据。
+// 与画布 guessCapability 同源关键字，但在宿主侧显式判定后随 payload 下发，避免画布再猜一次。
+const VIDEO_KEYWORDS = ["seedance", "video", "sora", "veo", "kling", "wan", "hailuo"]
+const AUDIO_KEYWORDS = ["audio", "tts", "speech", "voice", "music", "sound"]
+const IMAGE_KEYWORDS = [
+  "seedream",
+  "gpt-image",
+  "image",
+  "dall-e",
+  "dalle",
+  "imagen",
+  "flux",
+  "sdxl",
+  "stable-diffusion",
+  "midjourney",
+]
+
+function guessCapability(name: string): CanvasModelCapability {
+  const value = name.toLowerCase()
+  if (VIDEO_KEYWORDS.some((k) => value.includes(k))) return "video"
+  if (AUDIO_KEYWORDS.some((k) => value.includes(k))) return "audio"
+  if (IMAGE_KEYWORDS.some((k) => value.includes(k))) return "image"
+  return "text"
+}
+
+// [dokng] 一个 key 的模型名列表 → 带 capability 的模型数组。
+// 作图槽的 key：只保留 image/video 类模型；对话槽的 key：只保留 text 类模型；
+// audio 归入对话槽（画布把 audio 作为文本类对话的语音扩展）。
+// 若过滤后为空（该 key 没有对应类型的模型），回退全量按各自 capability 下发，避免画布无模型可选。
+function modelsForSlot(models: string[], slot: "image" | "chat"): CanvasInjectedModel[] {
+  const all = models.map((name) => ({ name, capability: guessCapability(name) }))
+  const wanted: CanvasModelCapability[] = slot === "image" ? ["image", "video"] : ["text", "audio"]
+  const filtered = all.filter((m) => wanted.includes(m.capability))
+  return filtered.length > 0 ? filtered : all
+}
+
+// [dokng] 由两槽位 + 已解析 key 列表合成投递 payload。核心规则：
+//   - 每个被选中的 key → 一个画布 channel（baseUrl + apiKey + 该 key 按槽位过滤的 models）。
+//   - 两槽同一个 key：合并成一个 channel，models 取该 key 的 image/video/text/audio 全类。
+//   - 两槽不同 key：两个 channel，各自只带对应类型模型。
+//   - 都没选：channels 为空（画布保持自身默认，不被覆盖）。
+// 同时给出各类默认模型选择（channelId::modelName），让画布切到刚接入的渠道模型。
+export function buildCanvasPayload(keys: ResolvedKey[], imgId: string | null, chatId: string | null): CanvasConfigPayload {
+  const byId = new Map(keys.map((k) => [k.id, k]))
+  const imgKey = imgId ? byId.get(imgId) : undefined
+  const chatKey = chatId ? byId.get(chatId) : undefined
+
+  const channels: CanvasInjectedChannel[] = []
+  const encode = (channelId: string, models: CanvasInjectedModel[], cap: CanvasModelCapability): string | undefined => {
+    const hit = models.find((m) => m.capability === cap)
+    return hit ? `${channelId}::${hit.name}` : undefined
+  }
+
+  let imageModel: string | undefined
+  let videoModel: string | undefined
+  let textModel: string | undefined
+  let audioModel: string | undefined
+
+  const channelName = (k: ResolvedKey) => k.label.trim() || "客户端渠道"
+
+  if (imgKey && chatKey && imgKey.id === chatKey.id) {
+    // 同一 key 两槽：一个 channel 供全类模型。
+    const models: CanvasInjectedModel[] = imgKey.models.map((name) => ({ name, capability: guessCapability(name) }))
+    channels.push({ id: imgKey.id, name: channelName(imgKey), baseUrl: imgKey.baseURL, apiKey: imgKey.key, models })
+    imageModel = encode(imgKey.id, models, "image")
+    videoModel = encode(imgKey.id, models, "video")
+    textModel = encode(imgKey.id, models, "text")
+    audioModel = encode(imgKey.id, models, "audio")
+  } else {
+    if (imgKey) {
+      const models = modelsForSlot(imgKey.models, "image")
+      channels.push({ id: imgKey.id, name: channelName(imgKey), baseUrl: imgKey.baseURL, apiKey: imgKey.key, models })
+      imageModel = encode(imgKey.id, models, "image")
+      videoModel = encode(imgKey.id, models, "video")
+    }
+    if (chatKey) {
+      const models = modelsForSlot(chatKey.models, "chat")
+      channels.push({ id: chatKey.id, name: channelName(chatKey), baseUrl: chatKey.baseURL, apiKey: chatKey.key, models })
+      textModel = encode(chatKey.id, models, "text")
+      audioModel = encode(chatKey.id, models, "audio")
+    }
+  }
+
+  return { type: "dokng:canvas-config", channels, imageModel, videoModel, textModel, audioModel }
+}
diff --git a/packages/app/src/pages/canvas-embed.tsx b/packages/app/src/pages/canvas-embed.tsx
new file mode 100644
index 000000000..1054105af
--- /dev/null
+++ b/packages/app/src/pages/canvas-embed.tsx
@@ -0,0 +1,167 @@
+// [dokng] 画布内嵌宿主（待办 4 + 页面保活）。
+//
+// infinite-canvas（React 19 SPA）与宿主（SolidJS）框架异构，不能当组件嵌，只能 <iframe> 隔离。
+// 画布产物构建期以 VITE_BASE=/canvas/ 打包、拷进 desktop 的 out/renderer/canvas/，经 oc:// 特权协议
+// （已白名单整个 out/renderer 子树）以 oc://renderer/canvas/index.html 加载，主进程/preload/协议零改。
+//
+// —— 页面保活（keep-alive）——
+// 本组件不再作为 /canvas 路由页渲染（那样切走即卸载、iframe 重建、画布内容与状态全丢）。
+// 改为常驻挂载在 NewLayout（跨路由不卸载的 router root 外壳，见 app.tsx 注释）里，用 fixed 全屏
+// 覆盖层承载：靠 useLocation() 判断是否在 /canvas，只切 display 显隐、绝不卸载 iframe。
+// 首次进入 /canvas 才创建 iframe（懒挂载：没进过画布就不加载画布资源）；之后 iframe 常驻内存，
+// 从画布切到别的页面再切回来，画布内容 / 缩放 / 选中态 / 未保存编辑全部原样保留。
+//
+// 本组件职责：
+//   1. 渲染全屏 <iframe src="oc://renderer/canvas/index.html">（fixed inset-0，盖住原生 titlebar）。
+//   2. 把账户面板选中的 key（双槽位 imageKeyId/chatKeyId）合成 channel 数组，postMessage 投给画布。
+//      投递时机：① 画布发来 dokng:canvas-ready 握手回执后立即投；② 槽位变化时重投（createEffect）。
+//   3. targetOrigin 严格限 oc://renderer，杜绝把 key 投给非宿主 origin。
+//
+// 全部仅 desktop 生效（key 来自 desktop preload 的 window.api）；非 desktop 时进入 /canvas 显示占位提示。
+
+import { createEffect, createMemo, createSignal, onCleanup, onMount, Show } from "solid-js"
+import { useLocation, useNavigate } from "@solidjs/router"
+import { Icon } from "@opencode-ai/ui/icon"
+import { IconButtonV2 } from "@opencode-ai/ui/v2/icon-button-v2"
+import { TooltipV2 } from "@opencode-ai/ui/v2/tooltip-v2"
+import { usePlatform } from "@/context/platform"
+import { loadChannelState, resolveKeyList, type ResolvedKey } from "@/components/cx-account/cx-account-api"
+import { buildCanvasPayload, canvasChatKeyId, canvasImageKeyId } from "@/components/cx-account/cx-canvas-slots"
+
+// 画布产物在 oc://renderer/canvas/ 下的入口；协议层已白名单 out/renderer 全子树。
+const CANVAS_SRC = "oc://renderer/canvas/index.html"
+// 画布 iframe 的 origin（oc 协议 + host=renderer）；postMessage 双向都严格用它，不用 "*"。
+const CANVAS_ORIGIN = "oc://renderer"
+// 画布路由路径：常驻宿主靠它切显隐。
+const CANVAS_PATH = "/canvas"
+
+export default function CanvasHost() {
+  const platform = usePlatform()
+  const navigate = useNavigate()
+  const location = useLocation()
+
+  // 是否处于画布路由（决定覆盖层显隐）。
+  const isCanvas = createMemo(() => location.pathname === CANVAS_PATH)
+
+  // 懒挂载：首次进入 /canvas 才创建 iframe；一旦创建就常驻（保活的关键——之后只切显隐不卸载）。
+  const [mounted, setMounted] = createSignal(false)
+  createEffect(() => {
+    if (isCanvas()) setMounted(true)
+  })
+
+  // 返回：优先浏览器历史回退（保留来源上下文），无历史时兜底回根路由。
+  // 保活下导航走后 iframe 只是 display:none、不卸载，画布状态全留。
+  const goBack = () => {
+    if (window.history.length > 1) navigate(-1)
+    else navigate("/")
+  }
+
+  // 非 desktop：画布依赖 desktop 侧渠道 key。仅在进入 /canvas 时显示占位，其余时候不渲染任何东西。
+  if (platform.platform !== "desktop") {
+    return (
+      <Show when={isCanvas()}>
+        <div class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-3 bg-v2-background-bg-deep text-v2-text-text-muted">
+          <span>画布仅在桌面客户端可用。</span>
+          <IconButtonV2
+            type="button"
+            variant="neutral"
+            size="small"
+            icon={<Icon name="arrow-left" size="small" />}
+            onClick={goBack}
+            aria-label="返回"
+          />
+        </div>
+      </Show>
+    )
+  }
+
+  let iframeRef: HTMLIFrameElement | undefined
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  const [ready, setReady] = createSignal(false)
+
+  // 向画布 iframe 投递当前槽位合成的渠道配置。画布未 ready 时不投（等握手），避免早投丢失。
+  const post = () => {
+    const win = iframeRef?.contentWindow
+    if (!win || !ready()) return
+    const payload = buildCanvasPayload(keys(), canvasImageKeyId(), canvasChatKeyId())
+    win.postMessage(payload, CANVAS_ORIGIN)
+  }
+
+  onMount(() => {
+    // 加载本地 key 列表（供合成 payload）。异步、失败返回空列表，不抛出。
+    void loadChannelState().then((state) => setKeys(resolveKeyList(state)))
+
+    // 画布就绪握手：收到 dokng:canvas-ready 才认为可投递（画布 listener 已挂好）。
+    const onMessage = (event: MessageEvent) => {
+      if (event.origin !== CANVAS_ORIGIN) return
+      const data = event.data as { type?: unknown } | null
+      if (!data || typeof data !== "object") return
+      if (data.type === "dokng:canvas-ready") {
+        setReady(true)
+        post()
+      }
+    }
+    window.addEventListener("message", onMessage)
+    onCleanup(() => window.removeEventListener("message", onMessage))
+  })
+
+  // 槽位变化或 key 列表加载完成后重投（画布已 ready 时才实际发送）。
+  createEffect(() => {
+    // 显式订阅这三个信号，任一变化触发重投。
+    void canvasImageKeyId()
+    void canvasChatKeyId()
+    void keys()
+    void ready()
+    post()
+  })
+
+  const isMac = platform.os === "macos"
+
+  // 常驻覆盖层：mounted 前不渲染 iframe（省资源）；mounted 后常驻，靠 isCanvas 切 display。
+  // 用 fixed inset-0 全屏覆盖整个窗口（盖住原生 titlebar），与保活前 /canvas 的观感一致。
+  return (
+    <Show when={mounted()}>
+      <div
+        class="fixed inset-0 z-50 flex flex-col bg-v2-background-bg-deep"
+        style={{ display: isCanvas() ? undefined : "none" }}
+        aria-hidden={isCanvas() ? undefined : "true"}
+      >
+        {/* 顶部精简栏：画布覆盖层盖住了原生 titlebar，此处补一条——
+            ① 窗口拖拽区（[app-region:drag]：Electron 无边框窗口靠 CSS app-region 拖窗）；
+            ② 容纳返回入口（进得去也出得来）；
+            ③ macOS 左侧留出红绿灯宽度（84px），避免返回按钮压住原生红绿灯。
+            返回按钮与提示标 [app-region:no-drag]，保证可点击不被拖拽区吞掉事件。 */}
+        <div
+          class="shrink-0 flex items-center gap-2 h-9 px-2 bg-v2-background-bg-deep border-b border-v2-border-border-muted [app-region:drag]"
+          style={{ "padding-left": isMac ? "84px" : undefined }}
+        >
+          <TooltipV2 placement="bottom" value="返回">
+            <IconButtonV2
+              type="button"
+              variant="ghost-muted"
+              size="small"
+              class="[app-region:no-drag]"
+              icon={<Icon name="arrow-left" size="small" />}
+              onClick={goBack}
+              aria-label="返回"
+            />
+          </TooltipV2>
+          <span class="select-none text-v2-text-text-muted text-sm">画布</span>
+          <Show when={keys().length === 0}>
+            <span class="ml-auto truncate pr-1 text-v2-text-text-faint text-xs [app-region:no-drag]">
+              未选择渠道，使用画布默认配置
+            </span>
+          </Show>
+        </div>
+        <iframe
+          ref={iframeRef}
+          src={CANVAS_SRC}
+          title="画布"
+          class="flex-1 min-h-0 min-w-0 w-full border-0"
+          // 沙箱：允许脚本 / 同源（IndexedDB 持久化画布数据）/ 弹窗 / 下载（导出图片）。
+          sandbox="allow-scripts allow-same-origin allow-popups allow-downloads allow-forms"
+        />
+      </div>
+    </Show>
+  )
+}
