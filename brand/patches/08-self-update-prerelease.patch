diff --git a/packages/desktop/scripts/finalize-latest-yml.ts b/packages/desktop/scripts/finalize-latest-yml.ts
index aa2ae5c96e..45bd56acc3 100644
--- a/packages/desktop/scripts/finalize-latest-yml.ts
+++ b/packages/desktop/scripts/finalize-latest-yml.ts
@@ -61,7 +61,13 @@ function parse(content: string): LatestYml {
 function serialize(data: LatestYml) {
   const lines = [`version: ${data.version}`, "files:"]
   for (const file of data.files) {
-    lines.push(`  - url: ${file.url}`)
+    // [dokng] 安装包在 R2 上下沉到 open-code/<version>/ 子目录（与 cc-switch 同构）。
+    // electron-updater 的 GenericProvider 用 new URL(file.url, updateBaseUrl) 解析产物地址，
+    // baseUrl = updateBaseUrl（补 / 结尾）= https://dl.dokng.com/open-code/，元数据 latest*.yml
+    // 仍留在该根、固定 URL 轮询。故此处 url 必须带 <version>/ 前缀，updater 才能拼到子目录里的
+    // 安装包；.blockmap 由 updater 按 url 同目录推导，无需在 yml 里显式列出。
+    // version 已由调用方剥掉 v 前缀（OPENCODE_VERSION#v），形如 1.17.15-dokng.3。
+    lines.push(`  - url: ${version}/${file.url}`)
     lines.push(`    sha512: ${file.sha512}`)
     lines.push(`    size: ${file.size}`)
     if (file.blockMapSize) lines.push(`    blockMapSize: ${file.blockMapSize}`)
