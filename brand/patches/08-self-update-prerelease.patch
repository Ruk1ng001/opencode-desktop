# 08-self-update-prerelease —— 放行 prerelease（allowPrerelease=true）
#
# 职责：把 updater.ts 的 autoUpdater.allowPrerelease 从 false 改为 true。
#
# 现状说明（重要）：
#   dokng 版本号是 <opencode版本>-dokng.N，semver 里 -dokng.N 属 prerelease 记法。
#   本开关只对 electron-updater 的 GitHubProvider 有意义（GitHub 把带 - 后缀的 release 判为
#   pre-release、排除在 /releases/latest 之外，需放行 prerelease 才能选中）。
#   但当前默认更新源是 GenericProvider（R2，见 brand/electron-builder.brand.ts 的 updateBaseUrl /
#   useR2）——它直接拉 latest*.yml 按 semver 比对、完全忽略 allowPrerelease。因此本补丁在现网
#   属「无害冗余」死代码；保留它是为将来若切回/回退到 GitHub 源时，仍能正确选中 -dokng.N 版本。
#
# 配套（非本补丁，在父仓库）：
#   - brand/electron-builder.brand.ts：publish 源 = generic(R2 dl.dokng.com) + github(Ruk1ng001/
#     opencode-desktop)；mac target 含 zip（macOS 自更新载体，dmg 不能用于更新）。运行时 app-update.yml
#     只写 publish[0]（generic/R2），GitHub 项不做自动 fallback（electron-updater 原生不支持数组回退）。
#   - .github/workflows/release.yml：build 前注入 dokng 版本号到 package.json（否则产物恒为上游版本、
#     自更新永远「已是最新」）；上传 latest*.yml 并合并 mac 双架构（finalize-latest-yml.ts）。
#   - macOS 自更新前提是代码签名 + 公证；release.yml 现硬编码 CX_UNSIGNED=1 出未签名包，Squirrel.Mac
#     + Gatekeeper 会拦下 mac 自更新（Win/Linux 不受影响）。这属签名/证书配置，非本补丁可修。
#
# 依赖：独立文件（updater.ts），不与 01-07 共享，按 NN 序在最后应用即可。
# 应用（在 opencode/ 内，基线为 brand/BASE_SHA）：
#   git -C opencode apply brand/patches/08-self-update-prerelease.patch
diff --git a/packages/desktop/src/main/updater.ts b/packages/desktop/src/main/updater.ts
index cd483ed72..d4d9e21af 100644
--- a/packages/desktop/src/main/updater.ts
+++ b/packages/desktop/src/main/updater.ts
@@ -13,7 +13,11 @@ export function setupAutoUpdater(stop: () => Promise<void>) {
   const logger = getLogger()
   autoUpdater.logger = logger
   autoUpdater.channel = "latest"
-  autoUpdater.allowPrerelease = false
+  // [dokng] dokng 版本号是 <opencode版本>-dokng.N（semver 里 -dokng.N 属 prerelease）。放行 prerelease
+  // 仅对 GitHubProvider 生效（用于 /releases/latest 会排除带 - 后缀 release 的场景）。当前默认走
+  // GenericProvider（R2，见 brand/electron-builder.brand.ts），它按 latest*.yml 比 semver、忽略此开关，
+  // 故此行在现网属无害冗余；保留是为将来若切回 GitHub 源作 fallback 时仍能选中 -dokng.N 版本。
+  autoUpdater.allowPrerelease = true
   autoUpdater.allowDowngrade = true
   autoUpdater.autoDownload = false
   autoUpdater.autoInstallOnAppQuit = false
