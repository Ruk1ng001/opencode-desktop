+// [cx] US-003/US-008: 内置渠道「默认注入」。渠道值在构建期由 electron.vite 的 main.define
+// 内联进 import.meta.env（主进程运行时读不到 process.env 里的这些值）。三者齐备时构造一份
+// opencode config，经 OPENCODE_CONFIG_CONTENT 传给内核 sidecar。该变量在内核 config 合并链里
+// 排在全局 / 项目配置之后，故注入的 newapi provider 与默认 model 会覆盖用户同名配置，实现
+// 开箱即走内置渠道；值缺失（如 dev）则不注入，退回原生行为。结构对齐 brand/opencode.template.json。
+function buildChannelConfigContent(): string | undefined {
+  const baseURL = import.meta.env.NEWAPI_BASE_URL
+  const apiKey = import.meta.env.NEWAPI_API_KEY
+  const model = import.meta.env.NEWAPI_MODEL
+  if (!baseURL || !apiKey || !model) return undefined
+  return JSON.stringify({
+    $schema: "https://opencode.ai/config.json",
+    model: `newapi/${model}`,
+    provider: {
+      newapi: {
+        npm: "@ai-sdk/openai-compatible",
+        name: "内置渠道",
+        options: { baseURL, apiKey },
+        models: { [model]: { name: "内置模型" } },
+      },
+    },
+  })
+}
+
 function createSidecarEnv(): Record<string, string> {
   const env = Object.fromEntries(
     Object.entries(process.env).flatMap(([key, value]) => (value === undefined ? [] : [[key, String(value)]])),
@@ -214,6 +238,9 @@ function createSidecarEnv(): Record<string, string> {
   delete env.DEBUG
   if (process.platform === "linux") delete env.LD_PRELOAD
   if (!app.isPackaged) env.OPENCODE_DISABLE_CHANNEL_DB = "1"
+  // [cx] 默认注入内置渠道（仅当构建期内联了完整渠道值时生效）。
+  const channelConfig = buildChannelConfigContent()
+  if (channelConfig) env.OPENCODE_CONFIG_CONTENT = channelConfig
   return env
 }
 
