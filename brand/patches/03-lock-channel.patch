+// [cx] US-003/US-004/US-008: 内置渠道「默认注入」。三者齐备时构造一份 opencode config，
+// 经 OPENCODE_CONFIG_CONTENT 传给内核 sidecar。该变量在内核 config 合并链里排在全局 / 项目
+// 配置之后，故注入的 newapi provider 与默认 model 会覆盖用户同名配置，实现开箱即走内置渠道；
+// 值缺失（如 dev、且无本地激活 key）则不注入，退回原生行为。结构对齐 brand/opencode.template.json。
+//
+// [cx] US-004 token 来源改造 —— 数据流说明：
+//   baseURL / apiKey 优先来自「本地激活 key」（US-003 的 store-channel-keys）。该存储是主进程侧
+//   的 electron-store（opencode.settings，JSON 明文，仅本地），server.ts 与 store-channel-keys.ts
+//   同在主进程，故此处直接 readActiveChannelKey() 同步读取，无需经 IPC / renderer 中转（renderer
+//   若要改激活项，也是经 IPC 落到同一个 store，主进程下次 spawn sidecar 时即读到新值）。
+//   本地无激活 key 时回退到构建期内联的内置默认值（import.meta.env.NEWAPI_*，见 electron.vite
+//   main.define）；两者都无则整体缺失、不注入。
+//   注意：内核 config 是启动期一次性注入（US-002 结论），切换激活 key 后须重启 sidecar 才生效。
+//
+// [cx] US-009 可选模型注入 —— 模型列表来源：
+//   优先取激活 key 缓存的 models（切换激活 key 时拉该 key 的 /v1/models 落盘，见 store-channel-keys
+//   的 setChannelKeyModels）；该 key 尚无缓存时回退构建期内置 NEWAPI_MODEL 合成单条。列出的每个
+//   模型都写进 provider.newapi.models，成为内核里「该 key 的可选模型」；默认 model 取 NEWAPI_MODEL
+//   （若在列表内）否则列表首项。重建 config 后须重启 sidecar 才让新模型集合生效。
+function buildChannelConfigContent(): string | undefined {
+  const activeKey = readActiveChannelKey()
+  const baseURL = activeKey?.baseURL || import.meta.env.NEWAPI_BASE_URL
+  const apiKey = activeKey?.key || import.meta.env.NEWAPI_API_KEY
+  if (!baseURL || !apiKey) return undefined
+
+  // 可选模型集合：激活 key 缓存的 models 优先；无缓存回退构建期内置默认单条。
+  const builtinModel = import.meta.env.NEWAPI_MODEL
+  const cached = activeKey?.models?.filter((m) => typeof m === "string" && m.length > 0) ?? []
+  const modelList = cached.length > 0 ? cached : builtinModel ? [builtinModel] : []
+  if (modelList.length === 0) return undefined
+
+  // 默认模型：内置默认在列表内则用它，否则用列表首项。
+  const defaultModel = builtinModel && modelList.includes(builtinModel) ? builtinModel : modelList[0]
+  const models = Object.fromEntries(modelList.map((id) => [id, { name: id }]))
+
+  return JSON.stringify({
+    $schema: "https://opencode.ai/config.json",
+    model: `newapi/${defaultModel}`,
+    provider: {
+      newapi: {
+        npm: "@ai-sdk/openai-compatible",
+        name: "内置渠道",
+        options: { baseURL, apiKey },
+        models,
+      },
+    },
+  })
+}
+
 function createSidecarEnv(): Record<string, string> {
   const env = Object.fromEntries(
     Object.entries(process.env).flatMap(([key, value]) => (value === undefined ? [] : [[key, String(value)]])),
@@ -214,6 +264,9 @@ function createSidecarEnv(): Record<string, string> {
   delete env.DEBUG
   if (process.platform === "linux") delete env.LD_PRELOAD
   if (!app.isPackaged) env.OPENCODE_DISABLE_CHANNEL_DB = "1"
+  // [cx] 默认注入内置渠道（仅当构建期内联了完整渠道值时生效）。
+  const channelConfig = buildChannelConfigContent()
+  if (channelConfig) env.OPENCODE_CONFIG_CONTENT = channelConfig
   return env
 }
 
