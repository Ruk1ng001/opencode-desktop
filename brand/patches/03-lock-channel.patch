+// [cx] 多 provider 内置渠道 —— 构造 opencode config 对象（写入 OPENCODE_CONFIG 指向的文件）。
+//   把「每个本地 key」构造成一个**独立 provider**（providerID = channelProviderId(key.id)），
+//   内核启动/重建时读该文件，同时握着所有 key 的 provider；原生 model 选择器能列出每个 key
+//   及其模型。在已注册 key 之间切换是纯前端（model.set），零打断；增删 key 改变 provider 集合，
+//   由主进程重写文件 + POST /global/dispose 热重载生效（不重启进程）。
+//
+//   provider 来源优先级：
+//     1. 本地 stored keys（store-channel-keys）——每个 key 一个 provider；
+//     2. 无任何 key 时回退构建期内置默认单 provider（import.meta.env.NEWAPI_*），保证首启开箱即用；
+//     3. 两者都无 → 返回 undefined（不写文件、不设 OPENCODE_CONFIG，退回 opencode 原生行为）。
+//
+//   每个 provider 的模型：优先用该 key 缓存的 models（增删/切换时主进程拉 /v1/models 落盘）；
+//   无缓存回退构建期 NEWAPI_MODEL 合成单条；再无则跳过该 key。顶层默认 model 指向激活 key。
+function buildChannelConfig(): Record<string, unknown> | undefined {
+  const state = readChannelKeysState()
+  const builtinModel = import.meta.env.NEWAPI_MODEL
+
+  // 把单个 key 构造成一个 provider 条目。models 为空则跳过该 key（无法确定可选模型）。
+  // 返回 { id, providerId, defaultModel, entry } 或 null。
+  function buildProvider(key: { id: string; label: string; key: string; baseURL: string; models?: string[] }) {
+    const baseURL = key.baseURL || import.meta.env.NEWAPI_BASE_URL
+    const apiKey = key.key || import.meta.env.NEWAPI_API_KEY
+    if (!baseURL || !apiKey) return null
+
+    const cached = key.models?.filter((m) => typeof m === "string" && m.length > 0) ?? []
+    const modelList = cached.length > 0 ? cached : builtinModel ? [builtinModel] : []
+    if (modelList.length === 0) return null
+
+    const defaultModel = builtinModel && modelList.includes(builtinModel) ? builtinModel : modelList[0]
+    const models = Object.fromEntries(modelList.map((id) => [id, { name: id }]))
+    const providerId = channelProviderId(key.id)
+    return {
+      providerId,
+      defaultModel,
+      entry: {
+        npm: "@ai-sdk/openai-compatible",
+        // provider 显示名 = label + 短 id 后缀（与 renderer 侧一致，见 channelProviderId）。
+        name: `${key.label || "内置渠道"} (${key.id.slice(0, 8)})`,
+        options: { baseURL, apiKey },
+        models,
+      },
+    }
+  }
+
+  const provider: Record<string, unknown> = {}
+  let topModel: string | undefined
+
+  if (state.keys.length > 0) {
+    // 有本地 key：每个 key 注入成独立 provider。
+    for (const key of state.keys) {
+      const built = buildProvider(key)
+      if (!built) continue
+      provider[built.providerId] = built.entry
+      // 顶层默认 model 指向激活 key（无激活项时用首个成功构造的 provider）。
+      const isActive = key.id === state.activeKeyId
+      if (isActive || !topModel) topModel = `${built.providerId}/${built.defaultModel}`
+    }
+  } else {
+    // 无本地 key：回退构建期内置默认单 provider（首启开箱即用）。
+    const baseURL = import.meta.env.NEWAPI_BASE_URL
+    const apiKey = import.meta.env.NEWAPI_API_KEY
+    if (baseURL && apiKey && builtinModel) {
+      provider["newapi"] = {
+        npm: "@ai-sdk/openai-compatible",
+        name: "内置渠道",
+        options: { baseURL, apiKey },
+        models: { [builtinModel]: { name: builtinModel } },
+      }
+      topModel = `newapi/${builtinModel}`
+    }
+  }
+
+  if (Object.keys(provider).length === 0 || !topModel) return undefined
+
+  return {
+    $schema: "https://opencode.ai/config.json",
+    model: topModel,
+    provider,
+  }
+}
+
+// [cx] 把内置渠道 config 写入 OPENCODE_CONFIG 文件（整份覆盖，删除的 key 天然消失）。
+// 返回 true = 写了有效配置；false = 无可用渠道值（此时不应设 OPENCODE_CONFIG）。
+// spawn 前调用即完成首启注入（内核第一次读文件就位，无 HTTP、无时序竞争）。
+function writeChannelConfigFile(): boolean {
+  const config = buildChannelConfig()
+  const path = getChannelConfigPath()
+  try {
+    mkdirSync(dirname(path), { recursive: true })
+    if (!config) {
+      // 无可用渠道：写一个空对象，保证文件存在（OPENCODE_CONFIG 指向的文件缺失时内核会忽略）。
+      writeFileSync(path, "{}", "utf8")
+      return false
+    }
+    writeFileSync(path, JSON.stringify(config, null, 2), "utf8")
+    return true
+  } catch (error) {
+    getLogger().error("写入内置渠道配置文件失败", { error: String(error) })
+    return false
+  }
+}
+
+// [cx] 由渠道 baseURL 推导 OpenAI 兼容 /v1/models 端点（与 renderer 侧 deriveModelsUrl 同规则）。
+function deriveModelsUrl(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return /\/v1$/.test(trimmed) ? `${trimmed}/models` : `${trimmed}/v1/models`
+}
+
+// [cx] 主进程侧拉取某 key 的可用模型（无 CORS 限制，比 renderer fetch 更稳）。失败返回空数组。
+// baseURL 缺省回退构建期内置默认（NEWAPI_BASE_URL）。不打印 key 明文。
+async function fetchModelIds(baseURL: string, apiKey: string): Promise<string[]> {
+  const base = baseURL || import.meta.env.NEWAPI_BASE_URL
+  if (!base || !apiKey) return []
+  try {
+    const res = await fetch(deriveModelsUrl(base), {
+      headers: { authorization: `Bearer ${apiKey}`, accept: "application/json" },
+      signal: AbortSignal.timeout(10_000),
+    })
+    if (!res.ok) return []
+    const body = (await res.json()) as { data?: unknown } | unknown[]
+    const list = Array.isArray(body) ? body : Array.isArray((body as { data?: unknown }).data) ? (body as { data: unknown[] }).data : []
+    const ids = list
+      .map((m) => (typeof m === "string" ? m : m && typeof m === "object" ? (m as { id?: unknown }).id : undefined))
+      .filter((id): id is string => typeof id === "string" && id.length > 0)
+    return Array.from(new Set(ids))
+  } catch {
+    return []
+  }
+}
+
+// [cx] 拉取指定 key 的 /v1/models 并落盘，然后热重载。新增 key 时调用（renderer 经 IPC 触发）：
+// 主进程拉模型 → setChannelKeyModels → 重写文件 + dispose，使该 key 成为可用 provider——不重启。
+export async function refreshKeyModelsAndReload(id: string): Promise<void> {
+  const state = readChannelKeysState()
+  const key = state.keys.find((k) => k.id === id)
+  if (key) {
+    const models = await fetchModelIds(key.baseURL, key.key)
+    if (models.length > 0) setChannelKeyModels(id, models)
+  }
+  await reloadChannelConfig()
+}
+
+// [cx] 热重载内置渠道：重写 OPENCODE_CONFIG 文件 + POST /global/dispose 让内核重建 instance
+// 读到新配置——不重启进程。增删 key / 更新模型后由 IPC 调用。dispose 会中断进行中的流式生成
+// （partial 存为 interrupted，同原生加/连 provider 行为），故调用方应在会话空闲时触发。
+export async function reloadChannelConfig(): Promise<void> {
+  writeChannelConfigFile()
+  if (!sidecarUrl) return
+  let disposeUrl: URL
+  try {
+    disposeUrl = new URL("/global/dispose", sidecarUrl)
+  } catch {
+    return
+  }
+  const headers = new Headers({ "content-type": "application/json" })
+  if (sidecarPassword) {
+    headers.set("authorization", `Basic ${Buffer.from(`opencode:${sidecarPassword}`).toString("base64")}`)
+  }
+  try {
+    await fetch(disposeUrl, { method: "POST", headers, signal: AbortSignal.timeout(10_000) })
+  } catch (error) {
+    getLogger().error("触发内核热重载（dispose）失败", { error: String(error) })
+  }
+}
