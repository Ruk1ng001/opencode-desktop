+// [cx] US-003/US-004/US-008/多provider: 内置渠道「默认注入」。构造一份 opencode config，经
+// OPENCODE_CONFIG_CONTENT 传给内核 sidecar。该变量在内核 config 合并链里排在全局 / 项目配置
+// 之后，故注入的 provider 与默认 model 会覆盖用户同名配置，实现开箱即走内置渠道；无任何可用
+// 渠道值时不注入，退回原生行为。结构对齐 brand/opencode.template.json。
+//
+// [cx] 多 provider 改造 —— 核心数据流：
+//   把「每个本地 key」注入成一个**独立 provider**（providerID = channelProviderId(key.id)），
+//   而不再是「一个 newapi provider，内容随激活 key 变」。这样内核启动时就同时握着所有 key 的
+//   provider，opencode 原生 model 选择器能列出每个 key 及其可用模型；**在已注入的 key 之间切换
+//   是纯请求级行为（renderer 侧 model.set），无需重启 sidecar**。只有「新增 / 删除 key」改变了
+//   provider 集合，才需重启一次让新 provider 注册进内核。
+//
+//   provider 来源优先级：
+//     1. 本地 stored keys（store-channel-keys，主进程 electron-store，同进程同步读）——每个 key
+//        一个 provider；
+//     2. 本地无任何 key 时，回退到构建期内联的内置默认单 provider（import.meta.env.NEWAPI_*，见
+//        electron.vite main.define），保证首启（尚未导入 key）也能开箱即用；
+//     3. 两者都无 → 不注入，退回 opencode 原生行为（不破坏本地 dev）。
+//
+//   每个 provider 的可用模型：优先用该 key 缓存的 models（切换 / 导入时拉 /v1/models 落盘，见
+//   store-channel-keys.setChannelKeyModels）；无缓存时回退构建期内置 NEWAPI_MODEL 合成单条；再无
+//   则该 provider 不带具体模型（openai-compatible 允许运行时指定，但选择器会空——故尽量让 key 带
+//   models 缓存）。顶层默认 model 指向「激活 key 的 provider / 其默认模型」，保证开箱即用激活 key。
+function buildChannelConfigContent(): string | undefined {
+  const state = readChannelKeysState()
+  const builtinModel = import.meta.env.NEWAPI_MODEL
+
+  // 把单个 key 构造成一个 provider 条目。models 为空则跳过该 key（无法确定可选模型）。
+  // 返回 { id, providerId, defaultModel, entry } 或 null。
+  function buildProvider(key: { id: string; label: string; key: string; baseURL: string; models?: string[] }) {
+    const baseURL = key.baseURL || import.meta.env.NEWAPI_BASE_URL
+    const apiKey = key.key || import.meta.env.NEWAPI_API_KEY
+    if (!baseURL || !apiKey) return null
+
+    const cached = key.models?.filter((m) => typeof m === "string" && m.length > 0) ?? []
+    const modelList = cached.length > 0 ? cached : builtinModel ? [builtinModel] : []
+    if (modelList.length === 0) return null
+
+    const defaultModel = builtinModel && modelList.includes(builtinModel) ? builtinModel : modelList[0]
+    const models = Object.fromEntries(modelList.map((id) => [id, { name: id }]))
+    const providerId = channelProviderId(key.id)
+    return {
+      providerId,
+      defaultModel,
+      entry: {
+        npm: "@ai-sdk/openai-compatible",
+        // provider 显示名 = label + 短 id 后缀（与 renderer 侧一致，见 channelProviderId）。
+        name: `${key.label || "内置渠道"} (${key.id.slice(0, 8)})`,
+        options: { baseURL, apiKey },
+        models,
+      },
+    }
+  }
+
+  const provider: Record<string, unknown> = {}
+  let topModel: string | undefined
+
+  if (state.keys.length > 0) {
+    // 有本地 key：每个 key 注入成独立 provider。
+    for (const key of state.keys) {
+      const built = buildProvider(key)
+      if (!built) continue
+      provider[built.providerId] = built.entry
+      // 顶层默认 model 指向激活 key（无激活项时用首个成功构造的 provider）。
+      const isActive = key.id === state.activeKeyId
+      if (isActive || !topModel) topModel = `${built.providerId}/${built.defaultModel}`
+    }
+  } else {
+    // 无本地 key：回退构建期内置默认单 provider（首启开箱即用）。
+    const baseURL = import.meta.env.NEWAPI_BASE_URL
+    const apiKey = import.meta.env.NEWAPI_API_KEY
+    if (baseURL && apiKey && builtinModel) {
+      provider["newapi"] = {
+        npm: "@ai-sdk/openai-compatible",
+        name: "内置渠道",
+        options: { baseURL, apiKey },
+        models: { [builtinModel]: { name: builtinModel } },
+      }
+      topModel = `newapi/${builtinModel}`
+    }
+  }
+
+  if (Object.keys(provider).length === 0 || !topModel) return undefined
+
+  return JSON.stringify({
+    $schema: "https://opencode.ai/config.json",
+    model: topModel,
+    provider,
+  })
+}
+
 function createSidecarEnv(): Record<string, string> {
   const env = Object.fromEntries(
     Object.entries(process.env).flatMap(([key, value]) => (value === undefined ? [] : [[key, String(value)]])),
@@ -214,6 +306,9 @@ function createSidecarEnv(): Record<string, string> {
   delete env.DEBUG
   if (process.platform === "linux") delete env.LD_PRELOAD
   if (!app.isPackaged) env.OPENCODE_DISABLE_CHANNEL_DB = "1"
+  // [cx] 默认注入内置渠道（仅当构建期内联了完整渠道值时生效）。
+  const channelConfig = buildChannelConfigContent()
+  if (channelConfig) env.OPENCODE_CONFIG_CONTENT = channelConfig
   return env
 }
 
