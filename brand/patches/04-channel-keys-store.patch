@@ -0,0 +1,111 @@
+// [cx] US-003: 本地 key 列表存储模型 —— 多渠道 API Key 的持久化读写封装。
+//
+// 目的：让用户导入的多个 `sk-…` API Token 持久保存在本地，重启 App 后仍在，
+// 并可管理（新增 / 删除 / 更新 label / 设为激活 / 读取激活项）。
+//
+// 存储位置与格式：
+//   - 复用 opencode 既有的 electron-store（见 store.ts）。所有 key 数据写在
+//     默认 settings store（文件名 `opencode.settings`，无扩展名，JSON 明文），
+//     位于 electron `app.getPath("userData")` 目录下（各平台的用户数据目录，
+//     如 macOS 的 ~/Library/Application Support/<appId>）。
+//   - 在该 store 内以单个键 `channelKeys`（CHANNEL_KEYS_KEY）保存整个
+//     ChannelKeysState 对象：`{ keys: [{ id, label, key, baseURL }], activeKeyId }`。
+//
+// 安全底线（不可违背，见 TODO.md 第三节）：
+//   - key 明文**仅存本地用户设备**，绝不上传、绝不写日志。
+//   - 本模块所有函数都不打印 / 记录 key 值；调用方若需日志，只可记录 id / label，
+//     严禁把 `key` 字段带进日志或网络请求（调 AI 由内核 sidecar 经 config 注入完成）。
+
+import { randomUUID } from "node:crypto"
+import { getStore } from "./store"
+import { CHANNEL_KEYS_KEY } from "./store-keys"
+
+// 单个渠道 key 条目。`key` 为 new-api 的 API Token（`sk-…`），仅本地持有。
+export type ChannelKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+}
+
+// 本地存储的完整结构。activeKeyId 指向 keys 中当前激活项的 id；无激活项时为 null。
+export type ChannelKeysState = {
+  keys: ChannelKey[]
+  activeKeyId: string | null
+}
+
+const EMPTY_STATE: ChannelKeysState = { keys: [], activeKeyId: null }
+
+// 读取整份状态。store 里没有记录（首次启动）时返回空状态，不报错。
+export function readChannelKeysState(): ChannelKeysState {
+  const raw = getStore().get(CHANNEL_KEYS_KEY)
+  if (!raw || typeof raw !== "object") return { ...EMPTY_STATE }
+  const record = raw as Partial<ChannelKeysState>
+  const keys = Array.isArray(record.keys) ? record.keys.filter(isChannelKey) : []
+  const activeKeyId =
+    typeof record.activeKeyId === "string" && keys.some((item) => item.id === record.activeKeyId)
+      ? record.activeKeyId
+      : null
+  return { keys, activeKeyId }
+}
+
+// 读取当前激活的 key 条目。无 key 或无激活项时返回 null，不报错（验收标准）。
+export function readActiveChannelKey(): ChannelKey | null {
+  const state = readChannelKeysState()
+  if (!state.activeKeyId) return null
+  return state.keys.find((item) => item.id === state.activeKeyId) ?? null
+}
+
+// 新增一个 key。返回新建条目（含生成的 id）。若这是第一个 key，自动设为激活项。
+export function addChannelKey(input: { label: string; key: string; baseURL: string }): ChannelKey {
+  const state = readChannelKeysState()
+  const entry: ChannelKey = {
+    id: randomUUID(),
+    label: input.label,
+    key: input.key,
+    baseURL: input.baseURL,
+  }
+  const keys = [...state.keys, entry]
+  const activeKeyId = state.activeKeyId ?? entry.id
+  writeChannelKeysState({ keys, activeKeyId })
+  return entry
+}
+
+// 删除指定 id 的 key。若删的是当前激活项，激活项回退到列表首个剩余 key（无剩余则为 null）。
+export function removeChannelKey(id: string): void {
+  const state = readChannelKeysState()
+  const keys = state.keys.filter((item) => item.id !== id)
+  const activeKeyId =
+    state.activeKeyId === id ? (keys[0]?.id ?? null) : (keys.some((item) => item.id === state.activeKeyId) ? state.activeKeyId : null)
+  writeChannelKeysState({ keys, activeKeyId })
+}
+
+// 更新指定 id 的 key 的 label。id 不存在时静默忽略，不报错。
+export function updateChannelKeyLabel(id: string, label: string): void {
+  const state = readChannelKeysState()
+  const keys = state.keys.map((item) => (item.id === id ? { ...item, label } : item))
+  writeChannelKeysState({ keys, activeKeyId: state.activeKeyId })
+}
+
+// 设为激活项。id 不在列表中时静默忽略（不改变现有激活项），不报错。
+export function setActiveChannelKey(id: string): void {
+  const state = readChannelKeysState()
+  if (!state.keys.some((item) => item.id === id)) return
+  writeChannelKeysState({ keys: state.keys, activeKeyId: id })
+}
+
+// 落盘整份状态（内部使用）。
+function writeChannelKeysState(state: ChannelKeysState): void {
+  getStore().set(CHANNEL_KEYS_KEY, state)
+}
+
+function isChannelKey(value: unknown): value is ChannelKey {
+  if (!value || typeof value !== "object") return false
+  const record = value as Record<string, unknown>
+  return (
+    typeof record.id === "string" &&
+    typeof record.label === "string" &&
+    typeof record.key === "string" &&
+    typeof record.baseURL === "string"
+  )
+}
