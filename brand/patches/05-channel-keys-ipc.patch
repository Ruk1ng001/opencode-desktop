+// 安全底线：本文件对 key 管理 handler 一律不打印任何入参（尤其 sk- 明文），仅透传给数据层。
+import {
+  readChannelKeysState,
+  addChannelKey,
+  removeChannelKey,
+  updateChannelKeyLabel,
+  setActiveChannelKey,
+  setChannelKeyModels,
+} from "./store-channel-keys"
 import { getPinchZoomEnabled, getWindowID, setPinchZoomEnabled, setTitlebar, updateTitlebar } from "./windows"
 import type { UpdaterController } from "./updater-controller"
 import { createUpdaterSubscriptions } from "./updater-subscriptions"
@@ -112,6 +124,34 @@ export function registerIpcHandlers(deps: Deps) {
     return Object.keys(store.store).length
   })
 
+  // [cx] US-009: 本地 key 列表的增删改 + 切换激活。全部走主进程数据层（store-channel-keys）。
+  // 返回值统一为 JSON.stringify 后的最新 ChannelKeysState 字符串，renderer 解析回对象刷新 UI
+  // （与 store-get 对非字符串 JSON.stringify 的约定一致）。不打印任何入参（含 sk- 明文）。
+  ipcMain.handle("channel-keys-list", () => JSON.stringify(readChannelKeysState()))
+  ipcMain.handle(
+    "channel-keys-add",
+    (_event: IpcMainInvokeEvent, input: { label: string; key: string; baseURL: string }) => {
+      addChannelKey({ label: input.label ?? "", key: input.key ?? "", baseURL: input.baseURL ?? "" })
+      return JSON.stringify(readChannelKeysState())
+    },
+  )
+  ipcMain.handle("channel-keys-remove", (_event: IpcMainInvokeEvent, id: string) => {
+    removeChannelKey(id)
+    return JSON.stringify(readChannelKeysState())
+  })
+  ipcMain.handle("channel-keys-update-label", (_event: IpcMainInvokeEvent, id: string, label: string) => {
+    updateChannelKeyLabel(id, label ?? "")
+    return JSON.stringify(readChannelKeysState())
+  })
+  ipcMain.handle("channel-keys-set-active", (_event: IpcMainInvokeEvent, id: string) => {
+    setActiveChannelKey(id)
+    return JSON.stringify(readChannelKeysState())
+  })
+  ipcMain.handle("channel-keys-set-models", (_event: IpcMainInvokeEvent, id: string, models: string[]) => {
+    setChannelKeyModels(id, Array.isArray(models) ? models : [])
+    return JSON.stringify(readChannelKeysState())
+  })
+
