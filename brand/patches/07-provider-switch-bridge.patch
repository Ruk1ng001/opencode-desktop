+// [cx] 桥接组件：账户面板（BalanceLauncher，挂在 opencode 组件树之外，够不到 useLocal）
+// 通过 window CustomEvent `cx:select-provider` 请求切换到某个 key 对应的 provider/model；
+// 本组件挂在 LocalProvider 作用域内，收到事件后调用与原生 model 选择器同一个入口
+// useLocal().model.set(...)，把当前会话切到该 provider —— 纯请求级、零重启，效果同原生「闪一下」。
+// 复用仓库已有的 deep-link 事件桥同款模式（index.tsx 派发 / layout.tsx 监听）。
+// detail: { providerID: string; modelID: string }
+function CxProviderSwitchBridge() {
+  const local = useLocal()
+  const handler = (event: Event) => {
+    const detail = (event as CustomEvent).detail as { providerID?: unknown; modelID?: unknown } | undefined
+    if (!detail) return
+    const providerID = typeof detail.providerID === "string" ? detail.providerID : undefined
+    const modelID = typeof detail.modelID === "string" ? detail.modelID : undefined
+    if (!providerID || !modelID) return
+    local.model.set({ providerID, modelID }, { recent: true })
+  }
+  window.addEventListener("cx:select-provider", handler)
+  onCleanup(() => window.removeEventListener("cx:select-provider", handler))
+  return null
+}
