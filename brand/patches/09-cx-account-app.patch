+// [cx] 账户面板主体。经 useDialog().show(() => <CxDialogAccount/>) 弹出（接线在 07 的 layout.tsx）。
+// 用 v2 Dialog(size=large) 外壳组织账户摘要、token 统计与响应式 key 网格。
+export function CxDialogAccount() {
+  const [initializing, setInitializing] = createSignal(true)
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  const [profiles, setProfiles] = createSignal<Record<string, KeyProfileState>>({})
+  const [refreshingIds, setRefreshingIds] = createSignal<Set<string>>(new Set())
+  const [switchingId, setSwitchingId] = createSignal<string | null>(null)
+  const [addingKey, setAddingKey] = createSignal(false)
+  const [notice, setNotice] = createSignal("")
+  const requestVersions = new Map<string, number>()
+
+  const activeEntry = () => keys().find((k) => k.isActive) ?? keys()[0]
+  const activeProfile = (): KeyProfileState | undefined => {
+    const entry = activeEntry()
+    return entry ? profiles()[entry.id] : undefined
+  }
+  const accountProfile = (): Extract<KeyProfileState, { status: "ready" }> | undefined => {
+    const active = activeProfile()
+    if (active?.status === "ready") return active
+    return Object.values(profiles()).find(
+      (profile): profile is Extract<KeyProfileState, { status: "ready" }> => profile.status === "ready",
+    )
+  }
+  const tokenSummary = () => {
+    const ready = Object.values(profiles()).filter(
+      (profile): profile is Extract<KeyProfileState, { status: "ready" }> => profile.status === "ready",
+    )
+    return {
+      loaded: ready.length,
+      unlimited: ready.filter((profile) => profile.keyUnlimitedQuota).length,
+    }
+  }
+
+  const topupUrl = () => resolveTopupUrl(activeEntry()?.baseURL)
+  const siteUrl = () => resolveSiteUrl(activeEntry()?.baseURL)
+  const anyLoading = () => refreshingIds().size > 0
+
+  async function loadProfile(entry: ResolvedKey, options: { preserve?: boolean } = {}): Promise<void> {
+    const version = (requestVersions.get(entry.id) ?? 0) + 1
+    requestVersions.set(entry.id, version)
+    setRefreshingIds((prev) => new Set(prev).add(entry.id))
+    if (!options.preserve || !profiles()[entry.id]) {
+      setProfiles((prev) => ({ ...prev, [entry.id]: { status: "loading" } }))
+    }
+    const result = await fetchProfileWith(entry.baseURL, entry.key)
+    if (requestVersions.get(entry.id) !== version || !keys().some((item) => item.id === entry.id)) return
+    setProfiles((prev) => ({ ...prev, [entry.id]: result }))
+    setRefreshingIds((prev) => {
+      const next = new Set(prev)
+      next.delete(entry.id)
+      return next
+    })
+  }
+
+  function refreshAll(): void {
+    for (const entry of keys()) void loadProfile(entry, { preserve: true })
+  }
+
+  async function reloadKeys(options: { loadMissing?: boolean } = {}): Promise<ResolvedKey[]> {
+    const state = await loadChannelState()
+    const next = resolveKeyList(state)
+    const valid = new Set(next.map((entry) => entry.id))
+    setKeys(next)
+    setProfiles((prev) => Object.fromEntries(Object.entries(prev).filter(([id]) => valid.has(id))))
+    setInitializing(false)
+    if (options.loadMissing) {
+      for (const entry of next) {
+        if (!profiles()[entry.id]) void loadProfile(entry)
+      }
+    }
+    return next
+  }
+
+  onMount(() => {
+    void reloadKeys({ loadMissing: true })
+  })
+
+  // [cx] 新增 key —— 写入本地列表 → 主进程拉模型 + 热重载（provider 出现），不重启进程。
+  // [cx] 未填名称时：新增后用该 key 在 new-api 侧的 token 名称（/api/app/profile 的 token_name）
+  // 一次性回填本地 label（后续不再与远端同步）；取名失败 / 远端也没名字时保持「未命名 key」占位。
+  async function handleAdd(input: { label: string; key: string; baseURL: string }): Promise<void> {
+    setNotice("")
+    const addKey = cxChannelApi()?.channelKeysAdd
+    if (!addKey) throw new Error("当前环境无法保存 Key，请在桌面客户端中重试")
+
+    // channelKeysAdd 返回最新 ChannelKeysState 的 JSON，解析出新条目 id（按明文 key 反向匹配）。
+    let addedId: string | undefined
+    try {
+      const raw = await addKey(input)
+      const state = JSON.parse(raw) as { keys?: Array<{ id: string; key: string }> }
+      const list = Array.isArray(state.keys) ? state.keys : []
+      addedId = [...list].reverse().find((k) => k.key === input.key)?.id
+    } catch {
+      throw new Error("Key 保存失败，请检查桌面客户端状态后重试")
+    }
+    if (!addedId) throw new Error("未能确认新增的 Key，请重试")
+    const confirmedId = addedId
+
+    // [cx] 只同步本地 key 元数据，保留既有 profile 缓存（其它 key 不重拉）。
+    await reloadKeys()
+    setAddingKey(false)
+
+    // 本地写入成功后立即结束提交，让表单即时收起；远端名称、模型和 profile 在后台同步，
+    // 避免网络慢时用户点击「添加」长时间看不到反馈。
+    setNotice(`已添加 ${input.label.trim() || "新 Key"}，账户数据正在同步。`)
+    const entrySnapshot = keys().find((k) => k.id === confirmedId)
+    void (async () => {
+      if (!input.label.trim() && entrySnapshot) {
+        const remoteName = await fetchTokenName(entrySnapshot.baseURL, entrySnapshot.key)
+        if (remoteName) {
+          try {
+            await cxChannelApi()?.channelKeysUpdateLabel?.(confirmedId, remoteName)
+            await reloadKeys()
+          } catch {
+            // 回填失败不阻断：卡片仍显示「未命名 key」占位，可手动改名。
+          }
+        }
+      }
+
+      try {
+        await cxChannelApi()?.channelConfigRefreshKey?.(confirmedId)
+      } catch {
+        // 热重载失败不阻断；下次启动时文件配置仍会生效。
+      }
+      const refreshedEntry = keys().find((k) => k.id === confirmedId) ?? entrySnapshot
+      if (refreshedEntry) void loadProfile(refreshedEntry)
+    })()
+  }
+
+  // [cx] US-009: 保存 label —— 只更新本地列表，不重拉 profile（账户/token 数据未变）。
+  async function handleSaveLabel(id: string, label: string): Promise<void> {
+    try {
+      await cxChannelApi()?.channelKeysUpdateLabel?.(id, label)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    await reloadKeys()
+  }
+
+  // [cx] 删除 key（二次确认在卡片内完成）。删激活项时主进程侧激活回退首项/置空。
+  async function handleRemove(id: string): Promise<void> {
+    try {
+      await cxChannelApi()?.channelKeysRemove?.(id)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    // [cx] reloadKeys 已按存活 key 过滤 profile 缓存，无需额外清理。
+    await reloadKeys()
+    try {
+      await cxChannelApi()?.channelConfigReload?.()
+    } catch {
+      // 热重载失败不阻断；下次启动时文件配置仍会生效。
+    }
+  }
+
+  // [cx] 点击卡片切换激活 key —— 零重启。派发 cx:select-provider 事件，由 07 的桥接组件
+  // 接住 → useLocal().model.set 切到该 provider。providerID 规则须与 server.ts 完全一致。
+  async function handleActivate(entry: ResolvedKey): Promise<void> {
+    if (entry.builtin || entry.isActive || switchingId()) return
+    setSwitchingId(entry.id)
+    setNotice("")
+    try {
+      await cxChannelApi()?.channelKeysSetActive?.(entry.id)
+      // 拉该 key 的可用模型并落盘（供 provider 的可选模型）。失败返回空数组，不阻断切换。
+      const models = await fetchModelsWith(entry.baseURL, entry.key)
+      if (models.length > 0) {
+        try {
+          await cxChannelApi()?.channelKeysSetModels?.(entry.id, models)
+        } catch {
+          // 忽略：模型缓存写入失败不阻断切换。
+        }
+      }
+      const providerId = channelProviderId(entry.id)
+      // 默认 model：优先刚拉到的 models 首个；否则用 entry 已缓存的 models 首个；都没有则不派发
+      // 事件（仅更新激活项，避免切到一个没有 model 的 provider）。
+      const modelId = models.length > 0 ? models[0] : entry.models?.[0]
+      if (modelId) {
+        window.dispatchEvent(
+          new CustomEvent("cx:select-provider", { detail: { providerID: providerId, modelID: modelId } }),
+        )
+      }
+      // [cx] 只同步本地 active/models 元数据，保留全部 profile 缓存（账户级数据同源，不重拉）。
+      const next = await reloadKeys()
+      // 目标 key 若尚无 profile 缓存（例如刚导入未拉过），才补一次请求。
+      const target = next.find((k) => k.id === entry.id)
+      if (target && !profiles()[entry.id]) void loadProfile(target)
+    } catch {
+      setNotice("切换失败，请检查本地配置后重试。")
+    } finally {
+      setSwitchingId(null)
+    }
+  }
+
+  return (
+    <Dialog size="x-large" class="cx-account-dialog">
+      <DialogHeader closeLabel="关闭">
+        <DialogTitle>账户</DialogTitle>
+      </DialogHeader>
+      <DialogBody class="cx-account-body">
+        <Switch>
+          <Match when={initializing()}>
+            <div data-slot="cx-state-box">正在加载…</div>
+          </Match>
+
+          {/* [cx] US-011: 首启无 key 引导。 */}
+          <Match when={keys().length === 0}>
+            <div data-slot="cx-onboard">
+              <div data-slot="cx-onboard-icon">
+                <Icon name="plus" />
+              </div>
+              <div data-slot="cx-onboard-title">连接你的 Dokng 账户</div>
+              <div data-slot="cx-onboard-desc">
+                先在 Dokng 控制台创建 API Key，再将它粘贴到下方。Key 只保存在本机，并会自动读取账户余额与可用模型。
+              </div>
+              <Show when={siteUrl()}>
+                <ButtonV2 variant="neutral" size="normal" class="cx-site-button" onClick={() => openTopup(siteUrl())}>
+                  前往 Dokng 获取 API Key
+                  <Icon name="outline-square-arrow" size="small" />
+                </ButtonV2>
+              </Show>
+              <div data-slot="cx-onboard-divider">
+                <span>已有 API Key</span>
+              </div>
+              <AddKeyForm onAdd={handleAdd} startOpen />
+            </div>
+          </Match>
+
+          {/* [cx] 账户工作台：摘要、真实指标与 key 管理。 */}
+          <Match when={keys().length > 0}>
+            <div data-slot="cx-dashboard">
+              <div data-slot="cx-dashboard-head">
+                <Switch>
+                  <Match when={(activeProfile()?.status ?? "loading") === "loading"}>
+                    <div data-slot="cx-account-head" data-loading="">
+                      <div data-slot="cx-account-avatar-fallback">…</div>
+                      <div data-slot="cx-account-copy">
+                        <div data-slot="cx-account-name">正在读取账户</div>
+                        <div data-slot="cx-account-subtitle">正在连接当前激活的 key</div>
+                      </div>
+                    </div>
+                  </Match>
+                  <Match when={(activeProfile()?.status ?? "loading") === "error"}>
+                    <div data-slot="cx-account-head">
+                      <div data-slot="cx-account-avatar-fallback" data-error="">
+                        !
+                      </div>
+                      <div data-slot="cx-account-copy">
+                        <div data-slot="cx-account-name">账户数据不可用</div>
+                        <div data-slot="cx-account-subtitle">key 仍可管理，刷新后将重新请求</div>
+                      </div>
+                    </div>
+                  </Match>
+                  <Match
+                    when={
+                      activeProfile()?.status === "ready"
+                        ? (activeProfile() as Extract<KeyProfileState, { status: "ready" }>)
+                        : undefined
+                    }
+                    keyed
+                  >
+                    {(ready) => (
+                      <div data-slot="cx-account-head">
+                        <Show
+                          when={ready.avatar}
+                          fallback={
+                            <div data-slot="cx-account-avatar-fallback">
+                              {avatarInitial(ready.displayName || ready.username)}
+                            </div>
+                          }
+                        >
+                          <img src={ready.avatar} alt="头像" data-slot="cx-account-avatar" />
+                        </Show>
+                        <div data-slot="cx-account-copy">
+                          <div data-slot="cx-account-name">{ready.displayName || ready.username || "未命名用户"}</div>
+                          <div data-slot="cx-account-subtitle">
+                            {ready.displayName && ready.username ? `@${ready.username} · ` : ""}当前使用{" "}
+                            {activeEntry()?.label || ready.tokenName || "未命名 key"}
+                          </div>
+                        </div>
+                        <Tag data-slot="cx-connection-tag">已连接</Tag>
+                      </div>
+                    )}
+                  </Match>
+                </Switch>
+                <div data-slot="cx-dashboard-actions">
+                  <TooltipV2 value="刷新全部账户数据" placement="bottom">
+                    <IconButtonV2
+                      aria-label="刷新全部账户数据"
+                      variant="neutral"
+                      size="normal"
+                      disabled={anyLoading()}
+                      onClick={refreshAll}
+                      icon={<Icon name="reset" size="small" />}
+                    />
+                  </TooltipV2>
+                  <Show when={siteUrl()}>
+                    <ButtonV2 variant="neutral" size="normal" onClick={() => openTopup(siteUrl())}>
+                      控制台
+                      <Icon name="outline-square-arrow" size="small" />
+                    </ButtonV2>
+                  </Show>
+                  <ButtonV2
+                    variant="contrast"
+                    size="normal"
+                    disabled={!topupUrl()}
+                    onClick={() => openTopup(topupUrl())}
+                  >
+                    充值
+                  </ButtonV2>
+                </div>
+              </div>
+
+              {/* [cx] 账户余额与真实模型 Token 用量总览。API Key 数量只作为同步状态，绝不当作 token 消耗。 */}
+              <Show
+                when={
+                  accountProfile()?.status === "ready"
+                    ? (accountProfile() as Extract<KeyProfileState, { status: "ready" }>)
+                    : undefined
+                }
+                keyed
+              >
+                {(ready) => (
+                  <section data-slot="cx-summary" aria-label="账户用量总览">
+                    <div data-slot="cx-usage-visual">
+                      <div
+                        data-slot="cx-usage-ring"
+                        style={`--cx-used: ${usedPercent(ready.accountUsedQuota, ready.accountTotalQuota)}`}
+                        role="img"
+                        aria-label={`账户额度已使用 ${usedPercent(ready.accountUsedQuota, ready.accountTotalQuota)}%`}
+                      >
+                        <div data-slot="cx-usage-ring-inner">
+                          <strong>{`${usedPercent(ready.accountUsedQuota, ready.accountTotalQuota)}%`}</strong>
+                          <span>账户额度已用</span>
+                        </div>
+                      </div>
+                      <div data-slot="cx-usage-copy">
+                        <span>可用余额</span>
+                        <strong>{formatCurrency(ready.accountRemainingQuota)}</strong>
+                        <small>账户总额 {formatCurrency(ready.accountTotalQuota)}</small>
+                      </div>
+                    </div>
+
+                    <div data-slot="cx-overview-metrics">
+                      <div data-slot="cx-overview-head">
+                        <span>用量概览</span>
+                        <small>
+                          已同步 {tokenSummary().loaded} / {keys().length} 个 Key
+                          <Show when={tokenSummary().unlimited > 0}> · {tokenSummary().unlimited} 个额度不限</Show>
+                        </small>
+                      </div>
+                      <div data-slot="cx-overview-grid">
+                        <div data-slot="cx-overview-item">
+                          <span>今日 Tokens</span>
+                          <strong>{formatTokenCount(ready.accountTokensUsedToday)}</strong>
+                        </div>
+                        <div data-slot="cx-overview-item">
+                          <span>输入 / 输出</span>
+                          <strong>
+                            {formatTokenCount(ready.accountPromptTokensToday)} /{" "}
+                            {formatTokenCount(ready.accountCompletionTokensToday)}
+                          </strong>
+                        </div>
+                        <div data-slot="cx-overview-item">
+                          <span>今日费用</span>
+                          <strong>
+                            {ready.accountQuotaUsedToday === null ? "—" : formatCurrency(ready.accountQuotaUsedToday)}
+                          </strong>
+                        </div>
+                        <div data-slot="cx-overview-item">
+                          <span>累计费用</span>
+                          <strong>{formatCurrency(ready.accountUsedQuota)}</strong>
+                        </div>
+                      </div>
+                    </div>
+                  </section>
+                )}
+              </Show>
+
+              <Show when={notice()}>
+                <div data-slot="cx-notice">{notice()}</div>
+              </Show>
+
+              <div data-slot="cx-key-col">
+                <div data-slot="cx-key-col-head">
+                  <div data-slot="cx-key-col-copy">
+                    <span data-slot="cx-key-col-title">API Keys</span>
+                    <span data-slot="cx-key-count">{keys().length}</span>
+                    <div data-slot="cx-key-col-tip">管理凭据、查看实际 Token 用量与模型能力</div>
+                  </div>
+                  {/* [cx] 新增按钮放在标题行右侧；展开表单在标题下、网格上方。 */}
+                  <ButtonV2 variant="neutral" size="small" icon="plus" onClick={() => setAddingKey((prev) => !prev)}>
+                    新增 key
+                  </ButtonV2>
+                </div>
+                <Show when={addingKey()}>
+                  <div data-slot="cx-key-col-form">
+                    <AddKeyForm onAdd={handleAdd} open onOpenChange={setAddingKey} />
+                  </div>
+                </Show>
+                <div data-slot="cx-key-list">
+                  <For each={keys()}>
+                    {(entry) => (
+                      <KeyCard
+                        entry={entry}
+                        state={profiles()[entry.id]}
+                        switching={switchingId() === entry.id}
+                        onActivate={(e) => void handleActivate(e)}
+                        onSaveLabel={(id, label) => void handleSaveLabel(id, label)}
+                        onRemove={(id) => void handleRemove(id)}
+                      />
+                    )}
+                  </For>
+                </div>
+              </div>
+            </div>
+          </Match>
+        </Switch>
+      </DialogBody>
+    </Dialog>
+  )
+}
diff --git a/packages/app/src/components/cx-account/cx-account-import.tsx b/packages/app/src/components/cx-account/cx-account-import.tsx
