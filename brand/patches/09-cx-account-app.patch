+/* [cx] 账户工作台：完全复用 OpenCode v2 语义 token，不引入品牌外配色。 */
+@import "@opencode-ai/ui/v2/button-v2.css";
+@import "@opencode-ai/ui/v2/icon-button-v2.css";
+@import "@opencode-ai/ui/v2/text-input-v2.css";
+@import "@opencode-ai/ui/v2/tooltip-v2.css";
+
+/* [cx] 账户弹窗使用固定工作台布局：头部与总览保持可见，仅 Keys 列表独立滚动。 */
+[data-slot="dialog-content"].cx-account-dialog {
+  overflow: hidden;
+}
+
+[data-slot="dialog-content"] [data-slot="dialog-body"].cx-account-body {
+  flex: 1;
+  min-height: 0;
+  padding: 0 24px 24px;
+  overflow: hidden;
+}
+
+.cx-account-body [data-slot="cx-dashboard"] {
+  display: grid;
+  height: 100%;
+  min-width: 0;
+  min-height: 0;
+  grid-template-rows: auto auto minmax(0, 1fr);
+  gap: 16px;
+}
+
+.cx-account-body [data-slot="cx-key-list"] {
+  scrollbar-color: var(--v2-border-border-base) transparent;
+  scrollbar-width: thin;
+}
+
+.cx-account-body [data-slot="cx-key-list"]::-webkit-scrollbar {
+  width: 6px;
+}
+
+.cx-account-body [data-slot="cx-key-list"]::-webkit-scrollbar-thumb {
+  border-radius: 99px;
+  background: var(--v2-border-border-base);
+}
+
+.cx-account-body [data-slot="cx-dashboard-head"] {
+  display: flex;
+  min-width: 0;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+  padding: 16px 20px;
+  border-radius: 8px;
+  background: var(--v2-background-bg-layer-02);
+  box-shadow: inset 0 0 0 0.5px var(--v2-border-border-muted);
+}
+
+.cx-account-body [data-slot="cx-account-head"] {
+  display: flex;
+  min-width: 0;
+  flex: 1;
+  align-items: center;
+  gap: 12px;
+}
+
+.cx-account-body [data-slot="cx-account-avatar"],
+.cx-account-body [data-slot="cx-account-avatar-fallback"] {
+  width: 40px;
+  height: 40px;
+  flex-shrink: 0;
+  border: 0.5px solid var(--v2-border-border-base);
+  border-radius: 8px;
+}
+
+.cx-account-body [data-slot="cx-account-avatar"] {
+  object-fit: cover;
+}
+
+.cx-account-body [data-slot="cx-account-avatar-fallback"] {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: var(--v2-background-bg-layer-02);
+  color: var(--v2-text-text-muted);
+  font-size: 15px;
+  font-weight: 640;
+}
+
