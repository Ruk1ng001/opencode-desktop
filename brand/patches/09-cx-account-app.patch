+// [cx] US-009: 新增 key 表单。粘贴 sk-…（必填）+ 可选 label。key 明文只在内存流转，
+// 提交经 channelKeysAdd 写入本地 store；不打印、不写日志。
+// [cx] FR-3.5: 不暴露 baseURL 输入——新增 key 的 baseURL 固定为空串，由构建期内置
+// NEWAPI_BASE_URL 回退兜底；底层数据契约（channelKeysAdd 的 baseURL 参数）保持不变。
+// [cx] US-011: startOpen —— 首启无 key 引导时直接展开表单（引导即进入新增流程），无需再点一次。
+function AddKeyForm(props: {
+  onAdd: (input: { label: string; key: string; baseURL: string }) => Promise<void>
+  startOpen?: boolean
+}) {
+  const [open, setOpen] = createSignal(props.startOpen ?? false)
+  const [key, setKey] = createSignal("")
+  const [label, setLabel] = createSignal("")
+  const [error, setError] = createSignal("")
+  const [saving, setSaving] = createSignal(false)
+
+  function reset() {
+    setKey("")
+    setLabel("")
+    setError("")
+  }
+
+  async function submit() {
+    const k = key().trim()
+    if (!k) {
+      setError("请粘贴 API Key（sk-…）")
+      return
+    }
+    setSaving(true)
+    try {
+      // [cx] FR-3.5: baseURL 输入不暴露给用户，固定为空串——底层 channelKeysAdd 收到空 baseURL
+      // 时走构建期内置 NEWAPI_BASE_URL 回退（见 cx-account-api / 主进程 store）。数据契约不变。
+      await props.onAdd({ label: label().trim(), key: k, baseURL: "" })
+      reset()
+      setOpen(false)
+    } finally {
+      setSaving(false)
+    }
+  }
+
+  return (
+    <Show
+      when={open()}
+      fallback={
+        <ButtonV2 variant="neutral" size="normal" icon="plus" class="cx-add-key-trigger" onClick={() => setOpen(true)}>
+          新增 key
+        </ButtonV2>
+      }
+    >
+      <div data-slot="cx-add-form">
+        <TextInputV2
+          value={key()}
+          type="password"
+          autocomplete="off"
+          placeholder="API Key（sk-…，必填）"
+          onInput={(e) => setKey(e.currentTarget.value)}
+          aria-label="API Key"
+        />
+        <TextInputV2
+          value={label()}
+          placeholder="名称（可选）"
+          onInput={(e) => setLabel(e.currentTarget.value)}
+          aria-label="key 名称"
+        />
+        <Show when={error()}>
+          <div data-slot="cx-form-error">{error()}</div>
+        </Show>
+        <div data-slot="cx-form-actions">
+          <ButtonV2 variant="contrast" size="normal" class="cx-flex-1" disabled={saving()} onClick={submit}>
+            {saving() ? "保存中…" : "添加"}
+          </ButtonV2>
+          <ButtonV2
+            variant="neutral"
+            size="normal"
+            onClick={() => {
+              reset()
+              setOpen(false)
+            }}
+          >
+            取消
+          </ButtonV2>
+        </div>
+      </div>
+    </Show>
+  )
+}
