@@ -0,0 +1,571 @@
+// [cx] 账户面板（迁自 desktop 包 renderer/balance/balance-panel.tsx，US-005 → US-013）。
+//
+// 本文件是账户面板从 desktop 包迁入 @opencode-ai/app 包的落地：改用原生 v2 组件
+// （@opencode-ai/ui/v2 的 Dialog / ButtonV2 / TextInputV2 / ProgressCircleV2 / Tag）+
+// useDialog() 外壳，配色全走 v2 语义变量（cx-account.css），跟随明暗主题、与原生设置页视觉统一。
+// 不再自绘悬浮层 / 不再硬编码颜色（旧 desktop 面板 84 处硬编码金色内联样式已全部退役）。
+//
+// 数据层在 cx-account-api.ts（纯函数 + new-api 请求 + 本地 key 列表 + 跨包 window.api 桥接）。
+// 接线（侧边栏账户按钮 dialog.show、cx:// 深链）在 07 补丁的 layout.tsx；本文件只导出面板组件。
+//
+// 低冲突：独立目录 packages/app/src/components/cx-account/，全部 Cx 前缀，对上游现有文件零改动。
+
+import { createSignal, onMount, For, Show, Switch, Match } from "solid-js"
+import { Dialog, DialogBody, DialogHeader, DialogTitle } from "@opencode-ai/ui/v2/dialog-v2"
+import { ButtonV2 } from "@opencode-ai/ui/v2/button-v2"
+import { TextInputV2 } from "@opencode-ai/ui/v2/text-input-v2"
+import { ProgressCircleV2 } from "@opencode-ai/ui/v2/progress-circle-v2"
+import { Tag } from "@opencode-ai/ui/v2/badge-v2"
+import "./cx-account.css"
+import {
+  avatarInitial,
+  channelProviderId,
+  fetchModelsWith,
+  fetchProfileWith,
+  formatCurrency,
+  keyUsedPercent,
+  loadChannelState,
+  maskKey,
+  openTopup,
+  resolveKeyList,
+  resolveTopupUrl,
+  usedPercent,
+  cxChannelApi,
+  type KeyProfileState,
+  type ResolvedKey,
+} from "./cx-account-api"
+
+// [cx] US-008/US-009: 单张 key 卡片。按各自 key 独立展示 profile（loading/error/ready），并提供
+// 切换激活 / 编辑 label / 删除操作（builtin 内置渠道条目不可管理）。
+function KeyCard(props: {
+  entry: ResolvedKey
+  state: KeyProfileState | undefined
+  switching: boolean
+  onActivate: (entry: ResolvedKey) => void
+  onSaveLabel: (id: string, label: string) => void
+  onRemove: (id: string) => void
+}) {
+  const state = () => props.state ?? ({ status: "loading" } as KeyProfileState)
+  const [editing, setEditing] = createSignal(false)
+  const [labelDraft, setLabelDraft] = createSignal("")
+  const [confirmingDelete, setConfirmingDelete] = createSignal(false)
+
+  function startEdit() {
+    setLabelDraft(props.entry.label)
+    setEditing(true)
+  }
+  function saveEdit() {
+    props.onSaveLabel(props.entry.id, labelDraft().trim())
