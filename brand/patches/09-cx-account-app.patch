+// [cx] 账户面板数据层（迁自 desktop 包 renderer/balance/balance-panel.tsx，US-005 → US-013）。
+//
+// 纯数据层：零 UI import（不 import solid-js / 上游组件），可离线 typecheck。承载：
+//   - new-api 只读接口对接：profile（GET /api/app/profile，Bearer sk-）/ models（/v1/models）；
+//   - 本地 key 列表读取与解析（经 desktop preload 暴露的 window.api.channelKeys*）；
+//   - dokng:// 深链解析（parseImportDeepLink）；
+//   - providerID 派生（channelProviderId，须与主进程 server.ts / store-channel-keys.ts 完全一致）；
+//   - 单位换算 / 打码 / 使用率等纯函数。
+//
+// 跨包类型缺口：app 包看不到 desktop preload 的 window.api.channelKeys* / channelConfig* 与
+// import.meta.env.NEWAPI_*（那些类型声明在 desktop 包的 preload/types.ts、env.d.ts）。本文件用
+// 局部 interface + 断言访问器（cxWindowApi() / cxEnv()）解决，不碰上游类型文件；web 端无
+// window.api，全走可选链兜底、返回空态，绝不抛出。
+
+// [cx] US-006: new-api 只读 profile 接口路径（站点根下，非 /v1 渠道端点）。走 token 鉴权中间件，
+// 由 Bearer sk- 定位 token → 返回本人 profile。见 brand/docs/api-app-profile.md。
+const APP_PROFILE_PATH = "/api/app/profile"
+
+// new-api 默认 QuotaPerUnit：500000 额度 = 1 美元（common.QuotaPerUnit 默认值）。目标站点若改了
+// 该值，展示金额会有偏差——额度原值同时可展示以便对照。
+const QUOTA_PER_UNIT = 500000
+
+// ============================================================================
+// 跨包桥接：desktop preload 注入的 window.api（app 包无其类型）与构建期注入的渠道变量。
+// ============================================================================
+
+// [cx] desktop preload 暴露的、账户面板要用的 IPC 子集（签名与 05-channel-keys-ipc 的
+// preload/types.ts 对齐）。app 包不 import desktop 类型，故本地重声明；web 端 window.api 不存在。
+interface CxChannelApi {
+  channelKeysList: () => Promise<string>
+  channelKeysAdd: (input: { label: string; key: string; baseURL: string }) => Promise<string>
+  channelKeysRemove: (id: string) => Promise<string>
+  channelKeysUpdateLabel: (id: string, label: string) => Promise<string>
+  channelKeysSetActive: (id: string) => Promise<string>
+  channelKeysSetModels: (id: string, models: string[]) => Promise<string>
+  channelConfigRefreshKey: (id: string) => Promise<void>
+  channelConfigReload: () => Promise<void>
+  openLink: (url: string) => void
+}
+
+// [cx] 断言访问器：取 window.api 的账户面板子集。web 等无 preload 的平台返回 undefined，
+// 调用方全走可选链兜底。不抛出。
+export function cxChannelApi(): Partial<CxChannelApi> | undefined {
+  if (typeof window === "undefined") return undefined
+  return (window as unknown as { api?: Partial<CxChannelApi> }).api
+}
+
+// [cx] 构建期由 electron.vite renderer.define 注入的渠道变量（02 补丁）。app 包 env.d.ts 无这些
+// 声明，故此处按需断言读取；未注入时为空串。
+function cxEnv(): { NEWAPI_BASE_URL: string; NEWAPI_API_KEY: string; NEWAPI_TOPUP_URL: string } {
+  const env = import.meta.env as unknown as Record<string, string | undefined>
+  return {
+    NEWAPI_BASE_URL: env.NEWAPI_BASE_URL ?? "",
+    NEWAPI_API_KEY: env.NEWAPI_API_KEY ?? "",
+    NEWAPI_TOPUP_URL: env.NEWAPI_TOPUP_URL ?? "",
+  }
+}
+
+// ============================================================================
+// 纯工具函数
+// ============================================================================
+
+// 从渠道 baseURL（如 https://host/v1）推导 new-api 站点根，用户接口挂在站点根 /api 下。
+function deriveApiBase(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  return trimmed.replace(/\/v1$/, "")
+}
+
+// [cx] US-009: 由渠道 baseURL 推导 OpenAI 兼容 /v1/models 端点。
+function deriveModelsUrl(baseURL: string): string {
+  const trimmed = baseURL.trim().replace(/\/+$/, "")
+  if (/\/v1$/.test(trimmed)) return `${trimmed}/models`
+  return `${trimmed}/v1/models`
+}
+
+// [cx] US-007/US-010: 解析充值页面 URL。优先注入变量 NEWAPI_TOPUP_URL，缺省回退到「由激活 key
+// 的 baseURL 推导的站点根」（随激活 key 变化），activeBaseURL 为空再回退构建期 NEWAPI_BASE_URL。
+// 两者都缺失返回空串（充值入口禁用并提示）。
+export function resolveSiteUrl(activeBaseURL?: string): string {
+  const env = cxEnv()
+  const baseURL = (activeBaseURL ?? "").trim() || env.NEWAPI_BASE_URL
+  return deriveApiBase(baseURL)
+}
+
+export function resolveTopupUrl(activeBaseURL?: string): string {
+  const env = cxEnv()
+  const topup = env.NEWAPI_TOPUP_URL.trim()
+  if (topup) return topup
+  return resolveSiteUrl(activeBaseURL)
+}
+
+// [cx] US-007: 在系统默认浏览器打开充值页面。renderer 是浏览器上下文，经 preload 暴露的
+// openLink（→ 主进程 shell.openExternal）打开。客户端内不实现任何支付逻辑。
+export function openTopup(url: string): void {
+  if (!url) return
+  try {
+    cxChannelApi()?.openLink?.(url)
+  } catch {
+    // openLink 只是发一条 ipc 消息，正常不会抛出；即便异常也不应让面板崩溃。
+  }
+}
+
+// 额度 → 美元金额（两位小数）。
+export function formatCurrency(quotaUnits: number): string {
+  return "$" + (quotaUnits / QUOTA_PER_UNIT).toFixed(2)
+}
+
+// 模型实际消耗 token 数的人类可读格式。注意：这里的 token 指 prompt_tokens +
+// completion_tokens，不是 new-api 的 API Token / Key 记录。
+export function formatTokenCount(value: number | null): string {
+  if (value === null || !Number.isFinite(value)) return "—"
+  const count = Math.max(0, value)
+  const units = [
+    { value: 1_000_000_000, suffix: "B" },
+    { value: 1_000_000, suffix: "M" },
+    { value: 1_000, suffix: "K" },
+  ]
+  const unit = units.find((item) => count >= item.value)
+  if (!unit) return Math.round(count).toLocaleString("zh-CN")
+  const scaled = count / unit.value
+  const digits = scaled >= 100 ? 0 : scaled >= 10 ? 1 : 2
+  return `${Number(scaled.toFixed(digits))}${unit.suffix}`
+}
+
+// [cx] US-006: 无头像时的占位首字（取用户名首字符，空则用「?」）。
+export function avatarInitial(username: string): string {
+  const trimmed = username.trim()
+  return trimmed ? trimmed[0].toUpperCase() : "?"
+}
+
+// [cx] US-008: key 打码展示（`sk-…abcd`）。仅保留可辨识前缀与末 4 位，绝不整段渲染 key 明文。
+export function maskKey(key: string): string {
+  const k = key.trim()
+  if (!k) return ""
+  if (k.length <= 7) return "…" + k.slice(-Math.min(4, k.length))
+  return `${k.slice(0, 3)}…${k.slice(-4)}`
+}
+
+// 账户已用占比（0~100，整数）。总额度为 0 时返回 0，避免除零。
+export function usedPercent(usedQuota: number, quota: number): number {
+  if (quota <= 0) return 0
+  return Math.min(100, Math.max(0, Math.round((usedQuota / quota) * 100)))
+}
+
+// [cx] US-007: per-key 使用率（0~100，整数）——已用 /（已用 + 剩余）。分母为 0 时返回 0。
+// unlimited 时该值无意义，调用点已用 unlimited 分支屏蔽。
+export function keyUsedPercent(tokenUsed: number, tokenRemain: number): number {
+  const granted = tokenUsed + tokenRemain
+  if (granted <= 0) return 0
+  return Math.min(100, Math.max(0, Math.round((tokenUsed / granted) * 100)))
+}
+
+// [cx] 多 provider：由 key.id 派生稳定的 opencode providerID。**必须与主进程 server.ts /
+// store-channel-keys.ts 的 channelProviderId 完全一致**（`newapi-<id前8位>`），否则派发的
+// cx:select-provider 事件匹配不到 provider，切换不生效——硬约束。
+export function channelProviderId(keyId: string): string {
+  return `newapi-${keyId.slice(0, 8)}`
+}
+
+// ============================================================================
+// 类型
+// ============================================================================
+
+// [cx] US-006: profile 就绪态承载的字段。额度类均为 new-api 原始 quota 整数，换算在渲染层做。
+type ProfileData = {
+  username: string
+  displayName: string
+  avatar: string
+  // 账户额度来自 user.Quota（剩余）与 user.UsedQuota（累计），不能受当前 Key 是否不限额影响。
+  accountRemainingQuota: number
+  accountUsedQuota: number
+  accountTotalQuota: number
+  accountQuotaUsedToday: number | null
+  // 实际模型 token 数 = logs.prompt_tokens + logs.completion_tokens；与 API Key 记录严格区分。
+  accountTokensUsedToday: number | null
+  accountPromptTokensToday: number | null
+  accountCompletionTokensToday: number | null
+  keyRemainingQuota: number
+  keyUsedQuota: number
+  keyQuotaUsedToday: number | null
+  keyTokensUsedToday: number | null
+  keyPromptTokensToday: number | null
+  keyCompletionTokensToday: number | null
+  keyUnlimitedQuota: boolean
+  requestCountToday: number | null
+  // [cx] 该 key 在 new-api 侧的 token.Name。若本地没填名称，UI 直接用此字段展示，新增时也会回填本地。
+  tokenName: string
+}
+
+// [cx] US-006: /api/app/profile 响应信封（见 brand/docs/api-app-profile.md 第 3 节）。字段全部
+// 可选，做防御性解析；契约未强约束 success 信封，故按 HTTP status 分支，data 缺失时把整个 body
+// 当作扁平 profile 兜底。
+type ProfilePayload = {
+  username?: string
+  display_name?: string
+  avatar?: string
+  account_remaining_quota?: number
+  account_used_quota?: number
+  account_total_quota?: number
+  account_quota_used_today?: number
+  account_tokens_used_today?: number
+  account_prompt_tokens_today?: number
+  account_completion_tokens_today?: number
+  key_name?: string
+  key_remaining_quota?: number
+  key_used_quota?: number
+  key_quota_used_today?: number
+  key_tokens_used_today?: number
+  key_prompt_tokens_today?: number
+  key_completion_tokens_today?: number
+  key_unlimited_quota?: boolean
+  request_count_today?: number
+  // 旧版二开字段兼容：新后端应优先返回上面的 account_* / key_* 明确命名。
+  quota?: number
+  used_quota?: number
+  used_today?: number
+  token_name?: string
+  token_remain?: number
+  token_used?: number
+  token_used_today?: number
+  unlimited?: boolean
+}
+
+type ProfileResponse = ProfilePayload & {
+  success?: boolean
+  message?: string
+  data?: ProfilePayload
+}
+
+// [cx] US-008: 单 key 的 profile 拉取结果。无凭据的 key 不会进列表，故只有 loading/error/ready。
+export type KeyProfileState =
+  | { status: "loading" }
+  | { status: "error"; message: string }
+  | ({ status: "ready" } & ProfileData)
+
+// [cx] US-008/US-009: 已解析的可用 key 条目（本地 store 或构建期回退）。key 为明文仅本地持有，
+// 展示前必经 maskKey 打码。builtin=true 表示构建期注入的内置渠道合成条目（不可增删改切换）。
+export type ResolvedKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  isActive: boolean
+  builtin: boolean
+  models: string[]
+}
+
+// 本地 store 里的原始条目（与主进程 store-channel-keys.ts 的 ChannelKey 对齐）。
+type StoredChannelKey = {
+  id: string
+  label: string
+  key: string
+  baseURL: string
+  models?: string[]
+}
+
+function isStoredChannelKey(value: unknown): value is StoredChannelKey {
+  if (!value || typeof value !== "object") return false
+  const r = value as Record<string, unknown>
+  return (
+    typeof r.id === "string" &&
+    typeof r.label === "string" &&
+    typeof r.key === "string" &&
+    typeof r.baseURL === "string"
+  )
+}
+
+function normalizeModels(value: unknown): string[] {
+  if (!Array.isArray(value)) return []
+  return value.filter((m): m is string => typeof m === "string" && m.length > 0)
+}
+
+export type ChannelState = { keys: StoredChannelKey[]; activeKeyId: string | null }
+
+// [cx] US-013: 深链解析结果——待确认导入的 key 信息（key 为明文，仅内存持有，展示打码）。
+export type ImportRequest = { key: string; label: string; baseURL: string }
+
+// ============================================================================
+// 本地 key 列表读取与解析
+// ============================================================================
+
+// [cx] US-009: 读本地 key 列表状态。经专用 IPC channelKeysList 拿 JSON 字符串再解析；任何
+// 异常/脏数据都吞掉返回空状态，绝不抛出。web 端无 window.api 时同样返回空状态。
+export async function loadChannelState(): Promise<ChannelState> {
+  try {
+    const raw = await cxChannelApi()?.channelKeysList?.()
+    if (!raw) return { keys: [], activeKeyId: null }
+    const parsed = JSON.parse(raw) as { keys?: unknown; activeKeyId?: unknown }
+    if (!parsed || typeof parsed !== "object" || !Array.isArray(parsed.keys)) {
+      return { keys: [], activeKeyId: null }
+    }
+    const keys = parsed.keys.filter(isStoredChannelKey).map((k) => ({ ...k, models: normalizeModels(k.models) }))
+    const activeKeyId =
+      typeof parsed.activeKeyId === "string" && keys.some((k) => k.id === parsed.activeKeyId)
+        ? parsed.activeKeyId
+        : null
+    return { keys, activeKeyId }
+  } catch {
+    return { keys: [], activeKeyId: null }
+  }
+}
+
+// [cx] US-008/US-009: 把 store 状态解析成面板要展示的 key 列表。本地有 key 时全部展示（含缺
+// baseURL 的条目：查询用地址回退构建期变量），并标注激活项；本地无 key 时回退到构建期注入的内置
+// 渠道合成单条（builtin，不可管理），保证面板仍可用。
+export function resolveKeyList(state: ChannelState): ResolvedKey[] {
+  const env = cxEnv()
+  const fallbackBase = env.NEWAPI_BASE_URL
+  if (state.keys.length > 0) {
+    return state.keys.map((k) => ({
+      id: k.id,
+      // 保留空 label，让 profile 返回的 token.Name 能成为展示名；不要过早固化成占位文案。
+      label: k.label.trim(),
+      key: k.key,
+      baseURL: k.baseURL || fallbackBase,
+      isActive: k.id === state.activeKeyId,
+      builtin: false,
+      models: normalizeModels(k.models),
+    }))
+  }
+  const apiKey = env.NEWAPI_API_KEY
+  if (fallbackBase && apiKey) {
+    return [
+      {
+        id: "__builtin__",
+        label: "内置渠道",
+        key: apiKey,
+        baseURL: fallbackBase,
+        isActive: true,
+        builtin: true,
+        models: [],
+      },
+    ]
+  }
+  return []
+}
+
+// ============================================================================
+// new-api 网络请求（全部 try/catch，永不抛出）
+// ============================================================================
+
+// [cx] US-006/US-008: 按指定 key/baseURL 拉 profile。任何异常都转成 error 态返回，永不抛出。
+// 凭据由参数传入（逐 key 查询）——不同 key 可能是不同账户。
+export async function fetchProfileWith(baseURL: string, apiKey: string): Promise<KeyProfileState> {
+  if (!baseURL || !apiKey) return { status: "error", message: "缺少渠道凭据" }
+  try {
+    const url = deriveApiBase(baseURL) + APP_PROFILE_PATH
+    const res = await fetch(url, {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return { status: "error", message: `请求返回 HTTP ${res.status}` }
+
+    const body = (await res.json()) as ProfileResponse
+    if (body.success === false) {
+      return { status: "error", message: body.message || "接口返回失败" }
+    }
+    const p = body.data ?? body
+    const accountUsedQuota = p.account_used_quota ?? p.used_quota ?? 0
+    const accountTotalQuota = p.account_total_quota ?? p.quota ?? 0
+    const accountRemainingQuota = p.account_remaining_quota ?? Math.max(0, accountTotalQuota - accountUsedQuota)
+    return {
+      status: "ready",
+      username: p.username ?? "",
+      displayName: p.display_name ?? "",
+      avatar: p.avatar ?? "",
+      accountRemainingQuota,
+      accountUsedQuota,
+      accountTotalQuota: accountTotalQuota || accountRemainingQuota + accountUsedQuota,
+      accountQuotaUsedToday:
+        typeof p.account_quota_used_today === "number"
+          ? p.account_quota_used_today
+          : typeof p.used_today === "number"
+            ? p.used_today
+            : null,
+      accountTokensUsedToday: typeof p.account_tokens_used_today === "number" ? p.account_tokens_used_today : null,
+      accountPromptTokensToday:
+        typeof p.account_prompt_tokens_today === "number" ? p.account_prompt_tokens_today : null,
+      accountCompletionTokensToday:
+        typeof p.account_completion_tokens_today === "number" ? p.account_completion_tokens_today : null,
+      keyRemainingQuota: p.key_remaining_quota ?? p.token_remain ?? 0,
+      keyUsedQuota: p.key_used_quota ?? p.token_used ?? 0,
+      keyQuotaUsedToday:
+        typeof p.key_quota_used_today === "number"
+          ? p.key_quota_used_today
+          : typeof p.token_used_today === "number"
+            ? p.token_used_today
+            : null,
+      keyTokensUsedToday: typeof p.key_tokens_used_today === "number" ? p.key_tokens_used_today : null,
+      keyPromptTokensToday: typeof p.key_prompt_tokens_today === "number" ? p.key_prompt_tokens_today : null,
+      keyCompletionTokensToday:
+        typeof p.key_completion_tokens_today === "number" ? p.key_completion_tokens_today : null,
+      keyUnlimitedQuota: p.key_unlimited_quota ?? p.unlimited ?? false,
+      requestCountToday: typeof p.request_count_today === "number" ? p.request_count_today : null,
+      tokenName: typeof p.key_name === "string" ? p.key_name : typeof p.token_name === "string" ? p.token_name : "",
+    }
+  } catch (error) {
+    return {
+      status: "error",
+      message: error instanceof Error ? error.message : "网络请求失败",
+    }
+  }
+}
+
+// [cx] 新增 key 未填名称时，用该 key 在 new-api 侧的 token 名称（token.Name，经 /api/app/profile
+// 的 token_name 返回）作为本地 label 的一次性来源。拉取失败 / 名称为空时返回空串——调用方据此
+// 决定回退（如「未命名 key」）。此处只在新增那一刻取一次，后续本地 label 不再与远端同步。
+export async function fetchTokenName(baseURL: string, apiKey: string): Promise<string> {
+  const profile = await fetchProfileWith(baseURL, apiKey)
+  if (profile.status !== "ready") return ""
+  return profile.tokenName.trim()
+}
+
+// [cx] US-009: 拉取某 key 的可用模型列表（OpenAI 兼容 /v1/models，Bearer sk-）。返回模型 id
+// 数组；任何异常/非 200/脏响应都返回空数组，永不抛出。切换激活 key 后落盘，server.ts 注入内核。
+export async function fetchModelsWith(baseURL: string, apiKey: string): Promise<string[]> {
+  if (!baseURL || !apiKey) return []
+  try {
+    const res = await fetch(deriveModelsUrl(baseURL), {
+      headers: {
+        Authorization: `Bearer ${apiKey}`,
+        Accept: "application/json",
+      },
+    })
+    if (!res.ok) return []
+    const body = (await res.json()) as { data?: unknown } | unknown[]
+    const list = Array.isArray(body)
+      ? body
+      : Array.isArray((body as { data?: unknown }).data)
+        ? (body as { data: unknown[] }).data
+        : []
+    const ids = list
+      .map((m) => (typeof m === "string" ? m : m && typeof m === "object" ? (m as { id?: unknown }).id : undefined))
+      .filter((id): id is string => typeof id === "string" && id.length > 0)
+    return Array.from(new Set(ids))
+  } catch {
+    return []
+  }
+}
+
+// ============================================================================
+// [cx] US-013: dokng:// 深链一键导入解析
+//
+// 深链格式（约定）：dokng://import-key?key=sk-xxx&label=我的渠道&baseURL=https://host/v1
+//   - key（必填）：new-api 的 API Token（sk-…）。校验非空。
+//   - label（可选）：展示名。
+//   - baseURL（可选）：渠道地址，缺省用内置地址。校验须为可解析 http(s)，否则丢弃回退内置。
+// host 兼容 import-key / 空 host（dokng://?key=…）两种写法。
+//
+// 安全（US-013 验收 #3）：解析成功不静默写入，由调用方弹确认框展示 label / 打码 key / baseURL，
+// 用户确认后才 channelKeysAdd 写入，避免恶意深链偷偷灌 key。
+// ============================================================================
+
+// [cx] US-013: 从单条 dokng:// URL 解析导入请求。校验：dokng: 协议 + key 非空。baseURL 若提供须为
+// 可解析 http(s)，否则丢弃该字段（回退内置）而非整体失败。解析失败返回 null，不抛出。
+export function parseImportDeepLink(raw: string): ImportRequest | null {
+  if (typeof raw !== "string" || !raw.trim()) return null
+  let url: URL
+  try {
+    url = new URL(raw.trim())
+  } catch {
+    return null
+  }
+  if (url.protocol !== "dokng:") return null
+  const params = url.searchParams
+  const key = (params.get("key") ?? "").trim()
+  if (!key) return null
+  const label = (params.get("label") ?? "").trim()
+  let baseURL = (params.get("baseURL") ?? params.get("baseurl") ?? "").trim()
+  if (baseURL) {
+    try {
+      const parsed = new URL(baseURL)
+      if (parsed.protocol !== "http:" && parsed.protocol !== "https:") baseURL = ""
+    } catch {
+      baseURL = "" // baseURL 非法——丢弃，回退内置地址，不因此整体失败。
+    }
+  }
+  return { key, label, baseURL }
+}
+
+// [cx] US-013: 深链导入确认框展示用的渠道地址（空则回退构建期内置 / 文案兜底）。
+export function importDisplayBase(request: ImportRequest): string {
+  return request.baseURL || cxEnv().NEWAPI_BASE_URL || "内置渠道地址"
+}
+
+// [cx] 导入请求的「有效渠道地址」——用于向 new-api 发请求（取 token 名称等）。与
+// importDisplayBase 不同，这里不带「内置渠道地址」文案兜底：空则回退构建期内置 NEWAPI_BASE_URL，
+// 仍为空时返回空串（调用方 fetch 会因缺 baseURL 直接返回空/错误，不抛出）。
+export function importEffectiveBaseURL(request: ImportRequest): string {
+  return request.baseURL || cxEnv().NEWAPI_BASE_URL
+}
