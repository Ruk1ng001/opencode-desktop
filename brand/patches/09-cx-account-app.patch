@@ -0,0 +1,173 @@
+// [cx] US-013: dokng:// 深链一键导入确认框（迁自 desktop 包 balance-panel.tsx 的 ImportDialog）。
+//
+// 网站点击「一键导入」→ 系统唤起 App（dokng:// 协议，06 补丁在主进程注册）→ opencode 既有 deep-link
+// 分发把 URL 送到渲染层 → 07 补丁的 layout.tsx handleDeepLinks 解析出 dokng:// 后动态 import 本组件
+// 弹确认框。安全（US-013 验收 #3）：解析成功不静默写入，先展示 label / 打码 key / baseURL，
+// 用户确认后才 channelKeysAdd 写入本地列表，避免恶意深链偷偷灌 key。
+//
+// 用原生 v2 Dialog 外壳，配色走 v2 语义变量（cx-account.css），与账户面板视觉一致。
+// 自闭合：用同作用域 useDialog().close() 关闭，不接 onClose prop——layout.tsx 直接
+// dialog.show(() => <CxDialogImport request={req} />)，无需注入关闭回调。
+
+import { createSignal } from "solid-js"
+import { Switch, Match } from "solid-js"
+import { useDialog } from "@opencode-ai/ui/context/dialog"
+import { Dialog, DialogBody, DialogHeader, DialogTitle } from "@opencode-ai/ui/v2/dialog-v2"
+import { ButtonV2 } from "@opencode-ai/ui/v2/button-v2"
+import "./cx-account.css"
+import {
+  cxChannelApi,
+  fetchTokenName,
+  importDisplayBase,
+  importEffectiveBaseURL,
+  maskKey,
+  type ImportRequest,
+} from "./cx-account-api"
+
+// [cx] US-013: 导入确认框内容。展示待导入信息 → 确认写入 → 可选「设为激活」。
+// 用同作用域 useDialog().close() 自闭合（写入 / 取消 / 完成后关闭）。
+function CxDialogImport(props: { request: ImportRequest }) {
+  const dialog = useDialog()
+  const close = () => dialog.close()
+  type Phase =
+    | { status: "confirm" }
+    | { status: "saving" }
+    | { status: "done"; id: string }
+    | { status: "activating" }
+    | { status: "error"; message: string }
+  const [phase, setPhase] = createSignal<Phase>({ status: "confirm" })
+
+  async function confirmImport() {
+    setPhase({ status: "saving" })
+    try {
+      // channelKeysAdd 返回最新 ChannelKeysState 的 JSON。解析出新条目 id（用于「设为激活」）。
+      const raw = await cxChannelApi()?.channelKeysAdd?.({
+        label: props.request.label,
+        key: props.request.key,
+        baseURL: props.request.baseURL,
+      })
+      const state = raw ? (JSON.parse(raw) as { keys?: Array<{ id: string; key: string }> }) : { keys: [] }
+      const list = Array.isArray(state.keys) ? state.keys : []
+      // 新增条目排在末尾；按明文 key 匹配取回 id（key 仅内存比对，不外传）。
+      const added = [...list].reverse().find((k) => k.key === props.request.key)
+      const addedId = added?.id ?? ""
+
+      // [cx] 深链未带 label 时：用该 key 在 new-api 侧的 token 名称（/api/app/profile 的
+      // token_name）一次性回填本地 label（后续不再与远端同步）。失败 / 远端也无名称则保持占位。
+      if (addedId && !props.request.label.trim()) {
+        const remoteName = await fetchTokenName(importEffectiveBaseURL(props.request), props.request.key)
+        if (remoteName) {
+          try {
+            await cxChannelApi()?.channelKeysUpdateLabel?.(addedId, remoteName)
+          } catch {
+            // 回填失败不阻断：卡片显示「未命名 key」占位，可手动改名。
+          }
+        }
+      }
+
+      setPhase({ status: "done", id: addedId })
+    } catch {
+      setPhase({ status: "error", message: "导入失败，请重试或手动在账户面板添加。" })
+    }
+  }
+
+  // [cx] US-013: 导入成功后可直接设为激活。setActive → channelConfigRefreshKey（主进程拉该 key
+  // 的 /v1/models 落盘 + 重写 OPENCODE_CONFIG + 热重载），该 key 即成为可用 provider——不重启进程。
+  async function activateNow(id: string) {
+    if (!id) {
+      close()
+      return
+    }
+    setPhase({ status: "activating" })
+    try {
+      await cxChannelApi()?.channelKeysSetActive?.(id)
+      await cxChannelApi()?.channelConfigRefreshKey?.(id)
+    } catch {
+      // 设为激活/重载失败——不崩溃，直接关闭（用户可在面板手动切换）。
+    }
+    close()
+  }
+
+  return (
+    <Dialog size="normal" fit>
+      <DialogHeader closeLabel="关闭">
+        <DialogTitle>导入 key</DialogTitle>
+      </DialogHeader>
+      <DialogBody class="cx-account-body">
+        <Switch>
+          <Match when={phase().status === "done" || phase().status === "activating"}>
+            <div data-slot="cx-import-done">
+              <div data-slot="cx-onboard-title">✅ 导入成功</div>
+              <p data-slot="cx-import-done-text">
+                「{props.request.label || maskKey(props.request.key) || "新 key"}」已加入本地列表。是否立即设为激活
+                key？
+              </p>
+              <div data-slot="cx-form-actions">
+                <ButtonV2
+                  variant="contrast"
+                  size="normal"
+                  class="cx-flex-1"
+                  disabled={phase().status === "activating"}
+                  onClick={() => {
+                    const p = phase()
+                    if (p.status === "done") void activateNow(p.id)
+                  }}
+                >
+                  {phase().status === "activating" ? "设置中…" : "设为激活"}
+                </ButtonV2>
+                <ButtonV2 variant="neutral" size="normal" onClick={close}>
+                  暂不
+                </ButtonV2>
+              </div>
+            </div>
+          </Match>
+
+          <Match when={phase().status === "error"}>
+            <div data-slot="cx-state-box">
+              <div data-slot="cx-form-error">{(phase() as { status: "error"; message: string }).message}</div>
+              <ButtonV2 variant="neutral" size="normal" class="cx-flex-1" onClick={close}>
+                关闭
+              </ButtonV2>
+            </div>
+          </Match>
+
+          <Match when={phase().status === "confirm" || phase().status === "saving"}>
+            <p data-slot="cx-import-notice">
+              收到一条导入请求。请确认以下 key 信息无误后再导入——请勿导入来源不明的 key。
+            </p>
+            <div data-slot="cx-import-rows">
+              <div data-slot="cx-import-row">
+                <span data-slot="cx-import-row-label">名称</span>
+                <span data-slot="cx-import-row-value">{props.request.label || "（未命名）"}</span>
+              </div>
+              <div data-slot="cx-import-row">
+                <span data-slot="cx-import-row-label">API Key</span>
+                <span data-slot="cx-import-row-value">{maskKey(props.request.key)}</span>
+              </div>
+              <div data-slot="cx-import-row" data-last="">
+                <span data-slot="cx-import-row-label">渠道地址</span>
+                <span data-slot="cx-import-row-value">{importDisplayBase(props.request)}</span>
+              </div>
+            </div>
+            <div data-slot="cx-form-actions">
+              <ButtonV2
+                variant="contrast"
+                size="normal"
+                class="cx-flex-1"
+                disabled={phase().status === "saving"}
+                onClick={confirmImport}
+              >
+                {phase().status === "saving" ? "导入中…" : "确认导入"}
+              </ButtonV2>
+              <ButtonV2 variant="neutral" size="normal" onClick={close}>
+                取消
+              </ButtonV2>
+            </div>
+          </Match>
+        </Switch>
+      </DialogBody>
+    </Dialog>
+  )
+}
+
+export { CxDialogImport }
