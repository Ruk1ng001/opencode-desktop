+// [cx] 账户面板主体。经 useDialog().show(() => <CxDialogAccount/>) 弹出（接线在 07 的 layout.tsx）。
+// 用 v2 Dialog(size=large) 外壳 + 两栏布局：左账户卡（环形图 + 充值 + 用量小结），右 key 列表卡片。
+export function CxDialogAccount() {
+  const [initializing, setInitializing] = createSignal(true)
+  const [keys, setKeys] = createSignal<ResolvedKey[]>([])
+  // 逐 key 的 profile 状态，按 key id 索引；整份替换以触发响应式更新。
+  const [profiles, setProfiles] = createSignal<Record<string, KeyProfileState>>({})
+  // [cx] US-009: 正在切换激活的 key id（切换期间禁用相关按钮、显示反馈）。
+  const [switchingId, setSwitchingId] = createSignal<string | null>(null)
+
+  const activeEntry = () => keys().find((k) => k.isActive) ?? keys()[0]
+  const activeProfile = (): KeyProfileState | undefined => {
+    const entry = activeEntry()
+    return entry ? profiles()[entry.id] : undefined
+  }
+
+  // [cx] US-010: 充值 URL 派生自「当前激活 key」，随切换响应式变化。都缺失则空串 → 按钮禁用。
+  const topupUrl = () => resolveTopupUrl(activeEntry()?.baseURL)
+  // 有任一 key 仍在加载即视为刷新中（一键刷新按钮据此禁用 + 改文案）。
+  const anyLoading = () => keys().some((k) => (profiles()[k.id]?.status ?? "loading") === "loading")
+
+  // 对单个 key 拉 profile：先置 loading（加载反馈），再写入结果。
+  async function loadProfile(entry: ResolvedKey): Promise<void> {
+    setProfiles((prev) => ({ ...prev, [entry.id]: { status: "loading" } }))
+    const result = await fetchProfileWith(entry.baseURL, entry.key)
+    setProfiles((prev) => ({ ...prev, [entry.id]: result }))
+  }
+
+  // [cx] US-008: 一键刷新——对所有可见 key 重新拉取 profile。
+  function refreshAll(): void {
+    for (const entry of keys()) void loadProfile(entry)
+  }
+
+  // 从本地 store 重新拉列表并刷新 profile（增删改切换后调用以同步 UI）。
+  async function reload(): Promise<void> {
+    const state = await loadChannelState()
+    setKeys(resolveKeyList(state))
+    setInitializing(false)
+    refreshAll()
+  }
+
+  onMount(() => {
+    void reload()
+  })
+
+  // [cx] 新增 key —— 写入本地列表 → 主进程拉模型 + 热重载（provider 出现），不重启进程。
+  async function handleAdd(input: { label: string; key: string; baseURL: string }): Promise<void> {
+    let addedId: string | undefined
+    try {
+      // channelKeysAdd 返回最新 ChannelKeysState 的 JSON，解析出新条目 id（按明文 key 反向匹配）。
+      const raw = await cxChannelApi()?.channelKeysAdd?.(input)
+      const state = raw ? (JSON.parse(raw) as { keys?: Array<{ id: string; key: string }> }) : { keys: [] }
+      const list = Array.isArray(state.keys) ? state.keys : []
+      addedId = [...list].reverse().find((k) => k.key === input.key)?.id
+    } catch {
+      // 主进程写库正常不抛；即便异常也不应让面板崩溃。
+    }
+    await reload()
+    if (addedId) {
+      try {
+        await cxChannelApi()?.channelConfigRefreshKey?.(addedId)
+      } catch {
+        // 热重载失败不阻断；下次启动时文件配置仍会生效。
+      }
+      await reload()
+    }
+  }
+
+  // [cx] US-009: 保存 label。
+  async function handleSaveLabel(id: string, label: string): Promise<void> {
+    try {
+      await cxChannelApi()?.channelKeysUpdateLabel?.(id, label)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    await reload()
+  }
+
+  // [cx] 删除 key（二次确认在卡片内完成）。删激活项时主进程侧激活回退首项/置空。
+  async function handleRemove(id: string): Promise<void> {
+    try {
+      await cxChannelApi()?.channelKeysRemove?.(id)
+    } catch {
+      // 忽略：不让面板崩溃。
+    }
+    await reload()
+    try {
+      await cxChannelApi()?.channelConfigReload?.()
+    } catch {
+      // 热重载失败不阻断；下次启动时文件配置仍会生效。
+    }
+  }
+
+  // [cx] 点击卡片切换激活 key —— 零重启。派发 cx:select-provider 事件，由 07 的桥接组件
+  // 接住 → useLocal().model.set 切到该 provider。providerID 规则须与 server.ts 完全一致。
+  async function handleActivate(entry: ResolvedKey): Promise<void> {
+    if (entry.builtin || entry.isActive || switchingId()) return
+    setSwitchingId(entry.id)
+    try {
+      await cxChannelApi()?.channelKeysSetActive?.(entry.id)
+      // 拉该 key 的可用模型并落盘（供 provider 的可选模型）。失败返回空数组，不阻断切换。
+      const models = await fetchModelsWith(entry.baseURL, entry.key)
+      if (models.length > 0) {
+        try {
+          await cxChannelApi()?.channelKeysSetModels?.(entry.id, models)
+        } catch {
+          // 忽略：模型缓存写入失败不阻断切换。
+        }
+      }
+      const providerId = channelProviderId(entry.id)
+      // 默认 model：优先刚拉到的 models 首个；否则用 entry 已缓存的 models 首个；都没有则不派发
+      // 事件（仅更新激活项，避免切到一个没有 model 的 provider）。
+      const modelId = models.length > 0 ? models[0] : entry.models?.[0]
+      if (modelId) {
+        window.dispatchEvent(
+          new CustomEvent("cx:select-provider", { detail: { providerID: providerId, modelID: modelId } }),
+        )
+      }
+      await reload()
+    } catch {
+      // 忽略：切换失败不让面板崩溃。
+    } finally {
+      setSwitchingId(null)
+    }
+  }
+
+  return (
+    <Dialog size="large" fit>
+      <DialogHeader closeLabel="关闭">
+        <DialogTitle>账户</DialogTitle>
+      </DialogHeader>
+      <DialogBody class="cx-account-body">
+        <Switch>
+          <Match when={initializing()}>
+            <div data-slot="cx-state-box">正在加载…</div>
+          </Match>
+
+          {/* [cx] US-011: 首启无 key 引导。 */}
+          <Match when={keys().length === 0}>
+            <div data-slot="cx-onboard">
+              <div data-slot="cx-onboard-title">还没有可用的 key</div>
+              <div data-slot="cx-onboard-desc">
+                导入一个 API Key（sk-…）即可开始使用。
+                <br />
+                在下方粘贴你的 key 完成导入。
+              </div>
+              <AddKeyForm onAdd={handleAdd} startOpen />
+            </div>
+          </Match>
+
+          {/* [cx] 两栏。左＝账户卡（环形图＋充值＋用量小结），右＝key 列表（内部滚动）。 */}
+          <Match when={keys().length > 0}>
+            <div data-slot="cx-columns">
+              {/* ── 左：账户卡 ── */}
+              <div data-slot="cx-account-col">
+                <Switch>
+                  <Match when={(activeProfile()?.status ?? "loading") === "loading"}>
+                    <div data-slot="cx-donut">
+                      <ProgressCircleV2 percentage={0} size={132} strokeWidth={10} class="cx-donut-ring" />
+                      <div data-slot="cx-donut-center">
+                        <div data-slot="cx-donut-label">加载中…</div>
+                      </div>
+                    </div>
+                  </Match>
+
+                  <Match when={(activeProfile()?.status ?? "loading") === "error"}>
+                    <div data-slot="cx-donut">
+                      <ProgressCircleV2 percentage={0} size={132} strokeWidth={10} class="cx-donut-ring" />
+                      <div data-slot="cx-donut-center">
+                        <div data-slot="cx-donut-label" data-error="">
+                          获取失败
+                        </div>
+                      </div>
+                    </div>
+                  </Match>
+
+                  <Match when={activeProfile() as Extract<KeyProfileState, { status: "ready" }>} keyed>
+                    {(ready) => (
+                      <>
+                        {/* 环形图：accent 弧段=已用占比，中心=剩余余额。 */}
+                        <div data-slot="cx-donut">
+                          <ProgressCircleV2
+                            percentage={usedPercent(ready.usedQuota, ready.quota)}
+                            size={132}
+                            strokeWidth={10}
+                            class="cx-donut-ring"
+                          />
+                          <div data-slot="cx-donut-center">
+                            <div data-slot="cx-donut-balance">
+                              {ready.unlimited ? "不限额" : formatCurrency(Math.max(0, ready.quota - ready.usedQuota))}
+                            </div>
+                            <div data-slot="cx-donut-label">余额 Balance</div>
+                          </div>
+                        </div>
+
+                        <ButtonV2
+                          variant="contrast"
+                          size="large"
+                          class="cx-topup-button"
+                          disabled={!topupUrl()}
+                          onClick={() => openTopup(topupUrl())}
+                        >
+                          充值
+                        </ButtonV2>
+                        <Show when={!topupUrl()}>
+                          <div data-slot="cx-hint">未配置充值地址</div>
+                        </Show>
+
+                        <div data-slot="cx-usage-box">
+                          <div data-slot="cx-usage-title">用量 Usage</div>
+                          <div data-slot="cx-usage-row">
+                            <span>今日消耗</span>
+                            <span data-slot="cx-usage-value">
+                              {ready.usedToday === null ? "—" : formatCurrency(ready.usedToday)}
+                            </span>
+                          </div>
+                          <div data-slot="cx-usage-row">
+                            <span>账户总额</span>
+                            <span data-slot="cx-usage-value">{ready.unlimited ? "不限额" : formatCurrency(ready.quota)}</span>
+                          </div>
+                          <div data-slot="cx-usage-row">
+                            <span>已用</span>
+                            <span data-slot="cx-usage-value">{formatCurrency(ready.usedQuota)}</span>
+                          </div>
+                          <Show when={!ready.unlimited}>
+                            <div data-slot="cx-usage-row">
+                              <span>使用率</span>
+                              <span data-slot="cx-usage-value">{usedPercent(ready.usedQuota, ready.quota)}%</span>
+                            </div>
+                          </Show>
+                        </div>
+                      </>
+                    )}
+                  </Match>
+                </Switch>
+              </div>
+
+              {/* ── 右：key 列表 ── */}
+              <div data-slot="cx-key-col">
+                <div data-slot="cx-key-col-head">
+                  <span data-slot="cx-key-col-title">
+                    Key 列表 <span data-slot="cx-key-count">· {keys().length}</span>
+                  </span>
+                  <span data-slot="cx-key-col-actions">
+                    <ButtonV2 variant="neutral" size="small" disabled={anyLoading()} onClick={refreshAll}>
+                      {anyLoading() ? "刷新中…" : "刷新"}
+                    </ButtonV2>
+                    <span data-slot="cx-key-col-tip">点击卡片切换激活</span>
+                  </span>
+                </div>
+                <div data-slot="cx-key-list">
+                  <For each={keys()}>
+                    {(entry) => (
